{
  "name": "giraffe-crm",
  "version": "0.0.0",
  "private": true,
  "description": "Giraffe CRM — Fase 1. Story 1.1: esqueleto executável e ambiente base (monorepo front+back).",
  "packageManager": "pnpm@10.2.0+sha512.0d27364e0139c6aadeed65ada153135e0ca96c8da42123bd50047f961339dc7a758fc2e944b428f52be570d1bd3372455c1c65fa2e7aa0bfbf931190f9552001",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:ci": "pnpm --filter @giraffe/api test:ci && pnpm --filter @giraffe/web test:ci",
    "test:local": "node scripts/test-preflight.mjs && pnpm test:ci",
    "smoke": "node scripts/smoke.mjs",
    "compose:up": "docker compose up --build -d",
    "compose:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "sharp": "^0.35.0",
      "postcss": "^8.5.12"
    }
  }
}
