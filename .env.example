# ─────────────────────────────────────────────────────────────
# Giraffe CRM — exemplo de variáveis (SEM valores sensíveis)
# Copie para .env (NUNCA versione o .env real).
# ─────────────────────────────────────────────────────────────

# ── API (apps/api) — variáveis PRIVADAS (servidor) ──
NODE_ENV=development
API_PORT=3001
# Origens permitidas para CORS (separadas por vírgula). Sem wildcard em produção.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Nível de log: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info

# ── BANCO: bootstrap dos papéis (consumidas pelo docker-compose) ──
# NÃO têm valor padrão no Compose: variável ausente faz o `compose up` falhar, em vez de
# subir com uma senha conhecida e versionada (Constitution VI — sem credencial padrão).
POSTGRES_PASSWORD=CHANGE_ME
MIGRATOR_PASSWORD=CHANGE_ME
APP_PASSWORD=CHANGE_ME

# ── BANCO (apps/api) — DOIS papéis distintos, nunca o mesmo (AD-6) ──
# Runtime da aplicação: papel SEM BYPASSRLS e NÃO proprietário das tabelas.
# É este que o RLS obriga a respeitar o isolamento por Organização.
DATABASE_URL=postgresql://giraffe_app:CHANGE_ME@localhost:5434/giraffe?schema=public
# Migrations: papel dono do schema. NUNCA usado para servir requisição.
MIGRATION_DATABASE_URL=postgresql://giraffe_migrator:CHANGE_ME@localhost:5434/giraffe?schema=public

# ── WEB (apps/web) — variável de SERVIDOR (lida server-side; NÃO exposta ao browser) ──
# URL base da API interna consumida pela Web no servidor. Em Docker Compose use http://api:3001.
API_BASE_URL=http://localhost:3001

# ── Story 1.4 — autenticação e antiabuso ────────────────────────────────────────
# Assinatura da sessão. Gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=
# URL pública da API (cookies e callbacks).
BETTER_AUTH_URL=http://localhost:3001

# Segredo do HMAC que deriva a chave do contador de falhas de login (G1).
# Separado do BETTER_AUTH_SECRET de propósito: comprometer um não deve entregar o
# outro, e eles têm ciclos de rotação diferentes. Gere com: openssl rand -hex 32
LOGIN_HMAC_SECRET=
# Versão do segredo acima. INCREMENTE ao rotacionar.
LOGIN_HMAC_KEY_VERSION=1

# Segredo ANTERIOR, apenas durante a janela de sobreposição da rotação. Deixe VAZIO
# fora de uma rotação em curso.
# Sem ele, trocar o segredo muda todas as chaves derivadas de uma vez e os contadores
# de quem está sob ataque AGORA viram órfãos: todo atacante em curso ganharia 5
# tentativas novas, no exato instante da rotação.
# Sobreposição mínima: 15 min (a janela do G1) + margem. Recomendado: 1 h.
# Procedimento completo: docs/04-operacao/rotacao-do-segredo-hmac.md
LOGIN_HMAC_PREVIOUS_SECRET=
LOGIN_HMAC_PREVIOUS_KEY_VERSION=

# Endereços dos PROXIES confiáveis (IPs exatos, separados por vírgula).
# VAZIO por padrão, e isso é a decisão: só o endereço de um peer listado aqui
# autoriza a leitura do X-Forwarded-For. Para todos os demais, o IP é o do SOCKET e o
# header é IGNORADO — quem fala direto com a aplicação não tem autoridade para dizer
# quem é. (O Better Auth sozinho NÃO faz isso: ele confia num X-Forwarded-For de
# valor único. Quem resolve o IP aqui é kernel/auth/client-ip.ts.)
# NUNCA use faixa privada ampla (10.0.0.0/8) aqui: isso declara confiável qualquer
# coisa dentro da rede, inclusive um contêiner comprometido. São os SEUS proxies.
# Faixas CIDR (com "/") não são suportadas nesta versão (débito D-02): use IPs exatos.
TRUSTED_PROXY_IPS=

# Opt-in para rodar em PRODUÇÃO sem proxy confiável (exposição direta, IP do socket).
# Em produção, TRUSTED_PROXY_IPS vazio SEM este opt-in FALHA no boot — para ninguém
# subir atrás de um proxy com o G2 (por IP) colapsado num balde único por esquecimento.
# Fora de produção é ignorado. Deixe vazio a menos que a exposição seja mesmo direta.
ALLOW_DIRECT_EXPOSURE=

# Capacidade de UPLOAD de arquivos (Story 2.4, gate do Campo Arquivo — AD-28). Fail-closed:
# o tipo de Campo Arquivo existe no catálogo, mas o armazenamento é do Épico 3. Enquanto NÃO
# for "true", um Formulário com Campo Arquivo ativo não pode ser publicado (2.6). Só "true"
# habilita; ausência ou qualquer outro valor mantém desabilitado. Deixe vazio até o E3.
FILE_UPLOAD_ENABLED=
