# ─────────────────────────────────────────────────────────────
# Giraffe CRM — exemplo de variáveis (SEM valores sensíveis)
# Copie para .env (NUNCA versione o .env real).
# ─────────────────────────────────────────────────────────────

# ── API (apps/api) — variáveis PRIVADAS (servidor) ──
NODE_ENV=development
API_PORT=3001
# Origens permitidas para CORS (separadas por vírgula). Sem wildcard em produção.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Nível de log: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info

# ── BANCO: bootstrap dos papéis (consumidas pelo docker-compose) ──
# NÃO têm valor padrão no Compose: variável ausente faz o `compose up` falhar, em vez de
# subir com uma senha conhecida e versionada (Constitution VI — sem credencial padrão).
POSTGRES_PASSWORD=CHANGE_ME
MIGRATOR_PASSWORD=CHANGE_ME
APP_PASSWORD=CHANGE_ME

# ── BANCO (apps/api) — DOIS papéis distintos, nunca o mesmo (AD-6) ──
# Runtime da aplicação: papel SEM BYPASSRLS e NÃO proprietário das tabelas.
# É este que o RLS obriga a respeitar o isolamento por Organização.
DATABASE_URL=postgresql://giraffe_app:CHANGE_ME@localhost:5434/giraffe?schema=public
# Migrations: papel dono do schema. NUNCA usado para servir requisição.
MIGRATION_DATABASE_URL=postgresql://giraffe_migrator:CHANGE_ME@localhost:5434/giraffe?schema=public

# ── WEB (apps/web) — variável de SERVIDOR (lida server-side; NÃO exposta ao browser) ──
# URL base da API interna consumida pela Web no servidor. Em Docker Compose use http://api:3001.
API_BASE_URL=http://localhost:3001

# ── Story 1.4 — autenticação e antiabuso ────────────────────────────────────────
# Assinatura da sessão. Gere com: openssl rand -hex 32
BETTER_AUTH_SECRET=
# URL pública da API (cookies e callbacks).
BETTER_AUTH_URL=http://localhost:3001

# Segredo do HMAC que deriva a chave do contador de falhas de login (G1).
# Separado do BETTER_AUTH_SECRET de propósito: comprometer um não deve entregar o
# outro, e eles têm ciclos de rotação diferentes. Gere com: openssl rand -hex 32
LOGIN_HMAC_SECRET=
# Versão do segredo acima. INCREMENTE ao rotacionar — a rotação faz os contadores
# antigos expirarem com a janela (15 min), em vez de sumirem em silêncio.
LOGIN_HMAC_KEY_VERSION=1

# Endereços dos PROXIES confiáveis (IP ou CIDR, separados por vírgula).
# VAZIO por padrão, e isso é a decisão: sem proxy confiável, o IP vem do socket —
# que ninguém pode forjar. Confiar em X-Forwarded-For sem saber quem o escreveu é o
# mesmo que não ter limite por IP: o atacante forja o header e cada requisição chega
# de um "IP" novo.
# NUNCA use faixa privada ampla (10.0.0.0/8) aqui: isso declara confiável qualquer
# coisa dentro da rede, inclusive um contêiner comprometido. São os SEUS proxies.
TRUSTED_PROXY_IPS=
