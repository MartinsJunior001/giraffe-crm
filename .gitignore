# Dependências
node_modules/

# Builds
dist/
.next/
out/
build/
# Cache de compilação incremental do TS (regenerado pelo typecheck; específico da máquina)
*.tsbuildinfo

# Testes
coverage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Ambiente — segredos NUNCA versionados (só os exemplos)
.env
.env.*
!.env.example
# Exemplos versionados (SEM segredos): .env.example e .env.<contexto>.example (ex.: .env.test.example).
# A negação vem depois do `.env.*` para reincluir só os templates, nunca um .env real.
!.env.*.example

# Next
next-env.d.ts
.next/

# SO / editor
.DS_Store
Thumbs.db

# Prisma Client gerado (artefato de build — regenerado por `pnpm install`)
apps/api/generated/

# Overrides de banco por worktree (multi-lane) — nunca versionar
docker-compose.local-*.yml
