# .env.test.example — banco DESCARTÁVEL para a suíte local (DEB-ENV-TEST-REPRODUZIVEL)
#
# A suíte da API roda contra um PostgreSQL REAL. Sem um destino de teste declarado e reprodutível,
# ela acaba apontando para o .env de desenvolvimento — que pode estar mirando o banco de OUTRA lane,
# produzindo `P1000: Authentication failed` mascarado como dezenas de falhas de teste.
#
# Este arquivo NÃO contém segredos: as senhas são placeholders `CHANGE_ME`, iguais ao .env.example.
# Copie-o, defina senhas locais e suba o banco descartável do próprio Compose deste repositório —
# nunca aponte a suíte para um banco compartilhado ou de staging.
#
# Uso:
#   cp apps/api/.env.test.example .env      # (ou um .env.test dedicado, se preferir isolar)
#   # troque os CHANGE_ME por senhas locais quaisquer (o banco descartável é criado com elas)
#   docker compose up -d db                 # PostgreSQL 16; o bootstrap cria giraffe_migrator/giraffe_app
#   pnpm --filter @giraffe/api db:migrate   # aplica as migrations (papel giraffe_migrator)
#   pnpm --filter @giraffe/api db:seed      # fixtures de leitura (Orgs A/B/C)
#   pnpm test:local                         # preflight de banco + suíte serial reprodutível
#
# A porta 5434 é a padrão do Compose. Se ela já estiver ocupada por outra lane (outro worktree com
# o db no ar), remapeie a porta de host via override e ajuste as URLs abaixo — assim seu banco de
# teste fica ISOLADO do vizinho, que é exatamente o que evita o P1000.

# Senhas do banco descartável — placeholders; defina valores locais (não são segredos de produção).
POSTGRES_PASSWORD=CHANGE_ME
MIGRATOR_PASSWORD=CHANGE_ME
APP_PASSWORD=CHANGE_ME

# Runtime (papel giraffe_app) e migrations (papel giraffe_migrator). Host 127.0.0.1:5434 por padrão.
DATABASE_URL=postgresql://giraffe_app:CHANGE_ME@localhost:5434/giraffe?schema=public
MIGRATION_DATABASE_URL=postgresql://giraffe_migrator:CHANGE_ME@localhost:5434/giraffe?schema=public
