{
  "name": "@giraffe/api",
  "version": "0.0.0",
  "private": true,
  "description": "Giraffe CRM — API interna (NestJS): health/readiness e isolamento multi-tenant por RLS.",
  "main": "dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:migrate": "node ../../scripts/db-migrate.mjs deploy",
    "db:status": "node ../../scripts/db-migrate.mjs status",
    "db:seed": "node ../../scripts/db-migrate.mjs seed",
    "db:rollback": "node ../../scripts/db-migrate.mjs rollback"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "6.19.3",
    "better-auth": "^1.6.23",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "6.19.3",
    "vitest": "^4.0.0"
  }
}
