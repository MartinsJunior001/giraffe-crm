  phaseId                String              @db.Uuid
  formId                 String              @db.Uuid
  formVersionId          String              @db.Uuid
  /// Chave lГіgica da submissГЈo (cliente). Garante idempotГЄncia via Г­ndice Гєnico org+form.
  idempotencyKey         String
  /// Valores submetidos, chaveados por `Field.id` do snapshot (opГ§ГЈo por `id`). Validados contra a versГЈo.
  valores                Json                @default("{}")
  /// Origem do Card (Story 2.8): submissГЈo interna (`INTERNAL`, 2.7) ou pГєblica (`PUBLIC`, aprovada/direta).
  origin                 CardOrigin          @default(INTERNAL)
  /// Estado de CICLO DE VIDA (Story 2.11), eixo INDEPENDENTE da Fase (`Fase в‰  Status do Card`) e da saГєde temporal
  /// (2.13). TrГЄs estados canГґnicos; `reaberto`/`restaurado` sГЈo TRANSIГ‡Г•ES, nГЈo estados. Г‰ a ГљNICA coluna de `Card`
  /// que o runtime pode UPDATE (GRANT column-scoped na migration da 2.11) вЂ” junto de `previousLifecycleState` e
  /// `updatedAt`; `phaseId` (movimentaГ§ГЈo, 2.14) segue **sem** GRANT de UPDATE.
  lifecycleState         CardLifecycleState  @default(ATIVO)
  /// Estado ANTERIOR ao arquivamento (ATIVO ou FINALIZADO), para restaurar de forma confiГЎvel (AC 2.11). Nulo fora
  /// de ARQUIVADO. Preenchido ao arquivar, limpo ao restaurar.
  previousLifecycleState CardLifecycleState?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe             Pipe              @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  phase            Phase             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  form             Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
