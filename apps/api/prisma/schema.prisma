// quem nega. Ler `prisma/migrations/*/migration.sql` antes de mexer aqui.

generator client {
  provider = "prisma-client-js"
  // SaГ­da EXPLГЌCITA, fora de `node_modules`. Por padrГЈo o Prisma escreve o client dentro do
  // pacote `@prisma/client` no store do pnpm, num caminho com hash de peer-dependency вЂ” que
