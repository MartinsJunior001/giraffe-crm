// Modelo multi-tenant — Story 1.2.
//
// O isolamento NÃO é garantido por este schema, e sim pelas policies de RLS na
// migration `..._init_tenancy_rls`. Este arquivo descreve as tabelas; o banco é
// quem nega. Ler `prisma/migrations/*/migration.sql` antes de mexer aqui.

generator client {
  provider = "prisma-client-js"
  // Saída EXPLÍCITA, fora de `node_modules`. Por padrão o Prisma escreve o client dentro do
  // pacote `@prisma/client` no store do pnpm, num caminho com hash de peer-dependency — que
  // MUDA entre uma instalação completa e uma `--prod`. Resultado: a imagem de produção subia
  // sem o client, ou só ficava correta carregando 465 MB de devDependencies junto.
  // Um diretório estável é copiável entre stages do Docker. (Também é o formato exigido
  // pelo Prisma 7.)
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Runtime → papel `giraffe_app` (sem BYPASSRLS, não proprietário).
  // Migrations → o script `db:migrate` substitui esta URL pela do `giraffe_migrator`.
  url      = env("DATABASE_URL")
}

/// Papel do vínculo com a Organização. Papel ÚNICO por Membership (AD-7).
/// Origem: NFR-4 canônico (Admin da Org / Membro / Convidado). NÃO inventar papéis.
/// Super Admin NÃO está aqui: é papel de Plataforma e não concede acesso a dados
/// de Organização (INV-ADMIN-01).
enum MembershipRole {
  ADMIN
  MEMBER
  GUEST
}

/// Estado do vínculo. `REMOVED` É a remoção lógica exigida pelo AC2 — por isso
/// NÃO existe `deletedAt` paralelo (fonte de verdade única — AD-14).
enum MembershipState {
  ACTIVE
  SUSPENDED
  REMOVED
}

/// Estado do Pipe (Story 2.1). Arquivar é MUDANÇA DE ESTADO, não exclusão — não há transição
/// para "deletado" (o runtime nem tem GRANT DELETE). `ARCHIVED` preserva todos os dados.
enum PipeState {
  ACTIVE
  ARCHIVED
}

/// Papel POR Pipe (Story 2.2, decisão de Produto D1.4). Conjunto enxuto e fechado:
/// ADMIN administra a CONFIG do Pipe (não o ciclo de vida — isso é do Admin da Org, Story 2.1);
/// MEMBER edita os recursos acessíveis do Pipe; VIEWER (Somente leitura) consulta sem editar/mover.
enum PipeRole {
  ADMIN
  MEMBER
  VIEWER
}

/// Estado da concessão de papel por Pipe (Story 2.2). Revogar é MUDANÇA DE ESTADO, não exclusão —
/// preserva a trilha (simétrico a `MembershipState`); o runtime não tem GRANT DELETE.
enum PipeGrantState {
  ACTIVE
  REVOKED
}

/// Identidade GLOBAL da Plataforma (AD-7/AD-10).
/// Sem `orgId` e SEM RLS: a conta não pertence a nenhuma Organização — é o
/// Membership que a vincula. `email` é PII (LGPD): minimizado, nunca em log.
///
/// Story 1.4: esta tabela É o `user` do Better Auth (`user: { modelName: 'Account' }`).
/// Não existe uma segunda tabela de pessoas, e isso é deliberado. Deixar o Better Auth
/// criar o `user` dele daria DUAS identidades — `user`, dona da sessão, e `Account`,
/// dona da Membership — a serem sincronizadas para sempre. Toda divergência entre elas
/// (um `user` sem `Account`, um e-mail atualizado num lado só) é um bug de identidade,
/// que é a classe de bug que termina em "o usuário X viu os dados do usuário Y".
/// Uma identidade, uma tabela.
model Account {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  /// Exigidos pelo Better Auth. `emailVerified` não governa acesso nesta Story —
  /// quem governa é a Membership ativa (1.3). Verificação de e-mail é da Story 1.10.
  emailVerified Boolean @default(false)
  image         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  sessions    AuthSession[]
  credentials AuthCredential[]

  @@map("Account")
}

/// Sessão emitida pelo Better Auth (o `session` dele).
///
/// GLOBAL, como `Account` e pela mesma razão (AD-10): uma sessão é da PESSOA, não de uma
/// Organização. Sem `orgId`, sem RLS.
///
/// `activeOrganizationId` é um PEDIDO persistido, jamais autoridade. Quem decide se ele
/// vale é o `OrgContextResolver` da Story 1.3, conferindo contra a Membership ativa. Tratá-lo
/// como autoridade — "a sessão diz que ele é da Org X, logo é" — reabriria exatamente o buraco
/// que a 1.3 fechou: bastaria uma Membership ser suspensa para a sessão continuar valendo.
model AuthSession {
  id                   String   @id
  token                String   @unique
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String?  @db.Uuid
  userId               String   @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthSession")
}

/// O `account` do Better Auth, renomeado — e o nome importa.
///
/// Ela NÃO guarda "contas": guarda hash de senha e vínculos com provedores externos. Manter
/// o nome original num sistema onde `Account` significa "a identidade da pessoa" seria um
/// convite permanente ao erro, além de colidir com o nosso model (nome de model em Prisma é
/// único).
model AuthCredential {
  id                    String    @id
  /// Identificador da conta NO PROVEDOR (não é o nosso `Account.id`).
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  /// Hash da senha (credential provider). NUNCA em log, erro, métrica ou resposta.
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthCredential")
}

/// Tokens de verificação do Better Auth (`verification`).
model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("AuthVerification")
}

/// Contador do rate limit NATIVO do Better Auth (G2): chave = `${ip}|${path}`.
///
/// Vive no BANCO, não em memória. O padrão do Better Auth é `storage: 'memory'`, e memória
/// (a) não sobrevive a restart — o atacante zera a contagem esperando o container reciclar — e
/// (b) não é compartilhada entre instâncias: com 3 réplicas, o limite efetivo TRIPLICA. Um
/// limite assim não é uma proteção, é um enfeite.
model RateLimit {
  /// Sem default: quem preenche é o `generateId` do Better Auth (ver `auth.factory.ts`). Um default
  /// aqui só mascararia uma eventual regressão daquela configuração — e o INSERT sem `id` deve
  /// falhar alto, não ser silenciosamente remendado pelo schema.
  id          String @id
  key         String @unique
  count       Int
  lastRequest BigInt

  @@map("RateLimit")
}

/// Contador de FALHAS por identificador (G1). Nosso, e obrigatoriamente nosso.
///
/// O rate limiter nativo do Better Auth chaveia por `${ip}|${path}` e conta SOLICITAÇÕES —
/// verificado na fonte. Ele faz o G2 e é incapaz de fazer o G1. Confiar nele para as duas
/// coisas deixaria a força bruta dirigida a UMA conta sem proteção alguma: um atacante com uma
/// lista de e-mails, testando uma senha comum em cada, nunca estoura um limite por conta.
///
/// `key` é o HMAC do identificador NORMALIZADO, com prefixo de finalidade — nunca o e-mail em
/// claro. E-mail é PII: guardá-lo aqui criaria um segundo cadastro de e-mails, fora do controle
/// de `Account`, e um dump desta tabela viraria uma lista de usuários.
model LoginFailure {
  /// HMAC-SHA256(`login:` + e-mail normalizado), hex.
  key         String   @id
  /// Versão do segredo que gerou a chave (D6 — rotação sem zerar contadores em silêncio).
  keyVersion  Int
  count       Int
  windowStart DateTime

  @@map("LoginFailure")
}

/// Raiz do tenant. Toda linha organizacional aponta para cá.
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  pipes       Pipe[]
  pipeGrants  PipeGrant[]

  @@map("Organization")
}

/// Pipe — processo de trabalho da Organização (Story 2.1). Dado operacional org-owned (AD-10).
///
/// Isolamento pelo BANCO (RLS na migration `..._pipes`), como `Organization`/`Membership`: ENABLE
/// **e** FORCE ROW LEVEL SECURITY, policies por `orgId = current_org_id()`. O runtime recebe
/// SELECT/INSERT/UPDATE — **sem DELETE** (o épico proíbe exclusão definitiva; arquivar é `state`).
///
/// **Sem unicidade de `name`**: o identificador estável é o `id` (AD-11). Nome único org-scoped
/// colidiria no restaurar (arquiva "X", cria novo "X", restaura o antigo). RN-024 (catálogo
/// consistente) é sobre exibição por id, não unicidade de rótulo.
model Pipe {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @db.Uuid
  name       String
  state      PipeState @default(ACTIVE)
  /// Atributos de catálogo (Story 2.1): sem semântica de bloqueio inventada — só persistidos/alternáveis.
  locked     Boolean   @default(false)
  starred    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  /// Momento do arquivamento (null quando ativo). Arquivar preserva os dados; só muda estado.
  archivedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grants       PipeGrant[]

  // Todo acesso organizacional começa por `orgId`; o catálogo filtra por estado.
  @@index([orgId, state])
  @@map("Pipe")
}

/// PipeGrant — concessão explícita de papel POR Pipe (Story 2.2, decisão D1.4). Dado operacional
/// org-owned (AD-10). É o que abre o acesso de MEMBER/GUEST a um Pipe: sem concessão ACTIVE, não há
/// acesso (deny-by-default). O Admin da Organização acessa todos os Pipes SEM concessão (Story 2.1).
///
/// Liga-se a `Membership` (não a `Account`): o papel por Pipe vive DENTRO de uma Organização, e a
/// Membership é o vínculo Account×Org que já carrega `orgId` e estado (AD-7). Ligar à Account global
/// reabriria a porta de uma concessão "sem Org".
///
/// Isolamento pelo BANCO (RLS na migration `..._pipe_grants`): ENABLE **e** FORCE ROW LEVEL SECURITY,
/// policies por `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**:
/// revogar é `state = REVOKED`, não exclusão (preserva a trilha).
///
/// **No máximo UM papel efetivo por Pipe por pessoa**: índice único PARCIAL `(pipeId, membershipId)
/// WHERE state = 'ACTIVE'`, criado por raw SQL na migration (o Prisma 6.19.3 não expressa índice
/// parcial no schema — é v7.4+). Uma concessão revogada não colide com uma re-concessão.
model PipeGrant {
  id           String         @id @default(uuid()) @db.Uuid
  orgId        String         @db.Uuid
  pipeId       String         @db.Uuid
  membershipId String         @db.Uuid
  role         PipeRole
  state        PipeGrantState @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  /// Momento da revogação (null quando ativa). Revogar preserva a linha; só muda estado.
  revokedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe         Pipe         @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Acesso começa por Org; consultas por Pipe (quem acessa) e por pessoa (quais Pipes).
  @@index([orgId, pipeId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "um papel ativo por (pipe, pessoa)" é um índice PARCIAL, criado na migration
  // (WHERE state='ACTIVE') — não expressável aqui no Prisma 6.19.3.
  @@map("PipeGrant")
}

/// Vínculo Account × Organization (AD-7, Forma B). É a tabela organizacional
/// desta Story — e a fixture dos testes de isolamento.
model Membership {
  id        String          @id @default(uuid()) @db.Uuid
  accountId String          @db.Uuid
  orgId     String          @db.Uuid
  role      MembershipRole
  state     MembershipState @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipeGrants   PipeGrant[]

  // Uma conta tem no máximo UM vínculo por Organização (papel único — AD-7).
  @@unique([accountId, orgId])
  // Todo acesso organizacional começa por `orgId` → primeira coluna do índice.
  @@index([orgId, state])
  // Descoberta das próprias Organizações no login (Story 1.4), antes de haver contexto.
  @@index([accountId])
  @@map("Membership")
}
