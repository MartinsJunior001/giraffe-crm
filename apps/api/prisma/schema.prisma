  /// Chave de correlaГ§ГЈo da operaГ§ГЈo (linka evento в†” MOVED в†” CardPhaseEntry da mesma movimentaГ§ГЈo).
  correlationId String   @db.Uuid
  /// Tipo do envelope canГґnico (ex.: `CARD_MOVED`). VersГЈo do contrato do envelope.
  type          String
