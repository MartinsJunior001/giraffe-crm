  cardId         String?               @db.Uuid
  /// Chave de idempotГЄncia do cliente pГєblico (dedup de reenvio da mesma submissГЈo lГіgica).
  idempotencyKey String?
  /// Ator que decidiu a triagem (aprovou/rejeitou), quando aplicГЎvel.
  decidedBy      String?               @db.Uuid
  decidedAt      DateTime?
  createdAt      DateTime              @default(now())
