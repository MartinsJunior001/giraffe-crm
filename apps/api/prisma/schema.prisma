/// **Sem exclusГЈo** (preserva por GovernanГ§a/LGPD вЂ” NFR-8): o runtime tem `SELECT/INSERT/UPDATE`, **sem DELETE**.
/// Isolamento pelo banco (RLS ENABLE+FORCE, policies por `current_org_id()`, WITH CHECK). **IdempotГЄncia** da
/// conversГЈo: `cardId` Г© Гєnico (`@@unique`) e o estado terminal `CONVERTED` guarda contra reconversГЈo вЂ” nunca 2
/// Cards. `valores` sГЈo PII de titular externo: NUNCA em log.
model SubmissaoPublica {
