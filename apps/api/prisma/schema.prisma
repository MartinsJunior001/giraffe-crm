/// como autoridade вЂ” "a sessГЈo diz que ele Г© da Org X, logo Г©" вЂ” reabriria exatamente o buraco
/// que a 1.3 fechou: bastaria uma Membership ser suspensa para a sessГЈo continuar valendo.
model AuthSession {
