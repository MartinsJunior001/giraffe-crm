// Modelo multi-tenant — Story 1.2.
//
// O isolamento NÃO é garantido por este schema, e sim pelas policies de RLS na
// migration `..._init_tenancy_rls`. Este arquivo descreve as tabelas; o banco é
// quem nega. Ler `prisma/migrations/*/migration.sql` antes de mexer aqui.

generator client {
  provider = "prisma-client-js"
  // Saída EXPLÍCITA, fora de `node_modules`. Por padrão o Prisma escreve o client dentro do
  // pacote `@prisma/client` no store do pnpm, num caminho com hash de peer-dependency — que
  // MUDA entre uma instalação completa e uma `--prod`. Resultado: a imagem de produção subia
  // sem o client, ou só ficava correta carregando 465 MB de devDependencies junto.
  // Um diretório estável é copiável entre stages do Docker. (Também é o formato exigido
  // pelo Prisma 7.)
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Runtime → papel `giraffe_app` (sem BYPASSRLS, não proprietário).
  // Migrations → o script `db:migrate` substitui esta URL pela do `giraffe_migrator`.
  url      = env("DATABASE_URL")
}

/// Papel do vínculo com a Organização. Papel ÚNICO por Membership (AD-7).
/// Origem: NFR-4 canônico (Admin da Org / Membro / Convidado). NÃO inventar papéis.
/// Super Admin NÃO está aqui: é papel de Plataforma e não concede acesso a dados
/// de Organização (INV-ADMIN-01).
enum MembershipRole {
  ADMIN
  MEMBER
  GUEST
}

/// Estado do vínculo. `REMOVED` É a remoção lógica exigida pelo AC2 — por isso
/// NÃO existe `deletedAt` paralelo (fonte de verdade única — AD-14).
enum MembershipState {
  ACTIVE
  SUSPENDED
  REMOVED
}

/// Tipo do evento canônico do ciclo de Membership. `ROLE_CHANGED` (8.4 — alteração de papel);
/// `SUSPENDED`/`REACTIVATED` (8.5 — transição de estado da Membership); `REMOVED` (8.6 — encerramento
/// por remoção administrativa OU saída voluntária, distinguidas por `payload.saidaVoluntaria` +
/// `actorId`). Tudo aqui, sem tabela nova. O `version` da linha versiona o contrato do envelope
/// (AD-13), como em `MovementEvent`. Suspender/reativar/remover NÃO mudam papel: nesses eventos
/// `fromRole = toRole` (papel preservado) e o `payload` carrega `{ fromState, toState, … }` (sem PII).
enum MembershipEventType {
  ROLE_CHANGED
  SUSPENDED
  REACTIVATED
  REMOVED
}

/// Estado do Pipe (Story 2.1). Arquivar é MUDANÇA DE ESTADO, não exclusão — não há transição
/// para "deletado" (o runtime nem tem GRANT DELETE). `ARCHIVED` preserva todos os dados.
enum PipeState {
  ACTIVE
  ARCHIVED
}

/// Estado do Database (Story 3.1). Twin de `PipeState`, entidade DISTINTA (Database ≠ Pipe — RN-061).
/// Arquivar é MUDANÇA DE ESTADO, não exclusão (runtime sem GRANT DELETE) e coloca o Database em
/// SOMENTE-LEITURA INTEGRAL: em `ARCHIVED`, renomear é bloqueado (409) e a única escrita é `restaurar`.
enum DatabaseState {
  ACTIVE
  ARCHIVED
}

/// Papel POR Database (Story 3.2, decisão de Produto D3.4). Distinto de `PipeRole` (RN-061 — Database ≠ Pipe):
/// ADMIN (Admin do Database) configura/administra a estrutura e concede MEMBER/VIEWER; NÃO controla o ciclo de
/// vida do Database (Admin da Org, Story 3.1) nem Memberships da Org; MEMBER (Membro do Database) cria/edita
/// Registros (poder DIFERENCIAL = contrato futuro 3.4 — role dormente); VIEWER (Somente leitura) consulta.
enum DatabaseRole {
  ADMIN
  MEMBER
  VIEWER
}

/// Estado da concessão de papel por Database (Story 3.2). Revogar é MUDANÇA DE ESTADO, não exclusão —
/// preserva a trilha (simétrico a `PipeGrantState`); o runtime não tem GRANT de DELETE.
enum DatabaseGrantState {
  ACTIVE
  REVOKED
}

/// Papel POR Pipe (Story 2.2, decisão de Produto D1.4). Conjunto enxuto e fechado:
/// ADMIN administra a CONFIG do Pipe (não o ciclo de vida — isso é do Admin da Org, Story 2.1);
/// MEMBER edita os recursos acessíveis do Pipe; VIEWER (Somente leitura) consulta sem editar/mover.
enum PipeRole {
  ADMIN
  MEMBER
  VIEWER
}

/// Estado da concessão de papel por Pipe (Story 2.2). Revogar é MUDANÇA DE ESTADO, não exclusão —
/// preserva a trilha (simétrico a `MembershipState`); o runtime não tem GRANT DELETE.
enum PipeGrantState {
  ACTIVE
  REVOKED
}

/// Estado da Fase (Story 2.3). Arquivar é MUDANÇA DE ESTADO, não exclusão (simétrico a `PipeState`);
/// o runtime não tem GRANT DELETE. `ARCHIVED` preserva os dados e a posição na ordem é recalculada ao
/// restaurar (volta ao final da ordem ativa).
enum PhaseState {
  ACTIVE
  ARCHIVED
}

/// Catálogo CANÔNICO de tipos de Campo (Story 2.4, decisão de Produto D3.1). Conjunto FECHADO de 12 tipos,
/// o MESMO para toda Organização — é de PLATAFORMA (enum de código, como `PipeRole`), NÃO um catálogo
/// configurável por Organização. O que é dado org-scoped são as instâncias de `Field`, não o catálogo.
/// `FILE` existe no catálogo mas fica gated (AD-27/AD-28, fail-closed) até a capacidade de arquivos do E3.
enum FieldType {
  TEXT_SHORT
  TEXT_LONG
  NUMBER
  SELECT_SINGLE
  SELECT_MULTI
  BOOLEAN
  DATE
  DATETIME
  EMAIL
  PHONE
  URL
  FILE
}

/// Contexto de um Formulário (Story 2.4). Os três Formulários são INDEPENDENTES (INV-FORM-01): cada contexto
/// é uma LINHA distinta de `Form`, e alterar um não altera outro. `DATABASE` existe como CONTRATO (o E3
/// reutiliza o mesmo builder), mas NÃO é funcional nesta Story — não há owner de Database nem rota que crie
/// uma linha `context = DATABASE` (AD-11: nada materializado só para o futuro).
enum FormContext {
  PIPE_INITIAL
  PHASE
  DATABASE
}

/// Estado do Campo (Story 2.4). O ATRIBUTO existe desde a 2.4; a OPERAÇÃO de arquivar/restaurar com travas é
/// da 2.5 (simétrico a `PhaseState`). O runtime não tem GRANT DELETE — "sem exclusão" é fronteira de banco.
enum FieldState {
  ACTIVE
  ARCHIVED
}

/// Modo da submissão pública de um Formulário inicial (Story 2.8, PRD D3.3). `TRIAGE` (padrão): a submissão NÃO
/// cria Card até ser aprovada na triagem. `DIRECT`: a submissão válida cria 1 Card imediatamente.
enum PublicFormMode {
  TRIAGE
  DIRECT
}

/// Origem do Card (Story 2.8). `INTERNAL`: submissão interna (2.7). `PUBLIC`: submissão pública aprovada/direta.
/// "Origem registrada" (PRD D3.3): atributo do Card, consultável — não metadado solto de evento.
enum CardOrigin {
  INTERNAL
  PUBLIC
}

/// Ciclo da Submissão pública (Story 2.8, PRD D3.3) — DISTINTO do estado do Card (`Fase ≠ Status do Card`).
/// `PENDING` (aguardando triagem) → `CONVERTED` (aprovada: 1 Card criado na MESMA transação) ou `REJECTED`
/// (não cria Card; submissão preservada — LGPD). Aprovação e conversão são atômicas na 2.8, então não há estado
/// `APPROVED` persistido separado (AD-11: sem materializar estado sem consumidor). `CONVERTED` é terminal:
/// uma submissão convertida não reconverte (idempotência — epics.md §884).
enum SubmissaoPublicaState {
  PENDING
  CONVERTED
  REJECTED
}

/// Identidade GLOBAL da Plataforma (AD-7/AD-10).
/// Sem `orgId` e SEM RLS: a conta não pertence a nenhuma Organização — é o
/// Membership que a vincula. `email` é PII (LGPD): minimizado, nunca em log.
///
/// Story 1.4: esta tabela É o `user` do Better Auth (`user: { modelName: 'Account' }`).
/// Não existe uma segunda tabela de pessoas, e isso é deliberado. Deixar o Better Auth
/// criar o `user` dele daria DUAS identidades — `user`, dona da sessão, e `Account`,
/// dona da Membership — a serem sincronizadas para sempre. Toda divergência entre elas
/// (um `user` sem `Account`, um e-mail atualizado num lado só) é um bug de identidade,
/// que é a classe de bug que termina em "o usuário X viu os dados do usuário Y".
/// Uma identidade, uma tabela.
model Account {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String
  /// Exigidos pelo Better Auth. `emailVerified` não governa acesso nesta Story —
  /// quem governa é a Membership ativa (1.3). Verificação de e-mail é da Story 1.10.
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships Membership[]
  sessions    AuthSession[]
  credentials AuthCredential[]
  /// Story 3.10: relação de LEITURA apenas. `AccountAvatar` é org-scoped e vive do lado protegido por
  /// RLS — esta back-relation NÃO adiciona coluna nem privilégio a `Account`, que segue SELECT-only.
  avatars     AccountAvatar[]

  @@map("Account")
}

/// Sessão emitida pelo Better Auth (o `session` dele).
///
/// GLOBAL, como `Account` e pela mesma razão (AD-10): uma sessão é da PESSOA, não de uma
/// Organização. Sem `orgId`, sem RLS.
///
/// `activeOrganizationId` é um PEDIDO persistido, jamais autoridade. Quem decide se ele
/// vale é o `OrgContextResolver` da Story 1.3, conferindo contra a Membership ativa. Tratá-lo
/// como autoridade — "a sessão diz que ele é da Org X, logo é" — reabriria exatamente o buraco
/// que a 1.3 fechou: bastaria uma Membership ser suspensa para a sessão continuar valendo.
model AuthSession {
  id                   String   @id
  token                String   @unique
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String?  @db.Uuid
  userId               String   @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthSession")
}

/// O `account` do Better Auth, renomeado — e o nome importa.
///
/// Ela NÃO guarda "contas": guarda hash de senha e vínculos com provedores externos. Manter
/// o nome original num sistema onde `Account` significa "a identidade da pessoa" seria um
/// convite permanente ao erro, além de colidir com o nosso model (nome de model em Prisma é
/// único).
model AuthCredential {
  id                    String    @id
  /// Identificador da conta NO PROVEDOR (não é o nosso `Account.id`).
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  /// Hash da senha (credential provider). NUNCA em log, erro, métrica ou resposta.
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthCredential")
}

/// Tokens de verificação do Better Auth (`verification`).
model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("AuthVerification")
}

/// Contador do rate limit NATIVO do Better Auth (G2): chave = `${ip}|${path}`.
///
/// Vive no BANCO, não em memória. O padrão do Better Auth é `storage: 'memory'`, e memória
/// (a) não sobrevive a restart — o atacante zera a contagem esperando o container reciclar — e
/// (b) não é compartilhada entre instâncias: com 3 réplicas, o limite efetivo TRIPLICA. Um
/// limite assim não é uma proteção, é um enfeite.
model RateLimit {
  /// Sem default: quem preenche é o `generateId` do Better Auth (ver `auth.factory.ts`). Um default
  /// aqui só mascararia uma eventual regressão daquela configuração — e o INSERT sem `id` deve
  /// falhar alto, não ser silenciosamente remendado pelo schema.
  id          String @id
  key         String @unique
  count       Int
  lastRequest BigInt

  @@map("RateLimit")
}

/// Contador de FALHAS por identificador (G1). Nosso, e obrigatoriamente nosso.
///
/// O rate limiter nativo do Better Auth chaveia por `${ip}|${path}` e conta SOLICITAÇÕES —
/// verificado na fonte. Ele faz o G2 e é incapaz de fazer o G1. Confiar nele para as duas
/// coisas deixaria a força bruta dirigida a UMA conta sem proteção alguma: um atacante com uma
/// lista de e-mails, testando uma senha comum em cada, nunca estoura um limite por conta.
///
/// `key` é o HMAC do identificador NORMALIZADO, com prefixo de finalidade — nunca o e-mail em
/// claro. E-mail é PII: guardá-lo aqui criaria um segundo cadastro de e-mails, fora do controle
/// de `Account`, e um dump desta tabela viraria uma lista de usuários.
model LoginFailure {
  /// HMAC-SHA256(`login:` + e-mail normalizado), hex.
  key         String   @id
  /// Versão do segredo que gerou a chave (D6 — rotação sem zerar contadores em silêncio).
  keyVersion  Int
  count       Int
  windowStart DateTime

  @@map("LoginFailure")
}

/// Raiz do tenant. Toda linha organizacional aponta para cá.
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships             Membership[]
  pipes                   Pipe[]
  databases               Database[]
  databaseGrants          DatabaseGrant[]
  pipeGrants              PipeGrant[]
  phases                  Phase[]
  forms                   Form[]
  fields                  Field[]
  formVersions            FormVersion[]
  cards                   Card[]
  cardHistories           CardHistory[]
  publicSubmissions       SubmissaoPublica[]
  publicFormRoutes        PublicFormRoute[]
  cardGrants              CardGrant[]
  cardResponsaveis        CardResponsavel[]
  cardPhaseEntries        CardPhaseEntry[]
  cardPhaseValues         CardPhaseValues[]
  movementEvents          MovementEvent[]
  records                 Record[]
  recordHistories         RecordHistory[]
  fileObjects             FileObject[]
  fileScans               FileScan[]
  cardRecordLinks         CardRecordLink[]
  accountAvatars          AccountAvatar[]
  automations             Automation[]
  automationVersions      AutomationVersion[]
  domainEvents            DomainEvent[]
  invites                 Invite[]
  membershipEvents        MembershipEvent[]
  automationExecutions    AutomationExecution[]
  automationActionResults AutomationActionResult[]
  automationChainVisits   AutomationChainVisit[]
  tasks                   Task[]
  taskHistories           TaskHistory[]
  taskOverdueOccurrences  TaskOverdueOccurrence[]
  solicitacoes            Solicitacao[]
  solicitacaoHistories    SolicitacaoHistory[]
  notifications           Notification[]
  notificationRecipients  NotificationRecipient[]

  @@map("Organization")
}

/// Estado do Convite (Story 8.2, D5.1). Terminais (ACCEPTED/EXPIRED/CANCELLED) NUNCA voltam a
/// PENDING. Sem "Membership pendente" — o Convite é entidade distinta da Membership.
enum InviteState {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

/// Convite — o ato org-scoped de trazer um e-mail para a Organização com um papel inicial (Story 8.2).
///
/// Token: só o HASH persiste (`tokenHash`); o valor utilizável só existe em memória ao emitir/enviar.
/// Unicidade "1 PENDING por (orgId, normalizedEmail)" é imposta pelo BANCO via índice único PARCIAL
/// (raw SQL na migration — o Prisma 6.19.3 não expressa índice parcial), espelhando o par ativo de
/// `DatabaseGrant`. Sem exclusão: cancelar/expirar é `state`; o runtime tem GRANT SELECT/INSERT/UPDATE
/// e **não** DELETE. RLS ENABLE+FORCE + WITH CHECK, como toda tabela organizacional.
model Invite {
  id                 String         @id @default(uuid()) @db.Uuid
  orgId              String         @db.Uuid
  /// Chave de unicidade (com orgId). Forma normalizada (trim+minúsculas) do e-mail convidado.
  normalizedEmail    String
  /// E-mail original de exibição (roster 8.7). NÃO é a chave — a chave é `normalizedEmail`.
  email              String
  /// Papel inicial concedido no aceite. Teto AD-9 (GUEST) aplicado no serviço.
  role               MembershipRole
  state              InviteState    @default(PENDING)
  /// SHA-256 (hex) do token. NUNCA o token bruto. Único: o lookup de aceite é por este hash.
  tokenHash          String         @unique
  /// Expiração derivada do prazo (7 dias). Reenvio recalcula e reinicia.
  expiresAt          DateTime
  /// Último envio (emissão/reenvio) — base do cooldown de 60s entre reenvios (G2).
  lastSentAt         DateTime
  /// Conta que emitiu (rastreabilidade/roster). Sem FK: `Account` é global e o vínculo é informativo.
  invitedByAccountId String         @db.Uuid
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Catálogo por Organização + estado (roster 8.7) e resolução de conflito por e-mail.
  @@index([orgId, state])
  @@index([orgId, normalizedEmail])
  @@map("Invite")
}

/// InviteRoute — resolvedor GLOBAL de tenant do aceite (Story 8.3), gêmeo funcional de `PublicFormRoute`.
///
/// O aceite chega SEM contexto de Organização (o convidado ainda não é membro) e `Invite` é RLS FORCE:
/// não dá para achar o Convite pelo hash do token sem antes saber o `orgId`. Esta tabela é **GLOBAL e
/// SEM RLS** (como `Account`/`PublicFormRoute`): mapeia `tokenHash` → `orgId` para a resolução
/// pré-contexto. Ela é só uma DICA — o serviço entra em `withTenantContext(orgId)` e **RELÊ o `Invite`
/// sob RLS**, que é a AUTORIDADE (uma rota apontando para a org errada não concede nada: o relê não acha
/// o Convite → 404). Como o `tokenHash` é irreversível e `orgId` não é segredo, expô-la é inócuo.
///
/// **Mantida por TRIGGER em `Invite`** (a 8.2 não é tocada): `AFTER INSERT` insere; `AFTER UPDATE OF
/// tokenHash` troca OLD→NEW (cobre a rotação de token no reenvio). A migration backfilla os PENDING
/// existentes. Runtime: GRANT SELECT (+ INSERT/DELETE para o trigger, que roda como invoker).
model InviteRoute {
  /// SHA-256 (hex) do token — a mesma chave do `Invite.tokenHash`. PK: lookup O(1) pré-contexto.
  tokenHash String @id
  orgId     String @db.Uuid

  @@map("InviteRoute")
}

/// Pipe — processo de trabalho da Organização (Story 2.1). Dado operacional org-owned (AD-10).
///
/// Isolamento pelo BANCO (RLS na migration `..._pipes`), como `Organization`/`Membership`: ENABLE
/// **e** FORCE ROW LEVEL SECURITY, policies por `orgId = current_org_id()`. O runtime recebe
/// SELECT/INSERT/UPDATE — **sem DELETE** (o épico proíbe exclusão definitiva; arquivar é `state`).
///
/// **Sem unicidade de `name`**: o identificador estável é o `id` (AD-11). Nome único org-scoped
/// colidiria no restaurar (arquiva "X", cria novo "X", restaura o antigo). RN-024 (catálogo
/// consistente) é sobre exibição por id, não unicidade de rótulo.
model Pipe {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @db.Uuid
  name       String
  state      PipeState @default(ACTIVE)
  /// Atributos de catálogo (Story 2.1): sem semântica de bloqueio inventada — só persistidos/alternáveis.
  locked     Boolean   @default(false)
  starred    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  /// Momento do arquivamento (null quando ativo). Arquivar preserva os dados; só muda estado.
  archivedAt DateTime?

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grants         PipeGrant[]
  phases         Phase[]
  forms          Form[]
  cards          Card[]
  movementEvents MovementEvent[]
  automations    Automation[]
  domainEvents   DomainEvent[]
  tasks          Task[]
  solicitacoes   Solicitacao[]

  /// Chave-alvo da FK COMPOSTA tenant-safe (Story 4.1, F-A1). Redundante como IDENTIDADE (`id` já é PK),
  /// mas necessária como DESTINO: é ela que permite a um dependente referenciar o PAR `(orgId, id)` e
  /// assim provar, NO BANCO, que ele e o Pipe pertencem à MESMA Organização — em vez de deixar isso por
  /// conta de uma releitura no serviço. Ver `Automation.pipe`.
  @@unique([orgId, id])
  // Todo acesso organizacional começa por `orgId`; o catálogo filtra por estado.
  @@index([orgId, state])
  @@map("Pipe")
}

/// Database — base de dados estruturada, org-owned (Story 3.1). Twin ESTRUTURAL de `Pipe`, entidade
/// DISTINTA (Database ≠ Pipe — RN-061): catálogo/subject/módulo próprios, nunca reusa os de `Pipe`.
///
/// Isolamento pelo BANCO (RLS na migration `..._databases`): ENABLE **e** FORCE ROW LEVEL SECURITY,
/// policies por `orgId = current_org_id()` com `WITH CHECK` no INSERT e no UPDATE. Runtime recebe
/// SELECT/INSERT/UPDATE — **sem DELETE**: arquivar é `state = ARCHIVED`, não exclusão.
///
/// **Sem unicidade de `name`**: o identificador estável é o `id` (AD-11); nome único org-scoped
/// colidiria no restaurar. **Sem `locked`/`starred`** (não estão na epics da 3.1 — não inventar).
/// Arquivar coloca em SOMENTE-LEITURA INTEGRAL: em `ARCHIVED` o único write-side é `restaurar`
/// (renomear → 409). As escritas sobre dados dependentes (Formulário/Registro/Campo/arquivo/vínculo)
/// são contrato futuro (3.3/3.4/3.7/3.8/3.9), enforçadas pelo owner checando `state === ACTIVE`.
model Database {
  id         String        @id @default(uuid()) @db.Uuid
  orgId      String        @db.Uuid
  name       String
  state      DatabaseState @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  /// Momento do arquivamento (null quando ativo). Arquivar preserva os dados; só muda estado.
  archivedAt DateTime?

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grants       DatabaseGrant[]
  forms        Form[]
  records      Record[]

  // Todo acesso organizacional começa por `orgId`; o catálogo filtra por estado.
  @@index([orgId, state])
  @@map("Database")
}

/// Phase — Fase do fluxo DENTRO de um Pipe (Story 2.3). Dado operacional org-owned (AD-10).
///
/// `Fase ≠ Status do Card` (invariante conceitual): a Fase é a etapa do processo; o Card é que se move
/// entre Fases (Cards = 2.7+). RN-030: cada Fase pertence a EXATAMENTE UM Pipe e NÃO migra — não há rota
/// que altere `pipeId`.
///
/// Isolamento pelo BANCO (RLS na migration `..._phases`): ENABLE **e** FORCE ROW LEVEL SECURITY, policies
/// por `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**: arquivar é
/// `state = ARCHIVED`, não exclusão.
///
/// **Ordenação intra-Pipe por chave fracionária** (`position`, `numeric`): mover uma Fase é UM único
/// UPDATE (novo `position` = ponto médio dos vizinhos), porque `withTenantContext` define o contexto por
/// operação e não suporta transação multi-statement — reescrever N posições em lote não seria atômico.
/// Ordem determinística por `ORDER BY position, id`. **Sem unicidade** de `position` (empate raro
/// desempatado pelo `id`; uma constraint única brigaria com operações concorrentes).
model Phase {
  id         String     @id @default(uuid()) @db.Uuid
  orgId      String     @db.Uuid
  pipeId     String     @db.Uuid
  name       String
  state      PhaseState @default(ACTIVE)
  /// Chave de ordenação fracionária (ver nota do model). `numeric` de alta escala.
  position   Decimal    @db.Decimal(38, 18)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  /// Momento do arquivamento (null quando ativa). Arquivar preserva os dados; só muda estado.
  archivedAt DateTime?

  // ── Config de marcos por Fase (Story 2.12) — durações RELATIVAS à entrada, em MINUTOS (decisão de Arquitetura:
  // Int, pois o Prisma 6.19.3 não tem `interval` nativo). Invariante `esperado ≤ vencimento ≤ expiração` validado
  // no núcleo puro E por CHECK na migration (defesa em profundidade, tolerante a NULL). Ausente = marco não configurado.
  /// Prazo esperado, em minutos após a entrada na Fase (null = não configurado).
  expectedDurationMin   Int?
  /// Vencimento, em minutos após a entrada (null = não configurado). `expectedDurationMin ≤ dueDurationMin`.
  dueDurationMin        Int?
  /// Expiração, em minutos após a entrada (null = não configurado). `dueDurationMin ≤ expirationDurationMin`.
  expirationDurationMin Int?
  // Override ABSOLUTO por Campo `DATE`/`DATETIME` do Card (Story 2.12, D-OA3): a config designa, por marco, um
  // `Field.id` do Formulário inicial do Pipe. Na avaliação (2.13), valor não-nulo do Card nesse Campo prevalece
  // sobre a duração. Não é FK (Fields nunca são deletados; validação de tipo/pertencimento vive no serviço).
  /// Campo de override do prazo esperado (null = sem override; usa a duração).
  expectedFieldId       String? @db.Uuid
  /// Campo de override do vencimento (null = sem override).
  dueFieldId            String? @db.Uuid
  /// Campo de override da expiração (null = sem override).
  expirationFieldId     String? @db.Uuid

  organization           Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe                   Pipe              @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  forms                  Form[]
  cards                  Card[]
  phaseEntries           CardPhaseEntry[]
  phaseValues            CardPhaseValues[]
  movementEventsAsSource MovementEvent[]   @relation("MovementEventSource")
  movementEventsAsTarget MovementEvent[]   @relation("MovementEventTarget")

  // Acesso começa por Org; a listagem por Pipe filtra estado e ordena por position.
  @@index([orgId, pipeId, state, position])
  @@map("Phase")
}

/// PipeGrant — concessão explícita de papel POR Pipe (Story 2.2, decisão D1.4). Dado operacional
/// org-owned (AD-10). É o que abre o acesso de MEMBER/GUEST a um Pipe: sem concessão ACTIVE, não há
/// acesso (deny-by-default). O Admin da Organização acessa todos os Pipes SEM concessão (Story 2.1).
///
/// Liga-se a `Membership` (não a `Account`): o papel por Pipe vive DENTRO de uma Organização, e a
/// Membership é o vínculo Account×Org que já carrega `orgId` e estado (AD-7). Ligar à Account global
/// reabriria a porta de uma concessão "sem Org".
///
/// Isolamento pelo BANCO (RLS na migration `..._pipe_grants`): ENABLE **e** FORCE ROW LEVEL SECURITY,
/// policies por `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**:
/// revogar é `state = REVOKED`, não exclusão (preserva a trilha).
///
/// **No máximo UM papel efetivo por Pipe por pessoa**: índice único PARCIAL `(pipeId, membershipId)
/// WHERE state = 'ACTIVE'`, criado por raw SQL na migration (o Prisma 6.19.3 não expressa índice
/// parcial no schema — é v7.4+). Uma concessão revogada não colide com uma re-concessão.
model PipeGrant {
  id                      String         @id @default(uuid()) @db.Uuid
  orgId                   String         @db.Uuid
  pipeId                  String         @db.Uuid
  membershipId            String         @db.Uuid
  role                    PipeRole
  state                   PipeGrantState @default(ACTIVE)
  /// Capacidade EXPLÍCITA "Revisar submissões públicas" (Story 2.8, PRD D3.3), negada por padrão. É uma
  /// CAPACIDADE, não um papel: o Admin da Org a possui implicitamente (sem concessão); um não-Admin só revisa
  /// com uma concessão ACTIVE que a tenha `true`. Não cria papel novo nem toca o CASL/guard (C3 congelado) — a
  /// guarda fina vive em `pipe-authz` (`exigirRevisarSubmissoesPublicas`).
  reviewPublicSubmissions Boolean        @default(false)
  /// Modificador "restrito ao próprio" do Membro do Pipe (Story 2.10, PRD D1.5), deny-by-default. NÃO é papel novo
  /// (análogo a `reviewPublicSubmissions`): quando `true`, o Membro só opera Cards onde é Responsável atual OU tem
  /// concessão direta ativa (`creator`/histórico anterior não concedem acesso). Guarda fina em `pipe-authz`.
  restritoAoProprio       Boolean        @default(false)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  /// Momento da revogação (null quando ativa). Revogar preserva a linha; só muda estado.
  revokedAt               DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe         Pipe         @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Acesso começa por Org; consultas por Pipe (quem acessa) e por pessoa (quais Pipes).
  @@index([orgId, pipeId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "um papel ativo por (pipe, pessoa)" é um índice PARCIAL, criado na migration
  // (WHERE state='ACTIVE') — não expressável aqui no Prisma 6.19.3.
  @@map("PipeGrant")
}

/// DatabaseGrant — concessão explícita de papel POR Database (Story 3.2, decisão D3.4). Dado operacional
/// org-owned (AD-10). É o que abre o acesso de MEMBER/GUEST a um Database: sem concessão ACTIVE, não há
/// acesso (deny-by-default). O Admin da Organização acessa todos os Databases SEM concessão (Story 3.1).
/// É o **twin estrutural de `PipeGrant`** (2.2), entidade **DISTINTA** (Database ≠ Pipe — RN-061): tabela,
/// enums e subject próprios; nunca reutilizar `PipeGrant`/`PipeRole`.
///
/// Liga-se a `Membership` (não a `Account`): o papel por Database vive DENTRO de uma Organização (AD-7).
///
/// **Autoridade hierárquica de concessão (ajuste 2, D3.4 §969/§1086 — resolvida no serviço, não no banco):**
/// Admin da Org concede/altera/revoga qualquer papel; Admin do Database (grant `role=ADMIN` ACTIVE) concede/
/// revoga SÓ `MEMBER`/`VIEWER`; **somente Admin da Org concede/remove `ADMIN` do Database**. Teto da Org
/// (AD-9): um Convidado (`Membership.role=GUEST`) só recebe `VIEWER`.
///
/// Isolamento pelo BANCO (RLS na migration `..._database_grants`): ENABLE **e** FORCE ROW LEVEL SECURITY,
/// policies por `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**: revogar é
/// `state = REVOKED`, não exclusão (preserva a trilha).
///
/// **No máximo UM papel efetivo por Database por pessoa**: índice único PARCIAL `(databaseId, membershipId)
/// WHERE state = 'ACTIVE'`, criado por raw SQL na migration (o Prisma 6.19.3 não expressa índice parcial).
model DatabaseGrant {
  id           String             @id @default(uuid()) @db.Uuid
  orgId        String             @db.Uuid
  databaseId   String             @db.Uuid
  membershipId String             @db.Uuid
  role         DatabaseRole
  state        DatabaseGrantState @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  /// Momento da revogação (null quando ativa). Revogar preserva a linha; só muda estado.
  revokedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  database     Database     @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Acesso começa por Org; consultas por Database (quem acessa) e por pessoa (quais Databases).
  @@index([orgId, databaseId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "um papel ativo por (database, pessoa)" é um índice PARCIAL, criado na migration
  // (WHERE state='ACTIVE') — não expressável aqui no Prisma 6.19.3.
  @@map("DatabaseGrant")
}

/// Vínculo Account × Organization (AD-7, Forma B). É a tabela organizacional
/// desta Story — e a fixture dos testes de isolamento.
model Membership {
  id        String          @id @default(uuid()) @db.Uuid
  accountId String          @db.Uuid
  orgId     String          @db.Uuid
  role      MembershipRole
  state     MembershipState @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  account          Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipeGrants       PipeGrant[]
  databaseGrants   DatabaseGrant[]
  cardGrants       CardGrant[]
  cardResponsaveis CardResponsavel[]
  events           MembershipEvent[]

  // Uma conta tem no máximo UM vínculo por Organização (papel único — AD-7).
  @@unique([accountId, orgId])
  // Todo acesso organizacional começa por `orgId` → primeira coluna do índice.
  @@index([orgId, state])
  // Descoberta das próprias Organizações no login (Story 1.4), antes de haver contexto.
  @@index([accountId])
  @@map("Membership")
}

/// Evento canônico do ciclo de Membership (Story 8.4, D-2/D-3) — twin estrutural de `MovementEvent`.
/// Tabela org-scoped APPEND-ONLY e IMUTÁVEL: RLS ENABLE+FORCE, policies por `orgId = current_org_id()`,
/// GRANT só SELECT+INSERT (sem UPDATE/DELETE — "não se altera/apaga o fato histórico" é do BANCO, não da
/// ausência de rota). Escrito na MESMA transação da alteração de papel (não há mudança sem seu evento).
///
/// `eventId` é DETERMINÍSTICO por operação (uuidv5(NS, orgId+membershipId+correlationId)) com
/// `@@unique([orgId, eventId])`: um reprocessamento reproduz o id e não duplica o evento lógico (outbox
/// idempotente). Minimização LGPD (D-4): só referências mínimas (membershipId, actorId) + papéis
/// (from/to) + metadados — NUNCA senha/token/sessão/e-mail/corpo HTTP.
model MembershipEvent {
  id            String              @id @default(uuid()) @db.Uuid
  orgId         String              @db.Uuid
  /// Identidade lógica estável do evento (determinística por operação). Única por Organização.
  eventId       String              @db.Uuid
  /// Recurso do evento: a Membership alterada (referência mínima, org-scoped).
  membershipId  String              @db.Uuid
  type          MembershipEventType
  /// Papel anterior e novo — o DADO central da alteração (não é PII).
  fromRole      MembershipRole
  toRole        MembershipRole
  /// Ator administrativo que executou a alteração (referência de auditoria). Nulo só por defesa.
  actorId       String?             @db.Uuid
  /// Momento efetivo da alteração (instante absoluto).
  occurredAt    DateTime            @default(now()) @db.Timestamptz(3)
  /// Chave de correlação da operação (linka evento ↔ UPDATE ↔ revogações da mesma alteração).
  correlationId String              @db.Uuid
  version       Int                 @default(1)
  /// Envelope mínimo versionado (ex.: concessões revogadas por incompatibilidade). Sem PII.
  payload       Json                @default("{}")
  createdAt     DateTime            @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Um reprocessamento não cria um 2º evento lógico.
  @@unique([orgId, eventId])
  // Leitura da trilha por Membership (cronológica) e correlação com a operação.
  @@index([orgId, membershipId, occurredAt])
  @@index([orgId, correlationId])
  @@map("MembershipEvent")
}

/// Form — Formulário de UM contexto (Story 2.4). Dado operacional org-owned (AD-10). Os três Formulários
/// (inicial do Pipe, de Fase, de Database) são INDEPENDENTES (INV-FORM-01): cada contexto é uma LINHA
/// distinta, e a não-contaminação entre eles cai como consequência de linhas separadas + RLS.
///
/// **Tabela única com owner por contexto** (FKs nuláveis): `pipeId` para `PIPE_INITIAL`, `phaseId` para
/// `PHASE`. O contexto `DATABASE` existe no enum como CONTRATO do E3, mas SEM coluna de owner e SEM rota
/// nesta Story (AD-11). A coerência contexto↔owner e a unicidade "um Form por owner+contexto" são impostas
/// pelo BANCO (CHECK + índices únicos PARCIAIS na migration `..._forms` — não expressáveis no Prisma 6.19.3).
///
/// Isolamento pelo banco (RLS na migration): ENABLE **e** FORCE ROW LEVEL SECURITY, policies por
/// `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**.
model Form {
  id               String         @id @default(uuid()) @db.Uuid
  orgId            String         @db.Uuid
  context          FormContext
  /// Owner do contexto `PIPE_INITIAL` (null nos demais). CHECK na migration garante a coerência.
  pipeId           String?        @db.Uuid
  /// Owner do contexto `PHASE` (null nos demais).
  phaseId          String?        @db.Uuid
  /// Owner do contexto `DATABASE` (null nos demais). Story 3.3. CHECK na migration garante a coerência.
  databaseId       String?        @db.Uuid
  /// Número da `FormVersion` publicada corrente (null = rascunho/despublicado). Story 2.6. É NÚMERO, não FK,
  /// de propósito: evita o ciclo de FK Form↔FormVersion e não há risco de ponteiro pendente (versões nunca
  /// são deletadas e o ponteiro só é gravado para uma versão recém-criada na MESMA transação de publicação).
  publishedVersion Int?
  /// Opt-in de acesso PÚBLICO (Story 2.8, PRD D3.2). Só faz sentido em `PIPE_INITIAL` — CHECK na migration impõe
  /// (Fase/Database nunca são públicos). Habilitar cria também uma `PublicFormRoute` (URL opaca); revogar/
  /// despublicar bloqueia novas submissões.
  publicEnabled    Boolean        @default(false)
  /// Modo da submissão pública (triagem padrão ou criação direta). Só relevante com `publicEnabled`.
  publicMode       PublicFormMode @default(TRIAGE)
  /// MODO do Formulário de Fase (Story 2.15, D1) — dois booleanos INDEPENDENTES: um Formulário de Fase pode ser
  /// requisito de ENTRADA (valores exigidos antes de mover para a Fase) E/OU de SAÍDA (validados antes de sair).
  /// Ambos false = informativo/opcional. Só fazem sentido em `context='PHASE'` (config é "config do Pipe").
  requisitoEntrada Boolean        @default(false)
  requisitoSaida   Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe              Pipe?              @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  phase             Phase?             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  database          Database?          @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  fields            Field[]
  versions          FormVersion[]
  cards             Card[]
  publicSubmissions SubmissaoPublica[]
  publicRoutes      PublicFormRoute[]
  records           Record[]

  // Acesso começa por Org; a resolução por owner busca por (orgId, pipeId|phaseId|databaseId, context).
  @@index([orgId, pipeId])
  @@index([orgId, phaseId])
  @@index([orgId, databaseId])
  @@map("Form")
}

/// FormVersion — SNAPSHOT IMUTÁVEL da definição publicada de um Formulário (Story 2.6, AD-12/PRD D3.2).
///
/// Publicar congela o rascunho VALIDADO num `snapshot` JSON integral (Campos ATIVOS com id estável, tipo, label,
/// ajuda e `typeConfig`), na ordem do array — numerado monotonicamente por Formulário
/// (`@@unique([orgId, formId, version])`). O snapshot captura o que a definição realmente tem: NÃO há atributo
/// de obrigatoriedade em `Field` na 2.4/2.5 e o snapshot não o inventa (Constitution II). Submissões futuras
/// (2.7+) referenciarão `formVersionId`. Editar o rascunho depois NÃO altera versões já publicadas — imutáveis.
///
/// **Imutabilidade é do BANCO, não do código:** o runtime (`giraffe_app`) recebe **só SELECT+INSERT** em
/// `FormVersion` — sem UPDATE, sem DELETE (ver GRANT na migration). Uma rota que tentasse alterar uma versão
/// bateria em `permission denied`. Isolamento por RLS ENABLE+FORCE, policies por `current_org_id()`.
model FormVersion {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @db.Uuid
  formId      String   @db.Uuid
  /// Número monotônico por Formulário (1, 2, 3...). Unicidade imposta pelo banco.
  version     Int
  /// Snapshot integral e ordenado da definição publicada. Schema/limite/allowlist validados no serviço.
  snapshot    Json
  /// Hash determinístico do snapshot (revisão) — detecta divergência e identifica a versão.
  revision    String
  publishedAt DateTime @default(now())
  /// Conta que publicou (quando disponível). Não é PII sensível: é referência de ator para auditoria.
  actorId     String?  @db.Uuid
  createdAt   DateTime @default(now())

  organization      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form              Form               @relation(fields: [formId], references: [id], onDelete: Cascade)
  cards             Card[]
  publicSubmissions SubmissaoPublica[]
  phaseValues       CardPhaseValues[]
  records           Record[]

  @@unique([orgId, formId, version])
  @@index([orgId, formId])
  @@map("FormVersion")
}

/// Card — instância de trabalho criada por uma submissão do Formulário inicial (Story 2.7). Dado operacional
/// org-owned (AD-10). **Card ≠ Registro** (invariante conceitual): o Card é a unidade que percorre o Pipe; o
/// Registro (dado de Database) é do E3. **Fase ≠ Status do Card**: o Card nasce numa Fase e se move entre
/// Fases; o ciclo de vida/estado do Card (ativo/finalizado/arquivado) é da 2.11 — **não materializado aqui**.
///
/// A submissão interna **cria** um Card (nunca preenche um existente — D3.3). O Card nasce na **1ª Fase ativa**
/// do Pipe e referencia a **`FormVersion` publicada** no ato (`formVersionId`, imutável — AD-12): a definição
/// usada fica congelada, independentemente de edições futuras do rascunho. Os `valores` submetidos vivem em
/// JSONB **chaveado por `Field.id`** (e opção por `id`, nunca rótulo — AD-11/AD-12), não em tabela de valores
/// por Campo (normalização especulativa proibida por AD-11) — coerente com o snapshot JSON da 2.6.
///
/// **Idempotência**: `idempotencyKey` do cliente + `@@unique([orgId, formId, idempotencyKey])` — um retry da
/// MESMA submissão lógica colide e devolve o Card existente (nunca duplica). Isolamento pelo banco (RLS
/// ENABLE+FORCE); na 2.7 o runtime tem **só SELECT/INSERT** — sem UPDATE (nenhum consumidor de UPDATE ainda; a
/// 2.9/2.11 concede junto do consumidor e do teste) e **sem DELETE** (arquivar será `state` na 2.11).
model Card {
  id                     String              @id @default(uuid()) @db.Uuid
  orgId                  String              @db.Uuid
  pipeId                 String              @db.Uuid
  phaseId                String              @db.Uuid
  formId                 String              @db.Uuid
  formVersionId          String              @db.Uuid
  /// Chave lógica da submissão (cliente). Garante idempotência via índice único org+form.
  idempotencyKey         String
  /// Valores submetidos, chaveados por `Field.id` do snapshot (opção por `id`). Validados contra a versão.
  valores                Json                @default("{}")
  /// Origem do Card (Story 2.8): submissão interna (`INTERNAL`, 2.7) ou pública (`PUBLIC`, aprovada/direta).
  origin                 CardOrigin          @default(INTERNAL)
  /// Estado de CICLO DE VIDA (Story 2.11), eixo INDEPENDENTE da Fase (`Fase ≠ Status do Card`) e da saúde temporal
  /// (2.13). Três estados canônicos; `reaberto`/`restaurado` são TRANSIÇÕES, não estados. É a ÚNICA coluna de `Card`
  /// que o runtime pode UPDATE (GRANT column-scoped na migration da 2.11) — junto de `previousLifecycleState` e
  /// `updatedAt`; `phaseId` (movimentação, 2.14) segue **sem** GRANT de UPDATE.
  lifecycleState         CardLifecycleState  @default(ATIVO)
  /// Estado ANTERIOR ao arquivamento (ATIVO ou FINALIZADO), para restaurar de forma confiável (AC 2.11). Nulo fora
  /// de ARQUIVADO. Preenchido ao arquivar, limpo ao restaurar.
  previousLifecycleState CardLifecycleState?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe             Pipe              @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  phase            Phase             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  form             Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion      FormVersion       @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  history          CardHistory[]
  publicSubmission SubmissaoPublica?
  grants           CardGrant[]
  responsaveis     CardResponsavel[]
  phaseEntries     CardPhaseEntry[]
  phaseValues      CardPhaseValues[]
  movementEvents   MovementEvent[]
  recordLinks      CardRecordLink[]
  tasks            Task[]
  solicitacoes     Solicitacao[]

  // Um retry da mesma submissão lógica não cria um 2º Card.
  @@unique([orgId, formId, idempotencyKey])
  /// Chave-alvo da FK COMPOSTA tenant-safe (Story 5.1): permite a `Task` referenciar o PAR `(orgId, id)`
  /// e provar NO BANCO que Tarefa e Card pertencem à MESMA Organização (evita `cardId` alheio — a checagem
  /// de FK roda com BYPASS de row security). Redundante como identidade (`id` já é PK), necessária como
  /// destino. Aplica parcialmente o `DEB-TENANT-COMPOSITE-FK-RETROFIT` a `Card`.
  @@unique([orgId, id])
  // Superfície do Kanban (2.9): Cards de um Pipe, por Fase.
  @@index([orgId, pipeId, phaseId])
  @@map("Card")
}

/// CardHistory — trilha de eventos do Card (Story 2.7 estabelece o contrato write-side, reusado por 2.10-2.16).
/// Dado operacional org-owned (AD-10). É **append-only e IMUTÁVEL**: o runtime recebe **só SELECT+INSERT**
/// (sem UPDATE/DELETE — ver GRANT na migration), como `FormVersion`. Distinta da Auditoria/Log técnico (AD-15):
/// é histórico de negócio, legível pelo usuário.
///
/// Na 2.7 há um único tipo de evento: `CREATED` (criação do Card pela submissão). O evento é escrito na MESMA
/// transação atômica do INSERT do Card (AD-13): não há Card sem evento nem evento sem Card.
model CardHistory {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  cardId        String   @db.Uuid
  /// Vocabulário do evento (2.7: apenas `CREATED`). String — a taxonomia completa é das Stories 2.10+.
  type          String
  /// Resumo legível do evento (sem PII desnecessária).
  summary       String
  /// Ator que originou o evento (quando disponível).
  actorId       String?  @db.Uuid
  /// Correlaciona eventos de uma MESMA operação entre trilhas (Story 3.9): `LINKED`/`UNLINKED` do Card e do
  /// Registro compartilham este valor. Nullable (eventos anteriores não têm). Não projetado pela leitura (2.17).
  correlationId String?  @db.Uuid
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([orgId, cardId, createdAt])
  @@index([orgId, correlationId])
  @@map("CardHistory")
}

/// Estado de CICLO DE VIDA do Card (Story 2.11). Três estados canônicos e persistentes; `reaberto`/`restaurado`
/// NÃO são estados — são transições que devolvem o Card a ATIVO/estado-anterior. Eixo independente da Fase e da
/// saúde temporal (2.13).
enum CardLifecycleState {
  ATIVO
  FINALIZADO
  ARQUIVADO
}

/// Estado de uma concessão direta de acesso a um Card (Story 2.10). Revogar preserva a linha (sem DELETE).
enum CardGrantState {
  ACTIVE
  REVOKED
}

/// Estado da atribuição de Responsável de um Card (Story 2.10). Remover preserva a linha (sem DELETE).
enum CardResponsavelState {
  ACTIVE
  REMOVED
}

/// CardGrant — concessão DIRETA de acesso a UM Card específico (Story 2.10, PRD D1.5). Dado operacional org-owned.
/// Não é papel: dá acesso SÓ àquele Card, nunca lista/config/métricas do Pipe nem outros Cards. Observador = só
/// `podeLer`; concessão operacional direta = `podeOperar` (+ `podeMover` opt-in — a OPERAÇÃO de mover é a 2.14;
/// aqui só o DADO da capacidade). Deny-by-default (capacidades default falsas, exceto leitura). Isolamento pelo
/// banco (RLS ENABLE+FORCE); runtime SELECT/INSERT/UPDATE — **sem DELETE** (revogar é `state = REVOKED`).
model CardGrant {
  id           String         @id @default(uuid()) @db.Uuid
  orgId        String         @db.Uuid
  cardId       String         @db.Uuid
  membershipId String         @db.Uuid
  /// Observador (leitura). Default true — uma concessão sempre concede ao menos ler o Card.
  podeLer      Boolean        @default(true)
  /// Concessão operacional direta (agir no Card). Deny-by-default.
  podeOperar   Boolean        @default(false)
  /// Capacidade "Mover Card" (dado de autorização; a operação é 2.14). Deny-by-default; só se concedida.
  podeMover    Boolean        @default(false)
  state        CardGrantState @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  revokedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Consultas por Card (quem acessa) e por pessoa (quais Cards).
  @@index([orgId, cardId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "uma concessão ativa por (card, pessoa)" é índice PARCIAL na migration (WHERE state='ACTIVE').
  @@map("CardGrant")
}

/// CardResponsavel — atribuição de RESPONSÁVEL de um Card (Story 2.10, PRD D5.1). Dado operacional org-owned. É
/// ATRIBUIÇÃO operacional, **não papel**: não amplia acesso (o alvo já precisa de acesso operacional). A chave é
/// `membershipId` (elegibilidade é por Membership — PRD §1065), não accountId. Mantém `Card` **append-only** (a
/// 2.10 NÃO abre GRANT de UPDATE em `Card`; o 1º UPDATE de Card segue reservado à movimentação — 2.14). No máximo
/// UMA atribuição ACTIVE por Card (índice parcial na migration). `creator` NÃO vive aqui — é o `actorId` do evento
/// `CREATED` (2.7). Isolamento pelo banco (RLS); runtime SELECT/INSERT/UPDATE — **sem DELETE** (remover é `state`).
model CardResponsavel {
  id           String               @id @default(uuid()) @db.Uuid
  orgId        String               @db.Uuid
  cardId       String               @db.Uuid
  membershipId String               @db.Uuid
  state        CardResponsavelState @default(ACTIVE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  removedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([orgId, cardId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "um Responsável ativo por Card" é índice PARCIAL na migration (WHERE state='ACTIVE').
  @@map("CardResponsavel")
}

/// Origem de uma entrada efetiva do Card numa Fase (Story 2.12). `SUBMISSION` = criação do Card (2.7 interna / 2.8
/// pública); `MOVE` = movimentação entre Fases (2.14, futura — o helper de entrada já aceita a origem, sem chamador
/// de movimentação nesta Story).
enum CardPhaseEntryOrigin {
  SUBMISSION
  MOVE
}

/// CardPhaseEntry — referência temporal de uma ENTRADA efetiva do Card numa Fase (Story 2.12, FR-10; D2.7). Dado
/// operacional org-owned (AD-10). É a **base absoluta** dos marcos: cada entrada preserva o **instante** e a
/// **origem**; cada reentrada (2.14) cria uma NOVA linha, preservando o histórico. "Entrada atual" = a linha mais
/// recente por `(cardId, enteredAt desc)` — sem "linha ativa" única, logo sem índice parcial de unicidade.
///
/// **Append-only e IMUTÁVEL** (como `CardHistory`/`FormVersion`): o runtime recebe **só SELECT + INSERT** (sem
/// UPDATE, sem DELETE — ver GRANT na migration). Não toca `Card` (a 2.12 não abre GRANT de UPDATE em `Card`;
/// `phaseId`/movimentação seguem sem UPDATE até 2.14).
///
/// **`configSnapshot`** congela as durações/override vigentes da Fase no instante da entrada (decisão D-OA1=A:
/// mudar a config afeta só entradas FUTURAS; "sem recálculo retroativo silencioso" cai por construção — padrão da
/// `FormVersion` da 2.6). JSON: `{ expectedDurationMin, dueDurationMin, expirationDurationMin, expectedFieldId,
/// dueFieldId, expirationFieldId }` (todos nuláveis). A **derivação** dos marcos a partir da base é 2.13.
///
/// **`enteredAt` é `@db.Timestamptz`** (instante absoluto — decisão de Arquitetura; diverge do `TIMESTAMP(3)` do
/// restante do schema por escolha explícita, DIV-1). Isolamento pelo banco (RLS ENABLE+FORCE, WITH CHECK).
model CardPhaseEntry {
  id             String               @id @default(uuid()) @db.Uuid
  orgId          String               @db.Uuid
  cardId         String               @db.Uuid
  phaseId        String               @db.Uuid
  /// Instante ABSOLUTO da entrada (base dos marcos). Timestamptz — instante, não data local.
  enteredAt      DateTime             @default(now()) @db.Timestamptz(3)
  origin         CardPhaseEntryOrigin
  /// Snapshot congelado da config de marcos da Fase no instante da entrada (D-OA1=A). Ver nota do model.
  configSnapshot Json
  createdAt      DateTime             @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  phase        Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  // "Entrada atual" e histórico: consulta por Card ordenada por instante de entrada.
  @@index([orgId, cardId, enteredAt])
  @@map("CardPhaseEntry")
}

/// CardPhaseValues — valores do Formulário de Fase por (Card, Fase) (Story 2.15). Dado operacional org-owned
/// (AD-10). É **append-only e IMUTÁVEL** (runtime só SELECT+INSERT — ver GRANT): registrar/corrigir valores é
/// INSERT (nova linha), NUNCA UPDATE/DELETE. O conjunto CORRENTE por (Card, Fase) é o mais recente por `createdAt`;
/// a correção posterior é uma nova linha + evento `PHASE_VALUES_CORRECTED` antes/depois no `CardHistory`.
///
/// **INV-FORM-01**: é DISTINTO de `Card.valores` (Formulário inicial, 2.7) — os três Formulários são independentes.
/// `valores` em JSONB por `Field.id` (opção por `id` — AD-11/AD-12), validado contra o snapshot da `FormVersion`
/// **publicada** (`formVersionId`, congelada — AD-12). Preenchido no requisito de ENTRADA na MESMA transação da
/// movimentação (2.14); no requisito de SAÍDA e na correção, validado/gravado no seu próprio fluxo.
model CardPhaseValues {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  cardId        String   @db.Uuid
  phaseId       String   @db.Uuid
  /// Versão publicada do Formulário de Fase contra a qual os valores foram validados (congelada — AD-12).
  formVersionId String   @db.Uuid
  /// Valores submetidos, chaveados por `Field.id` do snapshot (opção por `id`). Validados contra a versão.
  valores       Json     @default("{}")
  /// Ator que registrou/corrigiu (quando disponível). Referência de auditoria, não PII sensível.
  actorId       String?  @db.Uuid
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  phase        Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  formVersion  FormVersion  @relation(fields: [formVersionId], references: [id], onDelete: Cascade)

  // "Conjunto corrente" (mais recente por Card+Fase) e histórico das correções.
  @@index([orgId, cardId, phaseId, createdAt])
  @@map("CardPhaseValues")
}

/// MovementEvent — EVENTO CANÔNICO de movimentação de Card (Story 2.16). É a persistência confiável do tipo
/// **Outbox** (AD-13: registro do evento de integração confirmado ATOMICAMENTE com a movimentação; o processamento
/// assíncrono, se houver, vem depois). Trilha de INTEGRAÇÃO — DISTINTA do Histórico do Card (`CardHistory`) e das
/// demais trilhas (AD-15): o consumo é de E4 (Automação) e E5 (Notificação), **não** implementados aqui.
///
/// **Append-only e IMUTÁVEL**: o runtime recebe **só SELECT+INSERT** (sem UPDATE/DELETE — ver GRANT), como
/// `CardHistory`/`FormVersion`/`CardPhaseEntry`. Emitido SOMENTE quando a movimentação persiste, na MESMA transação
/// do UPDATE `phaseId` + `CardPhaseEntry`(MOVE) + `CardHistory`(MOVED) [+ `CardPhaseValues` da 2.15]; bloqueio,
/// no-op idempotente ou "aguardando confirmação" NÃO emitem (CA2). Rollback integral se qualquer gravação falhar.
///
/// **Idempotência (CA3):** `eventId` DETERMINÍSTICO — `uuidv5(orgId + cardId + correlationId)` — com
/// `@@unique([orgId, eventId])`: um reprocessamento técnico reproduz o MESMO `eventId`; o índice único impede
/// duplicata lógica. `correlationId` é gerado server-side por operação (linka o evento ao `MOVED`/`CardPhaseEntry`
/// da mesma movimentação). `type`+`version` versionam o envelope (AD-13). `payload` é o envelope mínimo, sem PII
/// desnecessária. **Este E2 NÃO controla idempotência de Automação/Notificação** — E4/E5 o fazem a partir do `eventId`.
model MovementEvent {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  /// Identidade lógica estável do evento (determinística por operação). Único por Organização.
  eventId       String   @db.Uuid
  pipeId        String   @db.Uuid
  cardId        String   @db.Uuid
  sourcePhaseId String   @db.Uuid
  targetPhaseId String   @db.Uuid
  /// Ator que originou a movimentação (quando disponível). Referência de auditoria.
  actorId       String?  @db.Uuid
  /// Origem da movimentação (espelha `CardPhaseEntryOrigin`; hoje `MOVE`). String — vocabulário estável.
  origin        String
  /// Momento efetivo da movimentação (instante absoluto).
  occurredAt    DateTime @default(now()) @db.Timestamptz(3)
  /// Chave de correlação da operação (linka evento ↔ MOVED ↔ CardPhaseEntry da mesma movimentação).
  correlationId String   @db.Uuid
  /// Tipo do envelope canônico (ex.: `CARD_MOVED`). Versão do contrato do envelope.
  type          String
  version       Int      @default(1)
  /// Envelope mínimo versionado (sem PII desnecessária), chaveado pelo contrato canônico.
  payload       Json     @default("{}")
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe         Pipe         @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  sourcePhase  Phase        @relation("MovementEventSource", fields: [sourcePhaseId], references: [id], onDelete: Cascade)
  targetPhase  Phase        @relation("MovementEventTarget", fields: [targetPhaseId], references: [id], onDelete: Cascade)

  // Um reprocessamento não cria um 2º evento lógico.
  @@unique([orgId, eventId])
  // Leitura da trilha por Card (cronológica) e correlação com a operação.
  @@index([orgId, cardId, occurredAt])
  @@index([orgId, correlationId])
  @@map("MovementEvent")
}

/// SubmissaoPublica — submissão de um Formulário inicial PÚBLICO por ator externo (Story 2.8). Dado operacional
/// org-owned (AD-10). É entidade DISTINTA do Card, com ciclo PRÓPRIO (`SubmissaoPublicaState`): triagem NÃO é
/// estado do Card (`Fase ≠ Status do Card`). Referencia o `Form` inicial e a `FormVersion` publicada no ato;
/// `valores` em JSONB por `Field.id`, validados contra o snapshot (reusa `submission.ts` da 2.7). Em modo
/// `TRIAGE` nasce `PENDING`; aprovar cria 1 Card (origem `PUBLIC`) e marca `CONVERTED` com `cardId` na MESMA
/// transação (AD-13); rejeitar marca `REJECTED` (sem Card). Em modo `DIRECT` a submissão pública cria o Card
/// direto e nasce `CONVERTED`.
///
/// **Sem exclusão** (preserva por Governança/LGPD — NFR-8): o runtime tem `SELECT/INSERT/UPDATE`, **sem DELETE**.
/// Isolamento pelo banco (RLS ENABLE+FORCE, policies por `current_org_id()`, WITH CHECK). **Idempotência** da
/// conversão: `cardId` é único (`@@unique`) e o estado terminal `CONVERTED` guarda contra reconversão — nunca 2
/// Cards. `valores` são PII de titular externo: NUNCA em log.
model SubmissaoPublica {
  id             String                @id @default(uuid()) @db.Uuid
  orgId          String                @db.Uuid
  formId         String                @db.Uuid
  formVersionId  String                @db.Uuid
  state          SubmissaoPublicaState @default(PENDING)
  valores        Json                  @default("{}")
  /// Ponteiro do Card criado na conversão (null enquanto PENDING/REJECTED). Único: uma submissão ⇒ ≤1 Card.
  cardId         String?               @db.Uuid
  /// Chave de idempotência do cliente público (dedup de reenvio da mesma submissão lógica).
  idempotencyKey String?
  /// Ator que decidiu a triagem (aprovou/rejeitou), quando aplicável.
  decidedBy      String?               @db.Uuid
  decidedAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion  FormVersion  @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  card         Card?        @relation(fields: [cardId], references: [id], onDelete: SetNull)

  // Uma submissão convertida aponta no máximo um Card (idempotência da conversão).
  @@unique([cardId])
  // Dedup de reenvio público por Formulário.
  @@unique([orgId, formId, idempotencyKey])
  // Fila de triagem por Formulário e estado.
  @@index([orgId, formId, state])
  @@map("SubmissaoPublica")
}

/// PublicFormRoute — mapa GLOBAL e opaco de `publicId` → (`orgId`, `formId`) para resolver o tenant de uma
/// submissão pública ANTES de haver contexto (Story 2.8). GLOBAL e **SEM RLS por definição** (como `Account`,
/// AD-10): resolver o tenant não pode depender do contexto que ainda não existe. Guarda o MÍNIMO e **nenhuma
/// PII**: só o `publicId` aleatório/opaco (a URL pública), o `orgId` e o `formId` de destino.
///
/// O cliente público apresenta APENAS o `publicId`; o servidor resolve `(orgId, formId)`, entra em
/// `withTenantContext(orgId)` e RELÊ o `Form` sob RLS para validar (publicado, opt-in, versão, contexto) antes
/// de qualquer escrita — **nunca** aceita `orgId`/`formId` do cliente. `active=false` revoga (rotação = novo
/// `publicId`); link inválido/revogado/cross-tenant → 404 uniforme. Runtime: `SELECT` (resolver) + `INSERT`/
/// `UPDATE` (criar/revogar pela config autenticada), **sem DELETE** (revogar é estado, preserva a trilha).
model PublicFormRoute {
  id        String    @id @default(uuid()) @db.Uuid
  /// Identificador público OPACO e aleatório (a URL). Único global. Não deriva de orgId/formId.
  publicId  String    @unique
  orgId     String    @db.Uuid
  formId    String    @db.Uuid
  /// Revogação (link deixa de resolver). Rotação = revogar o antigo + criar um `publicId` novo.
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("PublicFormRoute")
}

/// Field — Campo de um Formulário (Story 2.4). Dado operacional org-owned (AD-10). O `id` é a IDENTIDADE
/// ESTÁVEL do Campo (AD-12): não depende do rótulo — renomear (na 2.5) não desloca valores.
///
/// `typeConfig` carrega o que VARIA por tipo (ex.: `options` de Seleção, cada uma com UUID estável; formato
/// de Número). Opções de Seleção vivem AQUI, em JSON com id estável — não em tabela própria (DBT-2.4-OPCOES-
/// JSON): assim criar um Campo de Seleção com suas opções é UM único `create` atômico, coerente com a recusa
/// de `$transaction` do `withTenantContext`. A validação do `typeConfig` por tipo vive no serviço.
///
/// `state` é ATRIBUTO desde a 2.4; arquivar/restaurar COM TRAVAS é da 2.5. Ordenação intra-Formulário por
/// chave fracionária (`position`), como `Phase`: mover = 1 UPDATE (ponto médio dos vizinhos). Isolamento pelo
/// banco (RLS); runtime SELECT/INSERT/UPDATE — **sem DELETE**.
model Field {
  id           String     @id @default(uuid()) @db.Uuid
  orgId        String     @db.Uuid
  formId       String     @db.Uuid
  label        String
  type         FieldType
  help         String?
  /// Config específica do tipo (ex.: `{ "options": [{ "id": uuid, "label": ..., "position": n }] }`).
  typeConfig   Json       @default("{}")
  /// Valor padrão do Campo (SQL NULL via `Prisma.DbNull` quando ausente).
  defaultValue Json?
  /// Chave de ordenação fracionária (ver nota do model). `numeric` de alta escala.
  position     Decimal    @db.Decimal(38, 18)
  /// Obrigatoriedade do Campo (Story 2.15). A Fase 1 não tinha obrigatoriedade (2.4-2.7); a 2.15 a introduz e o
  /// snapshot da publicação (2.6) a captura. É GATED ao Formulário de Fase (`context='PHASE'`) no serviço — o
  /// Formulário inicial (2.7) ignora obrigatoriedade. Default false: nada muda para Campos/Formulários existentes.
  required     Boolean    @default(false)
  state        FieldState @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  /// Momento do arquivamento (null quando ativo). Usado a partir da 2.5.
  archivedAt   DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)

  // Acesso começa por Org; a listagem por Formulário filtra estado e ordena por position.
  @@index([orgId, formId, state, position])
  @@map("Field")
}

/// Record — Registro: instância de DADO DO TITULAR de um Database (Story 3.4). Dado operacional org-owned
/// (AD-10). **Card ≠ Registro** (invariante conceitual): o Registro é o dado do Database; o Card é a unidade
/// que percorre o Pipe. O Registro pertence a EXATAMENTE UM Database (RN-063) e **não é transferível** — não há
/// rota nem GRANT que altere `databaseId`.
///
/// Criado por uma submissão do **Formulário de Database publicado** (3.3), reusando a maquinaria da submissão de
/// Card (2.7): referencia a `FormVersion` publicada no ato (`formVersionId`, imutável — AD-12) e guarda os
/// `valores` validados contra o snapshot em JSONB **chaveado por `Field.id`** (opção por `id`, nunca rótulo —
/// AD-11), não em tabela de valores por Campo. **Idempotência**: `idempotencyKey` + `@@unique([orgId,
/// databaseId, idempotencyKey])` — um retry da MESMA operação lógica devolve o Registro existente (nunca
/// duplica); P2002/P2028 → idempotente/409, nunca 500.
///
/// Ciclo de vida de **2 estados** (`ATIVO`/`ARQUIVADO` — sem `FINALIZADO`, que é do Card): arquivar é reversível
/// e não bloqueado por vínculos; restaurar volta a ATIVO (sem `previousLifecycleState`). Isolamento pelo banco
/// (RLS ENABLE+FORCE); GRANT column-scoped: o runtime pode UPDATE **só** `lifecycleState`/`valores`/`updatedAt`
/// (ciclo de vida 2.11 + edição de valores) e **sem DELETE** — arquivar é `state`, sem exclusão física (LGPD).
model Record {
  id             String               @id @default(uuid()) @db.Uuid
  orgId          String               @db.Uuid
  databaseId     String               @db.Uuid
  formId         String               @db.Uuid
  formVersionId  String               @db.Uuid
  /// Chave lógica da operação de criação (cliente). Garante idempotência via índice único org+database.
  idempotencyKey String
  /// Valores submetidos/editados, chaveados por `Field.id` do snapshot (opção por `id`). Validados contra a versão.
  valores        Json                 @default("{}")
  /// Origem do Registro. Story 3.4 materializa só `NOVO_REGISTRO` (criação interna); Automação (E4) e público
  /// entram com seus consumidores (AD-11).
  origin         RecordOrigin         @default(NOVO_REGISTRO)
  /// Estado de CICLO DE VIDA (Story 3.4), eixo próprio. Dois estados canônicos; `restaurado`/`arquivado` são
  /// TRANSIÇÕES. Coluna que o runtime pode UPDATE (GRANT column-scoped), junto de `valores`/`updatedAt`.
  lifecycleState RecordLifecycleState @default(ATIVO)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  database     Database         @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  form         Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion  FormVersion      @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  history      RecordHistory[]
  cardLinks    CardRecordLink[]

  // Um retry da mesma operação lógica não cria um 2º Registro no mesmo Database.
  @@unique([orgId, databaseId, idempotencyKey])
  // Consulta por Database (a visualização 3.5 consumirá).
  @@index([orgId, databaseId])
  @@map("Record")
}

/// RecordHistory — trilha própria do Registro (write-side, Story 3.4). Dado operacional org-owned (AD-10). É
/// **append-only e IMUTÁVEL**: o runtime recebe **só SELECT+INSERT** (sem UPDATE/DELETE — ver GRANT), como
/// `CardHistory`/`FormVersion`. Distinta da Auditoria/Log técnico (AD-15): é histórico de negócio, legível.
///
/// Vocabulário inicial: `CREATED`/`VALUES_UPDATED`/`ARCHIVED`/`RESTORED`. Eventos de arquivo (3.8) e de vínculo
/// (3.9, com `correlationId`) entram com suas Stories. O evento é escrito na MESMA transação da mutação (AD-13):
/// não há Registro/mutação sem evento. Correção = NOVO evento (não altera o original — imutabilidade do banco).
/// A CONSULTA da timeline (projeção/autorização por acesso atual/mascaramento) é a 3.6 (read-side).
model RecordHistory {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  recordId      String   @db.Uuid
  /// Vocabulário do evento (3.4: CREATED/VALUES_UPDATED/ARCHIVED/RESTORED). String — a taxonomia cresce em 3.8/3.9.
  type          String
  /// Resumo legível do evento (sem PII desnecessária).
  summary       String
  /// Ator/iniciador que originou o evento (quando disponível).
  actorId       String?  @db.Uuid
  /// Correlaciona eventos de uma MESMA operação entre trilhas (Story 3.9): `LINKED`/`UNLINKED` do Registro e do
  /// Card compartilham este valor. Nullable (eventos anteriores não têm). Não projetado pela leitura (3.6).
  correlationId String?  @db.Uuid
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  record       Record       @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([orgId, recordId, createdAt])
  @@index([orgId, correlationId])
  @@map("RecordHistory")
}

/// Estado de CICLO DE VIDA do Registro (Story 3.4). Dois estados canônicos e persistentes; `restaurado`/
/// `arquivado` NÃO são estados — são transições. Sem `FINALIZADO` (é do Card): restaurar volta sempre a ATIVO.
enum RecordLifecycleState {
  ATIVO
  ARQUIVADO
}

/// Origem do Registro (Story 3.4). Só `NOVO_REGISTRO` tem consumidor agora (criação interna autenticada);
/// `AUTOMACAO` (E4) e público entram com suas Stories (AD-11 — sem antecipar valores sem consumidor).
enum RecordOrigin {
  NOVO_REGISTRO
}

/// FileObject — ciclo de vida do arquivo (Story 3.7, capacidade compartilhada; ADR-001). Dado org-owned (AD-10),
/// **desacoplado** de Card/Registro: o recurso dono é referenciado de forma genérica (`resourceType`/`resourceId`),
/// e a autorização vem do recurso via a porta `FileAuthzContract` — a 3.7 NÃO conhece Card/Registro (3.8/3.10 ligam).
///
/// Entidade MUTÁVEL só nas colunas de ciclo de vida. Máquina de estados fail-closed (AD-28):
/// `QUARENTENA → DISPONIVEL → REMOVIDO_LOGICO → EXPURGADO` (+ `BLOCKED` terminal). O arquivo nasce em quarentena e
/// só fica disponível após veredito CLEAN (INSERT de `FileScan` + UPDATE do `state` na MESMA transação — promoção
/// atômica). `bucketKey` é referência OPACA ao objeto no storage (`<orgId>/<uuidv4>`) e **nunca** é autorização.
///
/// Isolamento pelo BANCO (RLS ENABLE+FORCE + WITH CHECK). GRANT column-scoped: o runtime pode UPDATE **só**
/// `state`/`nomeOriginal`/`updatedAt`/`purgedAt`; `bucketKey`/`resourceType`/`resourceId`/`orgId` ficam SEM UPDATE
/// (não transferível — provado por `permission denied`). **Sem DELETE** — remover é `state` (LGPD; expurgo é do
/// binário no storage, não da linha). Em `MODELOS_AUDITADOS`.
model FileObject {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @db.Uuid
  /// Chave OPACA do objeto no storage (`<orgId>/<uuidv4>`). Nunca é autorização; guarda de tenant é por SEGMENTO.
  bucketKey    String    @unique
  /// Nome original do arquivo. **PII** — fora de log; mascarável. Coluna de ciclo de vida (editável no substituir).
  nomeOriginal String
  /// Tipo do recurso dono (genérico — texto, não enum, para não acoplar a 3.7 a Card/Registro). Preenchido pelo consumidor.
  resourceType String
  /// Id do recurso dono. A autorização é resolvida pela porta a partir de `(resourceType, resourceId)`.
  resourceId   String    @db.Uuid
  /// Estado do ciclo de vida. Nasce em QUARENTENA; só o veredito CLEAN promove a DISPONIVEL (fail-closed).
  state        FileState @default(QUARENTENA)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  /// Instante do expurgo físico do binário (null enquanto não expurgado). Remoção lógica precede o expurgo.
  purgedAt     DateTime?

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scans        FileScan[]
  /// Story 3.10: o slot de avatar que aponta para este arquivo (quando `resourceType='ACCOUNT'`).
  avatars      AccountAvatar[]

  // Contagem por recurso (limite de 10 — Q1) e listagem por recurso do consumidor.
  @@index([orgId, resourceType, resourceId])
  @@map("FileObject")
}

/// FileScan — fato apurado da verificação de segurança (Story 3.7). Dado org-owned, **append-only e IMUTÁVEL**:
/// o runtime recebe **só SELECT+INSERT** (sem UPDATE/DELETE — ver GRANT), como `FormVersion`/`CardHistory`/
/// `RecordHistory`. Uma vez escrito, o veredito e os hashes não mudam — é a prova do que foi verificado.
///
/// Guarda os dois checksums (aceite × releitura) que provam que o conteúdo verificado é o que será promovido
/// (anti-troca-de-bytes), o tipo detectado por conteúdo real (magic bytes), o tamanho e o veredito composto.
/// Escrito na MESMA transação da promoção do `FileObject` (AD-13). Isolamento pelo banco (RLS ENABLE+FORCE +
/// WITH CHECK). Em `MODELOS_AUDITADOS`.
model FileScan {
  id              String      @id @default(uuid()) @db.Uuid
  orgId           String      @db.Uuid
  fileId          String      @db.Uuid
  /// Tamanho real em bytes (apurado no aceite/releitura). BigInt — arquivos podem exceder Int.
  tamanhoBytes    BigInt
  /// Tipo detectado por CONTEÚDO real (magic bytes), não pela extensão declarada.
  mimeDetectado   String
  /// Checksum SHA-256 no aceite (ingestão).
  sha256Ingest    String
  /// Checksum SHA-256 na releitura durante o scan. Diferente do de ingestão ⇒ troca de bytes ⇒ BLOCKED.
  sha256Releitura String
  /// Veredito composto: CLEAN só se magic bytes + tamanho + 2×SHA iguais + ClamAV CLEAN + if-match; senão BLOCKED.
  veredito        FileVerdict
  scannedAt       DateTime    @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  file         FileObject   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([orgId, fileId])
  @@map("FileScan")
}

/// ScanSlot — semáforo de verificação (Story 3.7). Tabela **GLOBAL, sem RLS** (como `RateLimit`/`Account`/
/// `PublicFormRoute`): não pertence a um tenant, e o isolamento aqui é lógico (a `key` embute o `orgId`).
/// Vive conceitualmente sob `kernel/antiabuso/` — limita a concorrência de scans por Organização (teto config),
/// fail-closed no teto (429). Cada linha ativa é UM slot; várias linhas por `key` até o teto.
///
/// `adquirirSlot`: statement atômico que insere só abaixo do teto (conta linhas ativas por `key`) → `token` ou nada
/// (429). `liberarSlot(token)`: DELETE em `finally`. `expiraEm` é auto-liberação (slot órfão de um scan que morreu).
/// GRANT: `SELECT, INSERT, DELETE` (é a única tabela da capacidade que o runtime pode DELETE — não guarda dado do
/// titular, é efêmera). NÃO está em `MODELOS_AUDITADOS` (semáforo técnico, não mutação de dado de negócio).
model ScanSlot {
  /// Posse do slot: gerado pela aplicação no `adquirirSlot` e usado no `liberarSlot`. PK (único por slot).
  token    String   @id @db.Uuid
  /// Chave do semáforo `scan:<orgId>`. Várias linhas ativas por `key` até o teto de concorrência.
  key      String
  /// Expiração do slot (auto-liberação). Instante absoluto — comparado com `now()`.
  expiraEm DateTime @db.Timestamptz

  // Contagem de slots ativos por `key` (para o teto) e varredura de expirados.
  @@index([key, expiraEm])
  @@map("ScanSlot")
}

/// Estado do ciclo de vida do FileObject (Story 3.7). Fail-closed: nasce em QUARENTENA, indisponível até CLEAN.
/// `BLOCKED` é terminal (nunca baixável/associável). Remoção é lógica (`REMOVIDO_LOGICO`); `EXPURGADO` = binário
/// expurgado do storage, linha preservada (LGPD). `restaurado`/`promovido` NÃO são estados — são transições.
enum FileState {
  QUARENTENA
  DISPONIVEL
  REMOVIDO_LOGICO
  EXPURGADO
  BLOCKED
}

/// Estado do vínculo Card↔Registro (Story 3.9). `ACTIVE` = vínculo vigente; `REMOVED` = desvinculado (soft —
/// sem exclusão física, preserva a trilha). Desvincular é `state = REMOVED`, não DELETE.
enum CardRecordLinkState {
  ACTIVE
  REMOVED
}

/// CardRecordLink — vínculo explícito **N–N** entre Card e Registro (Story 3.9). Entidade DISTINTA
/// (`Card ≠ Registro`): um Card pode ter vários Registros e vice-versa. Org-scoped, isolamento pelo BANCO
/// (RLS ENABLE+FORCE + WITH CHECK no INSERT e UPDATE). Runtime recebe `SELECT/INSERT/UPDATE` — **sem DELETE**
/// (desvincular é `state=REMOVED`). O par único é imposto pelo banco via índice único **parcial**
/// `(orgId, cardId, recordId) WHERE state='ACTIVE'` (raw SQL na migration — Prisma 6.19.3 não expressa parcial):
/// a 2ª criação ativa do mesmo par colide no INSERT (P2002→idempotente/409), sem leitura-antes-de-escrever.
/// **O vínculo NUNCA concede acesso** — cada recurso mantém sua autorização canônica (Card por pipe-authz;
/// Registro por database-authz); criar/remover exige operar OS DOIS. `correlationId` correlaciona os eventos
/// `LINKED`/`UNLINKED` gravados no `CardHistory` e no `RecordHistory` na MESMA transação (AD-13). Em
/// `MODELOS_AUDITADOS`.
model CardRecordLink {
  id            String              @id @default(uuid()) @db.Uuid
  orgId         String              @db.Uuid
  cardId        String              @db.Uuid
  recordId      String              @db.Uuid
  state         CardRecordLinkState @default(ACTIVE)
  /// Da operação que criou o vínculo — mesmo valor dos dois eventos `LINKED` (Card e Registro).
  correlationId String              @db.Uuid
  /// Ator que criou o vínculo (quando disponível).
  createdBy     String?             @db.Uuid
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  /// Instante da remoção lógica (null enquanto ACTIVE).
  removedAt     DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  record       Record       @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([orgId, cardId])
  @@index([orgId, recordId])
  // Nota: a unicidade "um vínculo ATIVO por (orgId, cardId, recordId)" é índice PARCIAL na migration
  // (WHERE state='ACTIVE') — não expressável aqui no Prisma 6.19.3.
  @@map("CardRecordLink")
}

/// Veredito da verificação (Story 3.7). Binário e fail-closed: qualquer coisa que não seja comprovadamente limpa
/// (erro, timeout, base velha, limite excedido, troca de bytes, assinatura ClamAV) é `BLOCKED`, nunca CLEAN por omissão.
enum FileVerdict {
  CLEAN
  BLOCKED
}

/// Estado do slot de avatar (Story 3.10). `ACTIVE` = avatar vigente na Organização; `REMOVED` = retirado pelo
/// titular (soft — a linha é preservada e reaproveitada no próximo envio). Remover é `state`, nunca DELETE:
/// o runtime não tem GRANT de DELETE em `AccountAvatar`.
enum AccountAvatarState {
  ACTIVE
  REMOVED
}

/// AccountAvatar — o SLOT de avatar de uma Conta DENTRO de uma Organização (Story 3.10, FR-32).
///
/// Por que uma tabela org-scoped, e não uma coluna em `Account`: `Account` é GLOBAL e **sem RLS** (AD-10), e o
/// runtime tem **SELECT-only** nela. Uma coluna `Account.avatarFileId` com GRANT column-scoped restringiria
/// *qual coluna*, mas **não** *qual linha* — o runtime poderia trocar o avatar de qualquer conta, em qualquer
/// Organização, e o único freio seria a aplicação. Aqui o freio é o BANCO: as policies são self-only
/// (`orgId = current_org_id() AND accountId = current_account_id()`), com `WITH CHECK` no INSERT e no UPDATE.
/// `Account` permanece intocada.
///
/// Por que não bastou o `FileObject` sozinho (a alternativa investigada primeiro): `FileObject.state` é o ciclo
/// de VERIFICAÇÃO (`QUARENTENA`→`DISPONIVEL` pelo antivírus), não o do slot — um índice único parcial sobre
/// `DISPONIVEL` só seria imposto na promoção assíncrona pós-scan, e dois envios colidiriam dentro do caminho do
/// antivírus, não no do usuário. Além disso, um índice condicionado a `resourceType='ACCOUNT'` acoplaria a
/// tabela genérica da 3.7 a um consumidor concreto.
///
/// A unicidade é SIMPLES (`@@unique([orgId, accountId])`), não parcial: **uma linha por par**. "Um avatar ativo
/// por Conta em cada Organização" cai por CONSTRUÇÃO — substituir é `UPDATE` de `fileId` numa linha só (atômico
/// por definição), remover é `state='REMOVED'`, reenviar volta a `ACTIVE`. A leitura só considera `ACTIVE`.
///
/// O avatar é POR ORGANIZAÇÃO por decisão de MVP (não é débito): é o que preserva o isolamento — nenhuma
/// referência global aponta para um arquivo org-scoped. Sem avatar na Org ativa, a UI cai nas iniciais (1.11).
model AccountAvatar {
  id        String             @id @default(uuid()) @db.Uuid
  orgId     String             @db.Uuid
  accountId String             @db.Uuid
  /// `FileObject` (`resourceType='ACCOUNT'`, `resourceId=accountId`) com o binário. Mesma Organização — o
  /// serviço revalida sob RLS antes de apontar, e a FK garante que a linha existe.
  fileId    String             @db.Uuid
  state     AccountAvatarState @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  /// Instante da remoção lógica (null enquanto ACTIVE).
  removedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  file         FileObject   @relation(fields: [fileId], references: [id], onDelete: Restrict)

  /// UM avatar por Conta por Organização — imposto pelo banco, sem índice parcial.
  @@unique([orgId, accountId])
  @@index([orgId, fileId])
  @@map("AccountAvatar")
}

/// Estado da Automação (Story 4.1 — coluna; Story 4.2 — TRANSIÇÕES).
///
/// `INACTIVE` é o default e é o que torna a 4.1 segura de entregar ANTES do motor: "só a ativa dispara"
/// (D4.3), então nada criado por esta Story pode disparar — por CONSTRUÇÃO, não por ausência de código.
/// O runtime da 4.1 não recebe GRANT de UPDATE, logo sequer CONSEGUE levar uma Automação a `ACTIVE`.
enum AutomationState {
  INACTIVE
  ACTIVE
  ARCHIVED
}

/// Automation — a Automação declarativa (Story 4.1, FR-21/RN-100/RN-101).
///
/// Pertence a EXATAMENTE UM Pipe (RN-100) e nunca atravessa Organização (NFR-3). A estrutura é
/// `quando` (Evento) → `condicoes` (AND) → `entao` (Ações), persistida em JSONB e validada por núcleo
/// PURO (`automation-config.ts`, fail-closed com allowlist). Os CATÁLOGOS de Evento/Condição/Ação são
/// 4.3/4.4/4.5 — a 4.1 valida a ESTRUTURA e as REFERÊNCIAS, não o vocabulário (AD-11).
///
/// Isolamento pelo BANCO: RLS ENABLE **e** FORCE, policies por `orgId = current_org_id()` com `WITH
/// CHECK` no INSERT e no UPDATE. GRANT do runtime = `SELECT, INSERT` — **sem UPDATE** (editar/transicionar
/// é 4.2, que abrirá o privilégio junto do seu consumidor e do teste que prova o escopo dele, como `Card`
/// fez entre a 2.7 e a 2.11) e **sem DELETE** ("não há exclusão definitiva", D4.3, garantido pelo banco).
model Automation {
  id                  String          @id @default(uuid()) @db.Uuid
  orgId               String          @db.Uuid
  pipeId              String          @db.Uuid
  name                String
  state               AutomationState @default(INACTIVE)
  /// Ponteiro para a `AutomationVersion` em vigor (Story 4.2 — D-4.2-B). Twin de `Form.publishedVersion`.
  /// INVARIANTE: `state = ACTIVE ⟹ activeVersion != null` — ativar e editar-enquanto-ativa congelam a
  /// config vigente numa versão e avançam este número; o motor (4.6) captura-o e nunca mistura versões
  /// numa Execução. Desativar/arquivar NÃO o zeram (histórico inerte; o motor gateia por `state`). É
  /// NÚMERO, não FK, pelo mesmo motivo de `Form.publishedVersion`: evita o ciclo de FK e não há ponteiro
  /// pendente (versões nunca são apagadas — GRANT sem DELETE em `AutomationVersion`).
  activeVersion       Int?
  /// Idempotência OPCIONAL de criação/duplicação (Story 4.2 — D-4.2-F). Com `@@unique([orgId, pipeId,
  /// idempotencyKey])`: NULLs são distintos no Postgres, então criações sem chave nunca colidem (a `criar`
  /// da 4.1 segue idêntica); com chave, um retry devolve a Automação existente (P2002 → idempotente).
  /// Imutável após criação — fora do GRANT de UPDATE column-scoped.
  idempotencyKey      String?
  /// Versão do SCHEMA do documento de configuração (não da Automação — versões dela são a 4.2).
  /// Carimbada pelo servidor, nunca aceita do cliente. É o que torna migrável um JSON persistido: sem
  /// ela, 4.3/4.4/4.5 não distinguiriam "config antiga válida" de "config corrompida". É COLUNA, e não
  /// chave dentro do JSON, para ser consultável — "quais linhas ainda estão na v1?".
  configSchemaVersion Int             @default(1)
  /// QUANDO — o Evento gatilho. Objeto com `tipo` (catálogo = 4.3) e `refs` opcionais.
  quando              Json
  /// CONDIÇÕES — array combinado por E/AND (D4.1). Vazio = sem Condição: a Ação executa direto.
  condicoes           Json            @default("[]")
  /// ENTÃO — array de Ações, NÃO VAZIO (uma Automação sem Ação não é uma Automação).
  entao               Json
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// FK **COMPOSTA** tenant-safe (F-A1). Referencia o PAR `(orgId, id)` de `Pipe`, não só o `id`.
  ///
  /// Com uma FK simples em `pipeId`, um INSERT com `orgId` próprio e `pipeId` ALHEIO passaria: o `WITH
  /// CHECK` da RLS só olha o `orgId` (que é legítimo), e a verificação de FK roda com BYPASS de row
  /// security — encontraria o Pipe da outra Organização e aceitaria. Sobraria apenas a releitura no
  /// serviço guardando o invariante-mãe, e nesta base quem isola é o banco, não a aplicação.
  ///
  /// Com o par, o vazamento cross-tenant deixa de ser questão de código e vira violação de FK.
  /// `RESTRICT` porque o runtime não tem DELETE em `Pipe`: apagar um Pipe com Automação é erro
  /// explícito, nunca cascata silenciosa.
  pipe Pipe @relation(fields: [orgId, pipeId], references: [orgId, id], onDelete: Restrict)

  /// Versões congeladas da configuração (Story 4.2). Snapshot imutável por edição-ativa/ativação.
  versions AutomationVersion[]

  /// Execuções lógicas do motor (Story 4.6). FK composta tenant-safe RESTRICT — não há DELETE de Automação
  /// com Execução (a trilha da 4.8 é preservada).
  executions AutomationExecution[]

  /// Alvo da FK COMPOSTA tenant-safe de `AutomationVersion` — o par `(orgId, id)` prova, no banco, que a
  /// versão e a Automação pertencem à MESMA Organização (mesmo racional de F-A1).
  @@unique([orgId, id])
  /// Idempotência de criação/duplicação (D-4.2-F). NULLs distintos ⇒ sem chave não há colisão.
  @@unique([orgId, pipeId, idempotencyKey])
  /// A consulta do motor (4.6) é "Automações ATIVAS de um Pipe"; a desta Story é "Automações de um Pipe".
  @@index([orgId, pipeId, state])
  @@map("Automation")
}

/// AutomationVersion — SNAPSHOT IMUTÁVEL da configuração de uma Automação (Story 4.2 — D-4.2-A, twin de
/// `FormVersion`). É o que a 4.2/4.6 exigem: editar uma Automação ATIVA (ou ativá-la) CONGELA a config
/// vigente aqui; o motor (4.6) captura `Automation.activeVersion` e avalia a versão, nunca o rascunho — sem
/// mistura de versões dentro de uma Execução.
///
/// **Imutabilidade é do banco:** RLS ENABLE **e** FORCE, policies por `orgId = current_org_id()` com `WITH
/// CHECK` no INSERT e no UPDATE; GRANT do runtime = **só `SELECT, INSERT`** (sem UPDATE/DELETE). Uma rota que
/// tentasse alterar/apagar uma versão bateria em `permission denied` — como `FormVersion`/`CardHistory`.
model AutomationVersion {
  id                  String   @id @default(uuid()) @db.Uuid
  orgId               String   @db.Uuid
  automationId        String   @db.Uuid
  /// Número monotônico por Automação (1, 2, 3...). Unicidade imposta pelo banco.
  version             Int
  /// Snapshot integral da config congelada (`quando`/`condicoes`/`entao`/`schemaVersion`). Validado no núcleo.
  snapshot            Json
  /// Hash determinístico do snapshot — identifica a versão e detecta divergência.
  revision            String
  /// Versão do SCHEMA da config no momento do congelamento (espelha `Automation.configSchemaVersion`).
  configSchemaVersion Int
  /// Conta que congelou a versão (quando disponível). Referência de ator para auditoria, não PII sensível.
  actorId             String?  @db.Uuid
  createdAt           DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// FK **COMPOSTA** tenant-safe (mesmo racional de F-A1): referencia o PAR `(orgId, id)` de `Automation`, não
  /// só o `id` — uma versão nunca pertence a uma Automação de outra Organização, garantido pelo banco.
  automation Automation @relation(fields: [orgId, automationId], references: [orgId, id], onDelete: Cascade)

  @@unique([orgId, automationId, version])
  @@index([orgId, automationId])
  @@map("AutomationVersion")
}

/// DomainEvent — outbox CANÔNICO de Evento de integração (Story 4.3 — FR-21, D4.1, AD-13/AD-30).
///
/// GENERALIZA `MovementEvent` (2.16) para o catálogo completo de gatilhos (`event-catalog.ts`). É a trilha de
/// INTEGRAÇÃO (AD-15), DISTINTA do Histórico do Card/Registro e da Auditoria: o registro atômico e confiável do
/// fato de domínio (AD-13 "Outbox"), consumido pelo motor de Automação (4.6) e, futuramente, por Notificação
/// (E5). Source-agnóstico: o recurso principal é polimórfico (`resourceType`/`resourceId`), pois o outbox
/// atende Card, Registro e vínculo. Ver a decisão em
/// `_bmad-output/implementation-artifacts/decisions/domain-event-envelope-4-3.md`.
///
/// **Imutabilidade é do banco:** RLS ENABLE **e** FORCE, policies por `orgId = current_org_id()` com `WITH
/// CHECK` no INSERT e no UPDATE; GRANT do runtime = **só `SELECT, INSERT`** (append-only, sem UPDATE/DELETE) —
/// como `MovementEvent`/`CardHistory`/`FormVersion`. `eventId` DETERMINÍSTICO (uuidv5) + `@@unique([orgId,
/// eventId])` ⇒ reprocessar o mesmo fato não cria 2ª linha lógica (idempotência).
model DomainEvent {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @db.Uuid
  /// Identidade lógica estável do evento (determinística por fato). Única por Organização.
  eventId          String   @db.Uuid
  /// Tipo do catálogo (`event-catalog.ts`). String — vocabulário canônico estável (ex.: `CARD_CREATED`).
  eventType        String
  /// Versão do CONTRATO do envelope canônico (`SCHEMA_VERSION_ENVELOPE`). Carimbada pelo servidor.
  schemaVersion    Int      @default(1)
  /// Pipe do recurso, quando aplicável (Card/vínculo). NULL para Registro puro (Story §1339).
  pipeId           String?  @db.Uuid
  /// Recurso principal do Evento (polimórfico). `resourceType` ∈ {CARD, RECORD, CARD_RECORD_LINK}.
  resourceType     String
  resourceId       String   @db.Uuid
  /// Ator que originou o fato (quando disponível). Referência mínima de auditoria (pseudonimizável — D-4).
  actorId          String?  @db.Uuid
  /// Origem do fato (ex.: `SUBMISSION`, `PUBLIC`, `MOVE`). Vocabulário estável.
  origin           String
  /// Momento efetivo do fato (instante absoluto).
  occurredAt       DateTime @default(now()) @db.Timestamptz(3)
  /// Correlação da operação (linka eventos relacionados de um mesmo fato). Base do `eventId` determinístico.
  correlationId    String   @db.Uuid
  /// Evento causador (encadeamento por Automação — 4.7). NULL fora do motor.
  causationId      String?  @db.Uuid
  /// Cadeia de execução quando originado por Automação (4.7). NULL fora do motor.
  executionChainId String?  @db.Uuid
  /// Profundidade de encadeamento (Story 4.7). RAIZ (Evento externo) = 0; um Evento gerado por uma Ação carrega
  /// `profundidade-do-pai + 1`. O motor lê isto ao enfileirar a Execução-filha para aplicar `MAX_CHAIN_DEPTH`.
  /// INSERT-only (o outbox é append-only — GRANT sem UPDATE em `DomainEvent`).
  chainDepth       Int      @default(0)
  /// Envelope mínimo versionado (allowlist AD-30): só IDs/metadados da transição. NUNCA `valores`/PII/segredo.
  payload          Json     @default("{}")
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// FK **COMPOSTA** tenant-safe (F-A1): referencia o PAR `(orgId, pipeId)` de `Pipe`, não só `pipeId`. Uma FK
  /// simples deixaria passar `pipeId` alheio (a verificação de FK roda com BYPASS de row security). Com o par,
  /// o vazamento cross-tenant vira violação de FK — garantido pelo banco. `pipeId` nulável (Registro puro): o
  /// MATCH SIMPLE do Postgres não checa a FK quando a coluna é NULL. `CASCADE` como `MovementEvent` (2.16): o
  /// evento é um FATO DERIVADO da existência do Pipe — apagar o Pipe (operação SÓ do dono; o runtime não tem
  /// GRANT de DELETE em `Pipe`) leva junto seus eventos, sem RESTRICT bloqueando a limpeza/expurgo do dono. O
  /// recurso principal (`resourceId`) é polimórfico e não tem FK — isolado por RLS+orgId e validado in-tx pelo
  /// produtor (mesma natureza de uma referência por ID no payload).
  pipe Pipe? @relation(fields: [orgId, pipeId], references: [orgId, id], onDelete: Cascade)

  // Um reprocessamento do mesmo fato não cria um 2º evento lógico (idempotência).
  @@unique([orgId, eventId])
  // Consulta do motor (4.6): eventos de um Pipe por tipo (Automações são por Pipe — RN-100).
  @@index([orgId, pipeId, eventType])
  // Leitura da trilha por recurso (cronológica) e correlação com a operação.
  @@index([orgId, resourceType, resourceId, occurredAt])
  @@index([orgId, correlationId])
  @@map("DomainEvent")
}

/// Estado de uma Execução lógica de Automação (Story 4.6 — motor). Estados HONESTOS (§1411, UX-DR6):
/// `PENDING` (enfileirada, dedup criada), `RUNNING` (reivindicada, com lease), terminais `SUCCEEDED`/`PARTIAL`/
/// `FAILED`, `SKIPPED_CONDITIONS` (Condição AND não satisfeita — nenhuma Ação), `BLOCKED_CONFIRMATION` (uma Ação
/// exige confirmação humana — §1383; o motor NÃO a executa e NÃO mantém job aberto). Nunca há estado que funda
/// os dois eixos (dedup lógica × progresso físico) — o progresso por Ação vive em `AutomationActionResult`.
enum AutomationExecutionState {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  SKIPPED_CONDITIONS
  BLOCKED_CONFIRMATION
  /// Story 4.7 — Execução BARRADA por limite de encadeamento (profundidade/ciclo/timeout da cadeia). TERMINAL,
  /// dead-letter auditável, NÃO reivindicável (a fila só reivindica PENDING/RUNNING-lease-vencida). "Interrompida
  /// por limite" (§1432, UX-DR6); o motivo exato vive em `lastErrorCode` (DEPTH_EXCEEDED/CYCLE_DETECTED/CHAIN_TIMEOUT).
  HALTED_BY_LIMIT
}

/// Estado do resultado de UMA Ação dentro da Execução (Story 4.6). `SUCCEEDED`/`FAILED` (efeito ou falha reais),
/// `DENIED` (revalidação 4.5 recusou — não-ampliação/M-1/estado/alvo indeterminado), `BLOCKED_CONFIRMATION`
/// (Ação sensível — §1383), `BLOCKED_PRIOR_FAILURE` (uma Ação anterior da MESMA Automação falhou/foi recusada —
/// D4.2: as seguintes não executam). Append-only, como o próprio resultado (fato consumado).
enum AutomationActionResultState {
  SUCCEEDED
  FAILED
  DENIED
  BLOCKED_CONFIRMATION
  BLOCKED_PRIOR_FAILURE
}

/// AutomationExecution — a EXECUÇÃO LÓGICA do motor (Story 4.6 — FR-23, D4.2, AD-13/18). Uma por
/// `(evento × Automação × versão)`, materializada preguiçosamente a partir do outbox `DomainEvent` (4.3). É,
/// ao mesmo tempo, o **cursor de processamento** (a existência da linha = "este evento já foi processado por
/// esta Automação nesta versão" — o outbox é append-only e não pode ser marcado) e a **trilha** que a 4.8 lerá.
///
/// **Dedup lógica (§1402):** `@@unique([orgId, eventId, automationId, automationVersionId])` — uma ocorrência
/// reentregue (at-least-once) reencontra a mesma Execução; nunca há 2ª. **Versão congelada (§1404):**
/// `automationVersionId`/`configSnapshotRevision` capturados na criação; o motor avalia a versão, nunca o
/// rascunho, e desativar/arquivar depois NÃO cancela Execução iniciada.
///
/// **Concorrência/recuperação:** `leaseOwner`/`leaseExpiresAt` — a claim (`FOR UPDATE SKIP LOCKED`) reivindica
/// PENDING e RUNNING-com-lease-vencida (crash retomado sem duplicar efeito, pois o progresso por Ação é
/// idempotente). `attempt`/`nextAttemptAt` = backoff (falha transitória). **Auditoria (§1384):** `initiator*`
/// preserva quem iniciou a mudança ORIGINAL (nunca fundido com o ator=principal Automação=`automationId`).
///
/// **Isolamento pelo BANCO:** RLS ENABLE+FORCE, policies por `current_org_id()` com WITH CHECK no INSERT e no
/// UPDATE; FK COMPOSTA tenant-safe `(orgId, automationId)→Automation(orgId, id)` (F-A1). **GRANT como fronteira:**
/// `SELECT/INSERT` + **UPDATE column-scoped** só das colunas de progresso (estado/lease/attempt/tempos/errorCode);
/// `eventId`/`automationId`/`automationVersionId`/`orgId`/`pipeId`/`initiator*` IMUTÁVEIS por GRANT (uma Execução
/// não migra de evento/Automação/versão — provado no `automation-engine-rls`). **Sem DELETE** de runtime.
model AutomationExecution {
  id                     String                   @id @default(uuid()) @db.Uuid
  orgId                  String                   @db.Uuid
  /// Identidade lógica do fato gatilho (`DomainEvent.eventId`). Sem FK: o outbox pode ser expurgado pelo dono
  /// e a Execução (trilha da 4.8) sobrevive — como uma referência por id. Isolado por RLS+orgId.
  eventId                String                   @db.Uuid
  automationId           String                   @db.Uuid
  /// Número da versão congelada avaliada (`Automation.activeVersion` no ato). NÚMERO, não FK — como
  /// `Form.publishedVersion`: evita ciclo de FK; a versão nunca é apagada (GRANT sem DELETE em AutomationVersion).
  automationVersionId    Int
  /// Revisão (hash) do snapshot da versão avaliada — congela a config e detecta divergência (sem mistura, §1404).
  configSnapshotRevision String
  pipeId                 String                   @db.Uuid
  state                  AutomationExecutionState @default(PENDING)
  /// Tentativa atual (1..MAX). Backoff exponencial via `nextAttemptAt`; esgotar ⇒ estado final explícito (§1405).
  attempt                Int                      @default(0)
  nextAttemptAt          DateTime?                @db.Timestamptz(3)
  /// Lease de processamento (recuperação de job interrompido). `leaseOwner` = id do worker; `leaseExpiresAt` no
  /// passado ⇒ reivindicável. Um crash deixa RUNNING com lease vencida; o próximo drain retoma.
  leaseOwner             String?                  @db.Uuid
  leaseExpiresAt         DateTime?                @db.Timestamptz(3)
  startedAt              DateTime?                @db.Timestamptz(3)
  finishedAt             DateTime?                @db.Timestamptz(3)
  /// Iniciador PRESERVADO (§1384) — quem iniciou a mudança original que emitiu o evento. Nunca é o principal
  /// Automação (esse é o ATOR = `automationId`). `HUMANO`/`AUTOMACAO`/`SISTEMA` (String — vocabulário estável).
  initiatorType          String
  initiatorAccountId     String?                  @db.Uuid
  initiatorAutomationId  String?                  @db.Uuid
  correlationId          String                   @db.Uuid
  /// Cadeia de execução — propagada na 4.7. RAIZ (Evento externo) = o próprio `eventId` do gatilho; um filho
  /// HERDA o `executionChainId` do Evento gerador. NULL só em linhas legadas anteriores à 4.7.
  executionChainId       String?                  @db.Uuid
  /// Profundidade da Execução na cadeia (Story 4.7). RAIZ = 0; herdada do `DomainEvent.chainDepth` no enfileiramento.
  /// INSERT-only (não migra de nível — fora do GRANT de UPDATE column-scoped).
  chainDepth             Int                      @default(0)
  /// Código de erro SANITIZADO da última falha (enum estrutural em texto — NUNCA id/valor/PII/stack, AD-30).
  lastErrorCode          String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe (F-A1). RESTRICT: o runtime não tem DELETE em `Automation`; apagar uma Automação
  /// com Execução é erro explícito do dono, nunca cascata silenciosa que apagaria a trilha.
  automation   Automation   @relation(fields: [orgId, automationId], references: [orgId, id], onDelete: Restrict)

  actionResults AutomationActionResult[]

  /// Dedup lógica (§1402): ≤1 Execução por (evento, Automação, versão).
  @@unique([orgId, eventId, automationId, automationVersionId])
  /// Alvo da FK composta tenant-safe de `AutomationActionResult`.
  @@unique([orgId, id])
  /// Fila de reivindicação do drain: PENDING/lease-vencida por prazo.
  @@index([orgId, state, nextAttemptAt])
  /// Story 4.7 — consulta por cadeia (início da cadeia p/ timeout; inspeção de encadeamento).
  @@index([orgId, executionChainId])
  @@map("AutomationExecution")
}

/// AutomationActionResult — resultado de UMA Ação da Execução (Story 4.6). APPEND-ONLY: o resultado de uma Ação
/// é fato consumado; um retry que reprocessa a Execução só INSERE resultados das Ações AINDA sem linha (a dedup
/// de Ação garante "a mesma Ação não roda 2×", §1403). GRANT **só SELECT/INSERT** (imutável, como CardHistory).
///
/// **Dedup de Ação (§1403):** `@@unique([orgId, executionId, actionIndex])` — posição estável na config. FK
/// COMPOSTA tenant-safe `(orgId, executionId)→AutomationExecution(orgId, id)`, CASCADE (fato derivado da Execução).
/// **Sanitização (AD-30):** `targetResourceId` é só id de recurso; `valores`/PII NUNCA entram; `errorCode` é o
/// enum estrutural sanitizado da recusa/falha.
model AutomationActionResult {
  id               String                      @id @default(uuid()) @db.Uuid
  orgId            String                      @db.Uuid
  executionId      String                      @db.Uuid
  /// Posição estável da Ação na config `entao` (0-based) — a chave idempotente da Ação (§1403).
  actionIndex      Int
  actionType       String
  state            AutomationActionResultState
  /// Código sanitizado (motivo da recusa/falha) — nunca id/valor/PII/stack (AD-30). `null` no sucesso.
  errorCode        String?
  /// Id do recurso ALVO efetivamente tocado (Card/Registro), quando houver. Só id — nunca `valores`.
  targetResourceId String?                     @db.Uuid
  createdAt        DateTime                    @default(now())

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  execution    AutomationExecution @relation(fields: [orgId, executionId], references: [orgId, id], onDelete: Cascade)

  /// Dedup de Ação (§1403): ≤1 resultado por (Execução, posição).
  @@unique([orgId, executionId, actionIndex])
  @@index([orgId, executionId])
  @@map("AutomationActionResult")
}

/// AutomationChainVisit — registro APPEND-ONLY da ASSINATURA DE VISITA de uma cadeia (Story 4.7 — NFR-7, AD-18).
/// É o mecanismo de PREVENÇÃO DE CICLOS imposto pelo BANCO: cada Execução que o motor está prestes a rodar numa
/// cadeia registra sua assinatura determinística `(automationId + versão + eventType + resourceId)` sob o
/// `executionChainId`. O índice único `(orgId, executionChainId, signature)` faz a 2ª tentativa de rodar a MESMA
/// assinatura na MESMA cadeia colidir (P2002) — é a detecção de RE-VISITA (ciclo direto A→A e indireto A→B→A),
/// race-safe por construção (o banco arbitra dois workers concorrentes), FAIL-CLOSED (colisão ⇒ Execução barrada
/// como `HALTED_BY_LIMIT`/`CYCLE_DETECTED`, nunca executa). O `eventId` distingue REDELIVERY do MESMO Evento
/// (at-least-once — não é ciclo) de um Evento DIFERENTE com a mesma assinatura (é ciclo): a assinatura já
/// registrada com o MESMO `eventId` é a mesma ocorrência; com `eventId` distinto é re-visita.
///
/// **Isolamento pelo BANCO:** RLS ENABLE+FORCE, policies por `current_org_id()` com WITH CHECK no INSERT (e no
/// UPDATE por simetria/defesa — o runtime não tem GRANT de UPDATE). **GRANT como fronteira:** SÓ `SELECT/INSERT`
/// (append-only imutável, como `CardHistory`/`FormVersion`/`DomainEvent`/`AutomationActionResult`) — **sem DELETE**.
/// `executionId` é referência por id (sem FK, isolada por RLS+orgId), como `eventId` em `AutomationExecution`: a
/// visita SOBREVIVE ao expurgo eventual da Execução (é a prova durável de que a assinatura foi visitada).
model AutomationChainVisit {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @db.Uuid
  /// Raiz da cadeia (o `executionChainId` propagado). Todas as visitas de uma cadeia compartilham este valor.
  executionChainId String   @db.Uuid
  /// Assinatura determinística de visita (SHA-256 hex de `automationId:versão:eventType:resourceId`) — §1425/§1431.
  signature        String
  /// Evento gatilho que registrou a visita — distingue REDELIVERY (mesmo eventId) de RE-VISITA (eventId distinto).
  eventId          String   @db.Uuid
  /// Execução que registrou a visita (referência por id, sem FK — isolada por RLS+orgId).
  executionId      String   @db.Uuid
  createdAt        DateTime @default(now()) @db.Timestamptz(3)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// PREVENÇÃO DE CICLO (o coração de segurança): ≤1 visita por (cadeia, assinatura). A 2ª colide (P2002).
  @@unique([orgId, executionChainId, signature])
  /// Início da cadeia (min createdAt) para o timeout de duração e inspeção do encadeamento.
  @@index([orgId, executionChainId])
  @@map("AutomationChainVisit")
}

// ═══════════════════════════════════════════════════════════════════════════════════════════════════
// ÉPICO 5 — Tarefas, Solicitações e Notificações. Story 5.1: Tarefas — ciclo de vida e acompanhamento.
// ═══════════════════════════════════════════════════════════════════════════════════════════════════

/// Estado OPERACIONAL da Tarefa (Story 5.1, §1526). Eixo INDEPENDENTE do arquivamento. Nasce ABERTA;
/// concluir → CONCLUIDA; reabrir → ABERTA. `atrasada` NÃO é estado persistido — é DERIVADO na leitura
/// (aberta + prazo vencido), como a saúde do Card (2.13).
enum TaskLifecycleState {
  ABERTA
  CONCLUIDA
}

/// Estado de ARQUIVAMENTO da Tarefa (Story 5.1, §1526). Eixo SEPARADO do operacional: uma Tarefa
/// CONCLUIDA pode ser arquivada e restaurada preservando o estado operacional. Arquivar bloqueia toda
/// escrita (mantém leitura autorizada); restaurar preserva identidade/Pipe/Card/Responsável/prazo/anexos.
enum TaskArchiveState {
  ATIVA
  ARQUIVADA
}

/// Task — a Tarefa (Story 5.1, FR-27). Dado operacional org-owned (AD-10). Pertence a EXATAMENTE 1
/// Organização e 1 Pipe; associada a 0..1 Card do MESMO Pipe/Org (a associação NÃO funde recursos nem
/// amplia permissões — acesso à Tarefa ≠ acesso ao Card). Entidade DISTINTA (não reusa Card/Registro).
///
/// **Dois eixos independentes:** `lifecycleState` (ABERTA/CONCLUIDA) e `archiveState` (ATIVA/ARQUIVADA).
/// `atrasada` é DERIVADO na leitura (núcleo puro `task-overdue.core.ts`), nunca persistido.
///
/// **Responsável = 0..1 Membership ATIVA** da mesma Org via `responsavelMembershipId` — REFERÊNCIA-POR-ID
/// sem FK (isolada por RLS+orgId; a atribuição revalida a Membership ACTIVE sob RLS; a suspensão/remoção a
/// esvazia pelo contrato E8/8.5–8.6). FK composta a Membership é inviável (SetNull impossível com `orgId`
/// NOT NULL compartilhado; Cascade quebraria a exclusão de Conta — LGPD). `creatorMembershipId` idem
/// (metadado de autoria preservado, como `actorId`).
///
/// **Prazo:** `dueAt @db.Timestamptz` (instante absoluto — determinístico no fuso oficial, DIV-1) e
/// `dueVersion` (Int monotônico, bumpado a cada mudança de `dueAt`) — a "versão do prazo" da idempotência
/// do Evento "Tarefa atrasada" (ver `TaskOverdueOccurrence` e a decision doc).
///
/// **Isolamento pelo BANCO:** RLS ENABLE+FORCE, WITH CHECK no INSERT e UPDATE. **GRANT como fronteira:**
/// SELECT/INSERT + **UPDATE column-scoped** (título/descrição/prazo/dueVersion/Responsável/estados/cardId/
/// updatedAt) — **sem** `orgId`/`pipeId`/`creatorMembershipId`, **sem DELETE** (arquivar/concluir = state).
/// FK COMPOSTA tenant-safe `(orgId,pipeId)→Pipe` e `(orgId,cardId)→Card` (evita id alheio por bypass de FK).
model Task {
  id                      String             @id @default(uuid()) @db.Uuid
  orgId                   String             @db.Uuid
  pipeId                  String             @db.Uuid
  /// Card associado (0..1), do MESMO Pipe/Org. Vincular/desvincular é operação (UPDATE column-scoped).
  cardId                  String?            @db.Uuid
  title                   String
  description             String?
  /// Prazo como INSTANTE absoluto (determinístico no fuso oficial). Nulo = sem prazo (nunca atrasada).
  dueAt                   DateTime?          @db.Timestamptz(3)
  /// Versão monotônica do prazo — bumpada a cada mudança de `dueAt`. Chave de idempotência do Evento.
  dueVersion              Int                @default(0)
  /// Responsável: referência-por-id a uma Membership ATIVA da mesma Org (sem FK — ver doc do modelo).
  responsavelMembershipId String?            @db.Uuid
  /// Autoria preservada (referência-por-id, como `actorId`). Nunca reescrita (fora do GRANT de UPDATE).
  creatorMembershipId     String?            @db.Uuid
  lifecycleState          TaskLifecycleState @default(ABERTA)
  archiveState            TaskArchiveState   @default(ATIVA)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  organization       Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,pipeId)→Pipe(orgId,id)` (F-A1). Cascade: a Tarefa é dado do Pipe.
  pipe               Pipe                    @relation(fields: [orgId, pipeId], references: [orgId, id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,cardId)→Card(orgId,id)` — nulável (MATCH SIMPLE não checa com NULL).
  /// Cascade como `DomainEvent.pipe`: só dispara no expurgo do dono (runtime não tem DELETE em Card).
  card               Card?                   @relation(fields: [orgId, cardId], references: [orgId, id], onDelete: Cascade)
  history            TaskHistory[]
  overdueOccurrences TaskOverdueOccurrence[]

  /// Alvo da FK COMPOSTA tenant-safe de `TaskHistory`/`TaskOverdueOccurrence`.
  @@unique([orgId, id])
  /// Listagem operacional: Tarefas de um Pipe, por estado.
  @@index([orgId, pipeId, lifecycleState])
  // Nota: a varredura do mecanismo de atraso usa um índice PARCIAL `Task_orgId_dueAt_idx`
  // (WHERE "dueAt" IS NOT NULL) criado por raw SQL na migration — o Prisma 6.19.3 não expressa índice
  // parcial, então ele NÃO é declarado aqui (convenção da base: CardResponsavel/DatabaseGrant), evitando
  // falso-drift num `prisma migrate dev`.
  /// Consulta por Responsável (reatribuição E8; painéis futuros).
  @@index([orgId, responsavelMembershipId])
  /// Consulta por Card associado.
  @@index([orgId, cardId])
  @@map("Task")
}

/// TaskHistory — trilha de eventos da Tarefa (Story 5.1). Espelho estrutural de `CardHistory`, domínio
/// DISTINTO (`Task ≠ Card`). **Append-only e IMUTÁVEL**: GRANT só SELECT+INSERT (sem UPDATE/DELETE). Cada
/// mutação da Tarefa escreve seu evento na MESMA transação (não há mudança sem evento — AD-13).
model TaskHistory {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  taskId    String   @db.Uuid
  /// Vocabulário do evento: CREATED, EDITED, DUE_CHANGED, RESPONSAVEL_ASSIGNED/CHANGED/REMOVED, COMPLETED,
  /// REOPENED, ARCHIVED, RESTORED, CARD_LINKED, CARD_UNLINKED, FILE_ATTACHED, FILE_REMOVED. String — estável.
  type      String
  /// Resumo legível do evento (sem PII desnecessária).
  summary   String
  /// Ator que originou o evento (quando disponível).
  actorId   String?  @db.Uuid
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,taskId)→Task(orgId,id)`. Cascade: fato derivado da Tarefa.
  task         Task         @relation(fields: [orgId, taskId], references: [orgId, id], onDelete: Cascade)

  @@index([orgId, taskId, createdAt])
  @@map("TaskHistory")
}

/// TaskOverdueOccurrence — ocorrência canônica do Evento "Tarefa atrasada" (Story 5.1, gate §1535).
/// **Append-only e IMUTÁVEL**: GRANT só SELECT+INSERT. NÃO persiste o estado `atrasada` (que é derivado);
/// persiste o FATO de que a Tarefa foi detectada vencida numa dada VERSÃO do prazo. Idempotência por
/// `@@unique([orgId, taskId, dueVersion])`: um retry/atraso do scheduler colide (P2002) e é ignorado —
/// no máximo uma ocorrência por versão do prazo. Alterar o prazo bumpa `dueVersion` (nova versão pode
/// emitir de novo). Consumida pela 5.7 (registro no motor E4 + Notificação). Ver a decision doc.
model TaskOverdueOccurrence {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @db.Uuid
  taskId     String   @db.Uuid
  /// Versão do prazo detectada vencida (congela a identidade da ocorrência — idempotência).
  dueVersion Int
  /// Prazo (instante absoluto) que estava vencido — congelado no ato (padrão FormVersion/CardPhaseEntry).
  dueAt      DateTime @db.Timestamptz(3)
  /// Instante da detecção (quando o scan emitiu a ocorrência).
  detectedAt DateTime @default(now()) @db.Timestamptz(3)
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,taskId)→Task(orgId,id)`. Cascade: fato derivado da Tarefa.
  task         Task         @relation(fields: [orgId, taskId], references: [orgId, id], onDelete: Cascade)

  /// Idempotência do Evento: ≤1 ocorrência por (Tarefa, versão do prazo). A 2ª colide (P2002).
  @@unique([orgId, taskId, dueVersion])
  @@index([orgId, taskId])
  @@map("TaskOverdueOccurrence")
}

/// Estado OPERACIONAL da Solicitação (Story 5.2, RN-091). Twin da Tarefa (5.1), mas com a semântica de
/// Solicitação: `ABERTA`/`RESOLVIDA` (resolver→RESOLVIDA; reabrir→ABERTA). SEM mecanismo temporal — não há
/// prazo, `atrasada`, scheduler nem ocorrência de vencimento (diferença central frente à 5.1).
enum SolicitacaoLifecycleState {
  ABERTA
  RESOLVIDA
}

/// Estado de ARQUIVAMENTO da Solicitação (Story 5.2, §1546). Eixo SEPARADO do operacional: uma Solicitação
/// RESOLVIDA pode ser arquivada e restaurada preservando o estado operacional. Arquivar bloqueia toda
/// escrita (mantém leitura autorizada); restaurar preserva identidade/Pipe/Card/Responsável/anexos.
enum SolicitacaoArchiveState {
  ATIVA
  ARQUIVADA
}

/// Solicitacao — a Solicitação (Story 5.2, FR-28). Dado operacional org-owned (AD-10). **Twin da Tarefa
/// (5.1) SEM eixo temporal.** Pertence a EXATAMENTE 1 Organização e 1 Pipe; associada a 0..1 Card do MESMO
/// Pipe/Org (a associação NÃO funde recursos nem amplia permissões — acesso à Solicitação ≠ acesso ao Card).
/// Entidade DISTINTA (`Solicitacao ≠ Task ≠ Card`); reusa PADRÕES/autz, nunca as entidades.
///
/// **Dois eixos independentes:** `lifecycleState` (ABERTA/RESOLVIDA) e `archiveState` (ATIVA/ARQUIVADA).
///
/// **Responsável (0..1, opcional):** `responsavelMembershipId` é referência-por-id a uma Membership ATIVA da
/// mesma Org, SEM FK (isolada por RLS+orgId, como `CardResponsavel`/`actorId`; FK composta a Membership é
/// inviável — `orgId` NOT NULL compartilhado impede SetNull, Cascade quebraria a exclusão de Conta/LGPD).
/// `creatorMembershipId` idem (autoria preservada, como `actorId`). A validade é recomputada na leitura e
/// reconciliada pelo contrato E8 (suspensão/remoção esvazia).
///
/// **Isolamento pelo BANCO:** RLS ENABLE+FORCE, WITH CHECK no INSERT e UPDATE. **GRANT como fronteira:**
/// SELECT/INSERT + **UPDATE column-scoped** (título/descrição/Responsável/estados/cardId/updatedAt) — **sem**
/// `orgId`/`pipeId`/`creatorMembershipId`, **sem DELETE** (arquivar/resolver = state). FK COMPOSTA tenant-safe
/// `(orgId,pipeId)→Pipe` e `(orgId,cardId)→Card` (evita id alheio por bypass de FK). Reusa o índice
/// `Card_orgId_id_key` já criado pela 5.1 e o par `(orgId,id)` de `Pipe` (4.1).
model Solicitacao {
  id                      String                    @id @default(uuid()) @db.Uuid
  orgId                   String                    @db.Uuid
  pipeId                  String                    @db.Uuid
  /// Card associado (0..1), do MESMO Pipe/Org. Vincular/desvincular é operação (UPDATE column-scoped).
  cardId                  String?                   @db.Uuid
  title                   String
  description             String?
  /// Responsável: referência-por-id a uma Membership ATIVA da mesma Org (sem FK — ver doc do modelo). 0..1.
  responsavelMembershipId String?                   @db.Uuid
  /// Autoria preservada (referência-por-id, como `actorId`). Nunca reescrita (fora do GRANT de UPDATE).
  creatorMembershipId     String?                   @db.Uuid
  lifecycleState          SolicitacaoLifecycleState @default(ABERTA)
  archiveState            SolicitacaoArchiveState   @default(ATIVA)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  organization Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,pipeId)→Pipe(orgId,id)`. Cascade: a Solicitação é dado do Pipe.
  pipe         Pipe                 @relation(fields: [orgId, pipeId], references: [orgId, id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,cardId)→Card(orgId,id)` — nulável (MATCH SIMPLE não checa com NULL).
  card         Card?                @relation(fields: [orgId, cardId], references: [orgId, id], onDelete: Cascade)
  history      SolicitacaoHistory[]

  /// Alvo da FK COMPOSTA tenant-safe de `SolicitacaoHistory`.
  @@unique([orgId, id])
  /// Listagem operacional: Solicitações de um Pipe, por estado.
  @@index([orgId, pipeId, lifecycleState])
  /// Consulta por Responsável (reatribuição E8; painéis futuros).
  @@index([orgId, responsavelMembershipId])
  /// Consulta por Card associado.
  @@index([orgId, cardId])
  @@map("Solicitacao")
}

/// SolicitacaoHistory — trilha de eventos da Solicitação (Story 5.2). Espelho estrutural de `TaskHistory`,
/// domínio DISTINTO. **Append-only e IMUTÁVEL**: GRANT só SELECT+INSERT (sem UPDATE/DELETE). Cada mutação da
/// Solicitação escreve seu evento na MESMA transação (não há mudança sem evento — AD-13).
model SolicitacaoHistory {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  solicitacaoId String   @db.Uuid
  /// Vocabulário do evento: CREATED, EDITED, RESPONSAVEL_ASSIGNED/CHANGED/REMOVED, RESOLVED, REOPENED,
  /// ARCHIVED, RESTORED, CARD_LINKED, CARD_UNLINKED, FILE_ATTACHED, FILE_REMOVED. String — estável.
  type          String
  /// Resumo legível do evento (sem PII desnecessária).
  summary       String
  /// Ator que originou o evento (quando disponível).
  actorId       String?  @db.Uuid
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,solicitacaoId)→Solicitacao(orgId,id)`. Cascade: fato derivado.
  solicitacao  Solicitacao  @relation(fields: [orgId, solicitacaoId], references: [orgId, id], onDelete: Cascade)

  @@index([orgId, solicitacaoId, createdAt])
  @@map("SolicitacaoHistory")
}

/// Estado de DISPONIBILIDADE do destinatário (Story 5.3). `SUPPRESSED` é atingido pela revalidação de
/// acesso na LEITURA (5.4 — perda de acesso oculta a Notificação); a 5.3 entrega o campo + o GRANT de UPDATE
/// que a torna possível, não a transição.
enum NotificationAvailability {
  AVAILABLE
  SUPPRESSED
}

/// Conteúdo/evento canônico de uma Notificação (Story 5.3) — a FONTE ÚNICA (INV-NOTIF-01). **APPEND-ONLY,
/// IMUTÁVEL** (GRANT só SELECT/INSERT, como `MembershipEvent`/`CardHistory`/`FormVersion`): o conteúdo é
/// congelado no 1º write e nunca reescrito. O estado de leitura por destinatário vive em
/// `NotificationRecipient` (mutável) — a separação é o ponto da Story (§1570). org-scoped: RLS ENABLE+FORCE +
/// WITH CHECK (INSERT/UPDATE), em `MODELOS_AUDITADOS`.
model Notification {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  /// Tipo da Notificação. `String` — o catálogo canônico de tipos é a 5.6 (como `CardHistory.type`).
  type          String
  /// Versão do tipo — para renderização/evolução compatível (§1567).
  typeVersion   Int      @default(1)
  /// Evento de origem (idempotência). REFERÊNCIA-POR-ID sem FK — produtores 5.6/5.7/E8 têm origens distintas;
  /// um FK acoplaria o modelo e criaria cascata. Obrigatório (sem ele não há idempotência — fail-closed).
  sourceEventId String   @db.Uuid
  /// Referência INTERNA ao recurso (ids, NUNCA payload) — permite à leitura (5.4) revalidar a autz atual e
  /// ocultar/sanitizar/não-contar o inacessível. Referência-por-id sem FK (a Notificação NUNCA concede acesso).
  resourceType  String
  resourceId    String?  @db.Uuid
  /// Ator/iniciador (referência-por-id de auditoria, como `MembershipEvent.actorId`). Nulo por defesa/sistema.
  actorId       String?  @db.Uuid
  /// Data/hora do evento (instante absoluto).
  occurredAt    DateTime @default(now()) @db.Timestamptz(3)
  /// Parâmetros mínimos SANITIZADOS para renderização (allowlist estrutural fail-closed; HTML-escapado). NUNCA
  /// payload bruto/token/segredo/URL/PII desnecessária.
  params        Json     @default("{}")
  createdAt     DateTime @default(now())

  organization Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recipients   NotificationRecipient[]

  /// Idempotência do CONTEÚDO: 1 Notificação por (Org, Evento de origem, tipo). Reprocessar não duplica nem
  /// sobrescreve o congelado.
  @@unique([orgId, sourceEventId, type])
  /// Alvo da FK COMPOSTA tenant-safe de `NotificationRecipient`.
  @@unique([orgId, id])
  @@map("Notification")
}

/// Estado de leitura por DESTINATÁRIO (Story 5.3) — um registro por pessoa. **MUTÁVEL, auditável**: GRANT
/// SELECT/INSERT + UPDATE COLUMN-SCOPED (só `readAt`/`availabilityState`/`updatedAt`); **sem DELETE** (não se
/// apaga dado do titular — LGPD; suprimir = `availabilityState`). O estado lido/não-lido é DERIVADO de
/// `readAt` (nulo/preenchido), nunca um booleano persistido. org-scoped: RLS ENABLE+FORCE + WITH CHECK.
model NotificationRecipient {
  id                    String                   @id @default(uuid()) @db.Uuid
  orgId                 String                   @db.Uuid
  notificationId        String                   @db.Uuid
  /// Destinatário = a pessoa NA Org (a Membership). Referência-por-id SEM FK (como
  /// `Solicitacao.responsavelMembershipId`/`CardResponsavel`: FK composta a Membership é inviável — `orgId`
  /// compartilhado NOT NULL impede SetNull; Cascade quebraria LGPD). É a identidade que colapsa múltiplos papéis.
  recipientMembershipId String                   @db.Uuid
  /// `Account` global do destinatário (referência-por-id SEM FK — `Account` é global sem RLS; um FK Cascade
  /// apagaria destinatários de TODAS as Orgs).
  recipientUserId       String                   @db.Uuid
  /// Nulo = NÃO-LIDO; preenchido = LIDO. O booleano `lido` é DERIVADO (`estaLida`), nunca persistido.
  readAt                DateTime?                @db.Timestamptz(3)
  /// Data de entrega LÓGICA (quando o registro do destinatário foi materializado).
  deliveredAt           DateTime                 @default(now()) @db.Timestamptz(3)
  availabilityState     NotificationAvailability @default(AVAILABLE)
  /// Chave de deduplicação determinística `"{sourceEventId}|{type}|{recipientMembershipId}"` — encoda
  /// exatamente *Org + Evento de origem + tipo + destinatário* (§1569) num único índice, estável no reprocesso.
  dedupeKey             String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  /// FK COMPOSTA tenant-safe `(orgId,notificationId)→Notification(orgId,id)`. Cascade: o destinatário é dado
  /// da Notificação.
  notification Notification @relation(fields: [orgId, notificationId], references: [orgId, id], onDelete: Cascade)

  /// Idempotência do DESTINATÁRIO (o coração da Story): reprocesso E múltiplos papéis → mesma pessoa colapsam.
  @@unique([orgId, dedupeKey])
  /// Listar destinatários de uma Notificação.
  @@index([orgId, notificationId])
  /// Notificações de um destinatário (base da leitura/contagem da 5.4).
  @@index([orgId, recipientMembershipId])
  @@map("NotificationRecipient")
}
