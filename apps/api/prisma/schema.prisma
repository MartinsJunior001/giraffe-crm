/// Contador do rate limit NATIVO do Better Auth (G2): chave = `${ip}|${path}`.
///
/// Vive no BANCO, nГЈo em memГіria. O padrГЈo do Better Auth Г© `storage: 'memory'`, e memГіria
/// (a) nГЈo sobrevive a restart вЂ” o atacante zera a contagem esperando o container reciclar вЂ” e
/// (b) nГЈo Г© compartilhada entre instГўncias: com 3 rГ©plicas, o limite efetivo TRIPLICA. Um
/// limite assim nГЈo Г© uma proteГ§ГЈo, Г© um enfeite.
model RateLimit {
  /// Sem default: quem preenche Г© o `generateId` do Better Auth (ver `auth.factory.ts`). Um default
  /// aqui sГі mascararia uma eventual regressГЈo daquela configuraГ§ГЈo вЂ” e o INSERT sem `id` deve
  /// falhar alto, nГЈo ser silenciosamente remendado pelo schema.
  id          String @id
