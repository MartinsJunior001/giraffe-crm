  count       Int
  lastRequest BigInt

  @@map("RateLimit")
}

/// Contador de FALHAS por identificador (G1). Nosso, e obrigatoriamente nosso.
///
/// O rate limiter nativo do Better Auth chaveia por `${ip}|${path}` e conta SOLICITAГ‡Г•ES вЂ”
/// verificado na fonte. Ele faz o G2 e Г© incapaz de fazer o G1. Confiar nele para as duas
/// coisas deixaria a forГ§a bruta dirigida a UMA conta sem proteГ§ГЈo alguma: um atacante com uma
/// lista de e-mails, testando uma senha comum em cada, nunca estoura um limite por conta.
///
/// `key` Г© o HMAC do identificador NORMALIZADO, com prefixo de finalidade вЂ” nunca o e-mail em
/// claro. E-mail Г© PII: guardГЎ-lo aqui criaria um segundo cadastro de e-mails, fora do controle
/// de `Account`, e um dump desta tabela viraria uma lista de usuГЎrios.
model LoginFailure {
  /// HMAC-SHA256(`login:` + e-mail normalizado), hex.
  key         String   @id
  /// VersГЈo do segredo que gerou a chave (D6 вЂ” rotaГ§ГЈo sem zerar contadores em silГЄncio).
  keyVersion  Int
  count       Int
  windowStart DateTime

  @@map("LoginFailure")
}

