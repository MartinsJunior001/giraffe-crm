// Modelo multi-tenant — Story 1.2.
//
// O isolamento NÃO é garantido por este schema, e sim pelas policies de RLS na
// migration `..._init_tenancy_rls`. Este arquivo descreve as tabelas; o banco é
// quem nega. Ler `prisma/migrations/*/migration.sql` antes de mexer aqui.

generator client {
  provider = "prisma-client-js"
  // Saída EXPLÍCITA, fora de `node_modules`. Por padrão o Prisma escreve o client dentro do
  // pacote `@prisma/client` no store do pnpm, num caminho com hash de peer-dependency — que
  // MUDA entre uma instalação completa e uma `--prod`. Resultado: a imagem de produção subia
  // sem o client, ou só ficava correta carregando 465 MB de devDependencies junto.
  // Um diretório estável é copiável entre stages do Docker. (Também é o formato exigido
  // pelo Prisma 7.)
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Runtime → papel `giraffe_app` (sem BYPASSRLS, não proprietário).
  // Migrations → o script `db:migrate` substitui esta URL pela do `giraffe_migrator`.
  url      = env("DATABASE_URL")
}

/// Papel do vínculo com a Organização. Papel ÚNICO por Membership (AD-7).
/// Origem: NFR-4 canônico (Admin da Org / Membro / Convidado). NÃO inventar papéis.
/// Super Admin NÃO está aqui: é papel de Plataforma e não concede acesso a dados
/// de Organização (INV-ADMIN-01).
enum MembershipRole {
  ADMIN
  MEMBER
  GUEST
}

/// Estado do vínculo. `REMOVED` É a remoção lógica exigida pelo AC2 — por isso
/// NÃO existe `deletedAt` paralelo (fonte de verdade única — AD-14).
enum MembershipState {
  ACTIVE
  SUSPENDED
  REMOVED
}

/// Estado do Pipe (Story 2.1). Arquivar é MUDANÇA DE ESTADO, não exclusão — não há transição
/// para "deletado" (o runtime nem tem GRANT DELETE). `ARCHIVED` preserva todos os dados.
enum PipeState {
  ACTIVE
  ARCHIVED
}

/// Estado do Database (Story 3.1). Twin de `PipeState`, entidade DISTINTA (Database ≠ Pipe — RN-061).
/// Arquivar é MUDANÇA DE ESTADO, não exclusão (runtime sem GRANT DELETE) e coloca o Database em
/// SOMENTE-LEITURA INTEGRAL: em `ARCHIVED`, renomear é bloqueado (409) e a única escrita é `restaurar`.
enum DatabaseState {
  ACTIVE
  ARCHIVED
}

/// Papel POR Database (Story 3.2, decisão de Produto D3.4). Distinto de `PipeRole` (RN-061 — Database ≠ Pipe):
/// ADMIN (Admin do Database) configura/administra a estrutura e concede MEMBER/VIEWER; NÃO controla o ciclo de
/// vida do Database (Admin da Org, Story 3.1) nem Memberships da Org; MEMBER (Membro do Database) cria/edita
/// Registros (poder DIFERENCIAL = contrato futuro 3.4 — role dormente); VIEWER (Somente leitura) consulta.
enum DatabaseRole {
  ADMIN
  MEMBER
  VIEWER
}

/// Estado da concessão de papel por Database (Story 3.2). Revogar é MUDANÇA DE ESTADO, não exclusão —
/// preserva a trilha (simétrico a `PipeGrantState`); o runtime não tem GRANT de DELETE.
enum DatabaseGrantState {
  ACTIVE
  REVOKED
}

/// Papel POR Pipe (Story 2.2, decisão de Produto D1.4). Conjunto enxuto e fechado:
/// ADMIN administra a CONFIG do Pipe (não o ciclo de vida — isso é do Admin da Org, Story 2.1);
/// MEMBER edita os recursos acessíveis do Pipe; VIEWER (Somente leitura) consulta sem editar/mover.
enum PipeRole {
  ADMIN
  MEMBER
  VIEWER
}

/// Estado da concessão de papel por Pipe (Story 2.2). Revogar é MUDANÇA DE ESTADO, não exclusão —
/// preserva a trilha (simétrico a `MembershipState`); o runtime não tem GRANT DELETE.
enum PipeGrantState {
  ACTIVE
  REVOKED
}

/// Estado da Fase (Story 2.3). Arquivar é MUDANÇA DE ESTADO, não exclusão (simétrico a `PipeState`);
/// o runtime não tem GRANT DELETE. `ARCHIVED` preserva os dados e a posição na ordem é recalculada ao
/// restaurar (volta ao final da ordem ativa).
enum PhaseState {
  ACTIVE
  ARCHIVED
}

/// Catálogo CANÔNICO de tipos de Campo (Story 2.4, decisão de Produto D3.1). Conjunto FECHADO de 12 tipos,
/// o MESMO para toda Organização — é de PLATAFORMA (enum de código, como `PipeRole`), NÃO um catálogo
/// configurável por Organização. O que é dado org-scoped são as instâncias de `Field`, não o catálogo.
/// `FILE` existe no catálogo mas fica gated (AD-27/AD-28, fail-closed) até a capacidade de arquivos do E3.
enum FieldType {
  TEXT_SHORT
  TEXT_LONG
  NUMBER
  SELECT_SINGLE
  SELECT_MULTI
  BOOLEAN
  DATE
  DATETIME
  EMAIL
  PHONE
  URL
  FILE
}

/// Contexto de um Formulário (Story 2.4). Os três Formulários são INDEPENDENTES (INV-FORM-01): cada contexto
/// é uma LINHA distinta de `Form`, e alterar um não altera outro. `DATABASE` existe como CONTRATO (o E3
/// reutiliza o mesmo builder), mas NÃO é funcional nesta Story — não há owner de Database nem rota que crie
/// uma linha `context = DATABASE` (AD-11: nada materializado só para o futuro).
enum FormContext {
  PIPE_INITIAL
  PHASE
  DATABASE
}

/// Estado do Campo (Story 2.4). O ATRIBUTO existe desde a 2.4; a OPERAÇÃO de arquivar/restaurar com travas é
/// da 2.5 (simétrico a `PhaseState`). O runtime não tem GRANT DELETE — "sem exclusão" é fronteira de banco.
enum FieldState {
  ACTIVE
  ARCHIVED
}

/// Modo da submissão pública de um Formulário inicial (Story 2.8, PRD D3.3). `TRIAGE` (padrão): a submissão NÃO
/// cria Card até ser aprovada na triagem. `DIRECT`: a submissão válida cria 1 Card imediatamente.
enum PublicFormMode {
  TRIAGE
  DIRECT
}

/// Origem do Card (Story 2.8). `INTERNAL`: submissão interna (2.7). `PUBLIC`: submissão pública aprovada/direta.
/// "Origem registrada" (PRD D3.3): atributo do Card, consultável — não metadado solto de evento.
enum CardOrigin {
  INTERNAL
  PUBLIC
}

/// Ciclo da Submissão pública (Story 2.8, PRD D3.3) — DISTINTO do estado do Card (`Fase ≠ Status do Card`).
/// `PENDING` (aguardando triagem) → `CONVERTED` (aprovada: 1 Card criado na MESMA transação) ou `REJECTED`
/// (não cria Card; submissão preservada — LGPD). Aprovação e conversão são atômicas na 2.8, então não há estado
/// `APPROVED` persistido separado (AD-11: sem materializar estado sem consumidor). `CONVERTED` é terminal:
/// uma submissão convertida não reconverte (idempotência — epics.md §884).
enum SubmissaoPublicaState {
  PENDING
  CONVERTED
  REJECTED
}

/// Identidade GLOBAL da Plataforma (AD-7/AD-10).
/// Sem `orgId` e SEM RLS: a conta não pertence a nenhuma Organização — é o
/// Membership que a vincula. `email` é PII (LGPD): minimizado, nunca em log.
///
/// Story 1.4: esta tabela É o `user` do Better Auth (`user: { modelName: 'Account' }`).
/// Não existe uma segunda tabela de pessoas, e isso é deliberado. Deixar o Better Auth
/// criar o `user` dele daria DUAS identidades — `user`, dona da sessão, e `Account`,
/// dona da Membership — a serem sincronizadas para sempre. Toda divergência entre elas
/// (um `user` sem `Account`, um e-mail atualizado num lado só) é um bug de identidade,
/// que é a classe de bug que termina em "o usuário X viu os dados do usuário Y".
/// Uma identidade, uma tabela.
model Account {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String
  /// Exigidos pelo Better Auth. `emailVerified` não governa acesso nesta Story —
  /// quem governa é a Membership ativa (1.3). Verificação de e-mail é da Story 1.10.
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships Membership[]
  sessions    AuthSession[]
  credentials AuthCredential[]

  @@map("Account")
}

/// Sessão emitida pelo Better Auth (o `session` dele).
///
/// GLOBAL, como `Account` e pela mesma razão (AD-10): uma sessão é da PESSOA, não de uma
/// Organização. Sem `orgId`, sem RLS.
///
/// `activeOrganizationId` é um PEDIDO persistido, jamais autoridade. Quem decide se ele
/// vale é o `OrgContextResolver` da Story 1.3, conferindo contra a Membership ativa. Tratá-lo
/// como autoridade — "a sessão diz que ele é da Org X, logo é" — reabriria exatamente o buraco
/// que a 1.3 fechou: bastaria uma Membership ser suspensa para a sessão continuar valendo.
model AuthSession {
  id                   String   @id
  token                String   @unique
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String?  @db.Uuid
  userId               String   @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthSession")
}

/// O `account` do Better Auth, renomeado — e o nome importa.
///
/// Ela NÃO guarda "contas": guarda hash de senha e vínculos com provedores externos. Manter
/// o nome original num sistema onde `Account` significa "a identidade da pessoa" seria um
/// convite permanente ao erro, além de colidir com o nosso model (nome de model em Prisma é
/// único).
model AuthCredential {
  id                    String    @id
  /// Identificador da conta NO PROVEDOR (não é o nosso `Account.id`).
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  /// Hash da senha (credential provider). NUNCA em log, erro, métrica ou resposta.
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthCredential")
}

/// Tokens de verificação do Better Auth (`verification`).
model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("AuthVerification")
}

/// Contador do rate limit NATIVO do Better Auth (G2): chave = `${ip}|${path}`.
///
/// Vive no BANCO, não em memória. O padrão do Better Auth é `storage: 'memory'`, e memória
/// (a) não sobrevive a restart — o atacante zera a contagem esperando o container reciclar — e
/// (b) não é compartilhada entre instâncias: com 3 réplicas, o limite efetivo TRIPLICA. Um
/// limite assim não é uma proteção, é um enfeite.
model RateLimit {
  /// Sem default: quem preenche é o `generateId` do Better Auth (ver `auth.factory.ts`). Um default
  /// aqui só mascararia uma eventual regressão daquela configuração — e o INSERT sem `id` deve
  /// falhar alto, não ser silenciosamente remendado pelo schema.
  id          String @id
  key         String @unique
  count       Int
  lastRequest BigInt

  @@map("RateLimit")
}

/// Contador de FALHAS por identificador (G1). Nosso, e obrigatoriamente nosso.
///
/// O rate limiter nativo do Better Auth chaveia por `${ip}|${path}` e conta SOLICITAÇÕES —
/// verificado na fonte. Ele faz o G2 e é incapaz de fazer o G1. Confiar nele para as duas
/// coisas deixaria a força bruta dirigida a UMA conta sem proteção alguma: um atacante com uma
/// lista de e-mails, testando uma senha comum em cada, nunca estoura um limite por conta.
///
/// `key` é o HMAC do identificador NORMALIZADO, com prefixo de finalidade — nunca o e-mail em
/// claro. E-mail é PII: guardá-lo aqui criaria um segundo cadastro de e-mails, fora do controle
/// de `Account`, e um dump desta tabela viraria uma lista de usuários.
model LoginFailure {
  /// HMAC-SHA256(`login:` + e-mail normalizado), hex.
  key         String   @id
  /// Versão do segredo que gerou a chave (D6 — rotação sem zerar contadores em silêncio).
  keyVersion  Int
  count       Int
  windowStart DateTime

  @@map("LoginFailure")
}

/// Raiz do tenant. Toda linha organizacional aponta para cá.
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       Membership[]
  pipes             Pipe[]
  databases         Database[]
  databaseGrants    DatabaseGrant[]
  pipeGrants        PipeGrant[]
  phases            Phase[]
  forms             Form[]
  fields            Field[]
  formVersions      FormVersion[]
  cards             Card[]
  cardHistories     CardHistory[]
  publicSubmissions SubmissaoPublica[]
  publicFormRoutes  PublicFormRoute[]
  cardGrants        CardGrant[]
  cardResponsaveis  CardResponsavel[]
  cardPhaseEntries  CardPhaseEntry[]
  cardPhaseValues   CardPhaseValues[]
  movementEvents    MovementEvent[]
  records           Record[]
  recordHistories   RecordHistory[]

  @@map("Organization")
}

/// Pipe — processo de trabalho da Organização (Story 2.1). Dado operacional org-owned (AD-10).
///
/// Isolamento pelo BANCO (RLS na migration `..._pipes`), como `Organization`/`Membership`: ENABLE
/// **e** FORCE ROW LEVEL SECURITY, policies por `orgId = current_org_id()`. O runtime recebe
/// SELECT/INSERT/UPDATE — **sem DELETE** (o épico proíbe exclusão definitiva; arquivar é `state`).
///
/// **Sem unicidade de `name`**: o identificador estável é o `id` (AD-11). Nome único org-scoped
/// colidiria no restaurar (arquiva "X", cria novo "X", restaura o antigo). RN-024 (catálogo
/// consistente) é sobre exibição por id, não unicidade de rótulo.
model Pipe {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @db.Uuid
  name       String
  state      PipeState @default(ACTIVE)
  /// Atributos de catálogo (Story 2.1): sem semântica de bloqueio inventada — só persistidos/alternáveis.
  locked     Boolean   @default(false)
  starred    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  /// Momento do arquivamento (null quando ativo). Arquivar preserva os dados; só muda estado.
  archivedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grants       PipeGrant[]
  phases       Phase[]
  forms        Form[]
  cards        Card[]
  movementEvents MovementEvent[]

  // Todo acesso organizacional começa por `orgId`; o catálogo filtra por estado.
  @@index([orgId, state])
  @@map("Pipe")
}

/// Database — base de dados estruturada, org-owned (Story 3.1). Twin ESTRUTURAL de `Pipe`, entidade
/// DISTINTA (Database ≠ Pipe — RN-061): catálogo/subject/módulo próprios, nunca reusa os de `Pipe`.
///
/// Isolamento pelo BANCO (RLS na migration `..._databases`): ENABLE **e** FORCE ROW LEVEL SECURITY,
/// policies por `orgId = current_org_id()` com `WITH CHECK` no INSERT e no UPDATE. Runtime recebe
/// SELECT/INSERT/UPDATE — **sem DELETE**: arquivar é `state = ARCHIVED`, não exclusão.
///
/// **Sem unicidade de `name`**: o identificador estável é o `id` (AD-11); nome único org-scoped
/// colidiria no restaurar. **Sem `locked`/`starred`** (não estão na epics da 3.1 — não inventar).
/// Arquivar coloca em SOMENTE-LEITURA INTEGRAL: em `ARCHIVED` o único write-side é `restaurar`
/// (renomear → 409). As escritas sobre dados dependentes (Formulário/Registro/Campo/arquivo/vínculo)
/// são contrato futuro (3.3/3.4/3.7/3.8/3.9), enforçadas pelo owner checando `state === ACTIVE`.
model Database {
  id         String        @id @default(uuid()) @db.Uuid
  orgId      String        @db.Uuid
  name       String
  state      DatabaseState @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  /// Momento do arquivamento (null quando ativo). Arquivar preserva os dados; só muda estado.
  archivedAt DateTime?

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grants       DatabaseGrant[]
  forms        Form[]
  records      Record[]

  // Todo acesso organizacional começa por `orgId`; o catálogo filtra por estado.
  @@index([orgId, state])
  @@map("Database")
}

/// Phase — Fase do fluxo DENTRO de um Pipe (Story 2.3). Dado operacional org-owned (AD-10).
///
/// `Fase ≠ Status do Card` (invariante conceitual): a Fase é a etapa do processo; o Card é que se move
/// entre Fases (Cards = 2.7+). RN-030: cada Fase pertence a EXATAMENTE UM Pipe e NÃO migra — não há rota
/// que altere `pipeId`.
///
/// Isolamento pelo BANCO (RLS na migration `..._phases`): ENABLE **e** FORCE ROW LEVEL SECURITY, policies
/// por `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**: arquivar é
/// `state = ARCHIVED`, não exclusão.
///
/// **Ordenação intra-Pipe por chave fracionária** (`position`, `numeric`): mover uma Fase é UM único
/// UPDATE (novo `position` = ponto médio dos vizinhos), porque `withTenantContext` define o contexto por
/// operação e não suporta transação multi-statement — reescrever N posições em lote não seria atômico.
/// Ordem determinística por `ORDER BY position, id`. **Sem unicidade** de `position` (empate raro
/// desempatado pelo `id`; uma constraint única brigaria com operações concorrentes).
model Phase {
  id         String     @id @default(uuid()) @db.Uuid
  orgId      String     @db.Uuid
  pipeId     String     @db.Uuid
  name       String
  state      PhaseState @default(ACTIVE)
  /// Chave de ordenação fracionária (ver nota do model). `numeric` de alta escala.
  position   Decimal    @db.Decimal(38, 18)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  /// Momento do arquivamento (null quando ativa). Arquivar preserva os dados; só muda estado.
  archivedAt DateTime?

  // ── Config de marcos por Fase (Story 2.12) — durações RELATIVAS à entrada, em MINUTOS (decisão de Arquitetura:
  // Int, pois o Prisma 6.19.3 não tem `interval` nativo). Invariante `esperado ≤ vencimento ≤ expiração` validado
  // no núcleo puro E por CHECK na migration (defesa em profundidade, tolerante a NULL). Ausente = marco não configurado.
  /// Prazo esperado, em minutos após a entrada na Fase (null = não configurado).
  expectedDurationMin   Int?
  /// Vencimento, em minutos após a entrada (null = não configurado). `expectedDurationMin ≤ dueDurationMin`.
  dueDurationMin        Int?
  /// Expiração, em minutos após a entrada (null = não configurado). `dueDurationMin ≤ expirationDurationMin`.
  expirationDurationMin Int?
  // Override ABSOLUTO por Campo `DATE`/`DATETIME` do Card (Story 2.12, D-OA3): a config designa, por marco, um
  // `Field.id` do Formulário inicial do Pipe. Na avaliação (2.13), valor não-nulo do Card nesse Campo prevalece
  // sobre a duração. Não é FK (Fields nunca são deletados; validação de tipo/pertencimento vive no serviço).
  /// Campo de override do prazo esperado (null = sem override; usa a duração).
  expectedFieldId       String? @db.Uuid
  /// Campo de override do vencimento (null = sem override).
  dueFieldId            String? @db.Uuid
  /// Campo de override da expiração (null = sem override).
  expirationFieldId     String? @db.Uuid

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe         Pipe             @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  forms        Form[]
  cards        Card[]
  phaseEntries CardPhaseEntry[]
  phaseValues  CardPhaseValues[]
  movementEventsAsSource MovementEvent[] @relation("MovementEventSource")
  movementEventsAsTarget MovementEvent[] @relation("MovementEventTarget")

  // Acesso começa por Org; a listagem por Pipe filtra estado e ordena por position.
  @@index([orgId, pipeId, state, position])
  @@map("Phase")
}

/// PipeGrant — concessão explícita de papel POR Pipe (Story 2.2, decisão D1.4). Dado operacional
/// org-owned (AD-10). É o que abre o acesso de MEMBER/GUEST a um Pipe: sem concessão ACTIVE, não há
/// acesso (deny-by-default). O Admin da Organização acessa todos os Pipes SEM concessão (Story 2.1).
///
/// Liga-se a `Membership` (não a `Account`): o papel por Pipe vive DENTRO de uma Organização, e a
/// Membership é o vínculo Account×Org que já carrega `orgId` e estado (AD-7). Ligar à Account global
/// reabriria a porta de uma concessão "sem Org".
///
/// Isolamento pelo BANCO (RLS na migration `..._pipe_grants`): ENABLE **e** FORCE ROW LEVEL SECURITY,
/// policies por `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**:
/// revogar é `state = REVOKED`, não exclusão (preserva a trilha).
///
/// **No máximo UM papel efetivo por Pipe por pessoa**: índice único PARCIAL `(pipeId, membershipId)
/// WHERE state = 'ACTIVE'`, criado por raw SQL na migration (o Prisma 6.19.3 não expressa índice
/// parcial no schema — é v7.4+). Uma concessão revogada não colide com uma re-concessão.
model PipeGrant {
  id                      String         @id @default(uuid()) @db.Uuid
  orgId                   String         @db.Uuid
  pipeId                  String         @db.Uuid
  membershipId            String         @db.Uuid
  role                    PipeRole
  state                   PipeGrantState @default(ACTIVE)
  /// Capacidade EXPLÍCITA "Revisar submissões públicas" (Story 2.8, PRD D3.3), negada por padrão. É uma
  /// CAPACIDADE, não um papel: o Admin da Org a possui implicitamente (sem concessão); um não-Admin só revisa
  /// com uma concessão ACTIVE que a tenha `true`. Não cria papel novo nem toca o CASL/guard (C3 congelado) — a
  /// guarda fina vive em `pipe-authz` (`exigirRevisarSubmissoesPublicas`).
  reviewPublicSubmissions Boolean        @default(false)
  /// Modificador "restrito ao próprio" do Membro do Pipe (Story 2.10, PRD D1.5), deny-by-default. NÃO é papel novo
  /// (análogo a `reviewPublicSubmissions`): quando `true`, o Membro só opera Cards onde é Responsável atual OU tem
  /// concessão direta ativa (`creator`/histórico anterior não concedem acesso). Guarda fina em `pipe-authz`.
  restritoAoProprio       Boolean        @default(false)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  /// Momento da revogação (null quando ativa). Revogar preserva a linha; só muda estado.
  revokedAt               DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe         Pipe         @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Acesso começa por Org; consultas por Pipe (quem acessa) e por pessoa (quais Pipes).
  @@index([orgId, pipeId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "um papel ativo por (pipe, pessoa)" é um índice PARCIAL, criado na migration
  // (WHERE state='ACTIVE') — não expressável aqui no Prisma 6.19.3.
  @@map("PipeGrant")
}

/// DatabaseGrant — concessão explícita de papel POR Database (Story 3.2, decisão D3.4). Dado operacional
/// org-owned (AD-10). É o que abre o acesso de MEMBER/GUEST a um Database: sem concessão ACTIVE, não há
/// acesso (deny-by-default). O Admin da Organização acessa todos os Databases SEM concessão (Story 3.1).
/// É o **twin estrutural de `PipeGrant`** (2.2), entidade **DISTINTA** (Database ≠ Pipe — RN-061): tabela,
/// enums e subject próprios; nunca reutilizar `PipeGrant`/`PipeRole`.
///
/// Liga-se a `Membership` (não a `Account`): o papel por Database vive DENTRO de uma Organização (AD-7).
///
/// **Autoridade hierárquica de concessão (ajuste 2, D3.4 §969/§1086 — resolvida no serviço, não no banco):**
/// Admin da Org concede/altera/revoga qualquer papel; Admin do Database (grant `role=ADMIN` ACTIVE) concede/
/// revoga SÓ `MEMBER`/`VIEWER`; **somente Admin da Org concede/remove `ADMIN` do Database**. Teto da Org
/// (AD-9): um Convidado (`Membership.role=GUEST`) só recebe `VIEWER`.
///
/// Isolamento pelo BANCO (RLS na migration `..._database_grants`): ENABLE **e** FORCE ROW LEVEL SECURITY,
/// policies por `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**: revogar é
/// `state = REVOKED`, não exclusão (preserva a trilha).
///
/// **No máximo UM papel efetivo por Database por pessoa**: índice único PARCIAL `(databaseId, membershipId)
/// WHERE state = 'ACTIVE'`, criado por raw SQL na migration (o Prisma 6.19.3 não expressa índice parcial).
model DatabaseGrant {
  id           String             @id @default(uuid()) @db.Uuid
  orgId        String             @db.Uuid
  databaseId   String             @db.Uuid
  membershipId String             @db.Uuid
  role         DatabaseRole
  state        DatabaseGrantState @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  /// Momento da revogação (null quando ativa). Revogar preserva a linha; só muda estado.
  revokedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  database     Database     @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Acesso começa por Org; consultas por Database (quem acessa) e por pessoa (quais Databases).
  @@index([orgId, databaseId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "um papel ativo por (database, pessoa)" é um índice PARCIAL, criado na migration
  // (WHERE state='ACTIVE') — não expressável aqui no Prisma 6.19.3.
  @@map("DatabaseGrant")
}

/// Vínculo Account × Organization (AD-7, Forma B). É a tabela organizacional
/// desta Story — e a fixture dos testes de isolamento.
model Membership {
  id        String          @id @default(uuid()) @db.Uuid
  accountId String          @db.Uuid
  orgId     String          @db.Uuid
  role      MembershipRole
  state     MembershipState @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  account          Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipeGrants       PipeGrant[]
  databaseGrants   DatabaseGrant[]
  cardGrants       CardGrant[]
  cardResponsaveis CardResponsavel[]

  // Uma conta tem no máximo UM vínculo por Organização (papel único — AD-7).
  @@unique([accountId, orgId])
  // Todo acesso organizacional começa por `orgId` → primeira coluna do índice.
  @@index([orgId, state])
  // Descoberta das próprias Organizações no login (Story 1.4), antes de haver contexto.
  @@index([accountId])
  @@map("Membership")
}

/// Form — Formulário de UM contexto (Story 2.4). Dado operacional org-owned (AD-10). Os três Formulários
/// (inicial do Pipe, de Fase, de Database) são INDEPENDENTES (INV-FORM-01): cada contexto é uma LINHA
/// distinta, e a não-contaminação entre eles cai como consequência de linhas separadas + RLS.
///
/// **Tabela única com owner por contexto** (FKs nuláveis): `pipeId` para `PIPE_INITIAL`, `phaseId` para
/// `PHASE`. O contexto `DATABASE` existe no enum como CONTRATO do E3, mas SEM coluna de owner e SEM rota
/// nesta Story (AD-11). A coerência contexto↔owner e a unicidade "um Form por owner+contexto" são impostas
/// pelo BANCO (CHECK + índices únicos PARCIAIS na migration `..._forms` — não expressáveis no Prisma 6.19.3).
///
/// Isolamento pelo banco (RLS na migration): ENABLE **e** FORCE ROW LEVEL SECURITY, policies por
/// `orgId = current_org_id()`. Runtime recebe SELECT/INSERT/UPDATE — **sem DELETE**.
model Form {
  id               String         @id @default(uuid()) @db.Uuid
  orgId            String         @db.Uuid
  context          FormContext
  /// Owner do contexto `PIPE_INITIAL` (null nos demais). CHECK na migration garante a coerência.
  pipeId           String?        @db.Uuid
  /// Owner do contexto `PHASE` (null nos demais).
  phaseId          String?        @db.Uuid
  /// Owner do contexto `DATABASE` (null nos demais). Story 3.3. CHECK na migration garante a coerência.
  databaseId       String?        @db.Uuid
  /// Número da `FormVersion` publicada corrente (null = rascunho/despublicado). Story 2.6. É NÚMERO, não FK,
  /// de propósito: evita o ciclo de FK Form↔FormVersion e não há risco de ponteiro pendente (versões nunca
  /// são deletadas e o ponteiro só é gravado para uma versão recém-criada na MESMA transação de publicação).
  publishedVersion Int?
  /// Opt-in de acesso PÚBLICO (Story 2.8, PRD D3.2). Só faz sentido em `PIPE_INITIAL` — CHECK na migration impõe
  /// (Fase/Database nunca são públicos). Habilitar cria também uma `PublicFormRoute` (URL opaca); revogar/
  /// despublicar bloqueia novas submissões.
  publicEnabled    Boolean        @default(false)
  /// Modo da submissão pública (triagem padrão ou criação direta). Só relevante com `publicEnabled`.
  publicMode       PublicFormMode @default(TRIAGE)
  /// MODO do Formulário de Fase (Story 2.15, D1) — dois booleanos INDEPENDENTES: um Formulário de Fase pode ser
  /// requisito de ENTRADA (valores exigidos antes de mover para a Fase) E/OU de SAÍDA (validados antes de sair).
  /// Ambos false = informativo/opcional. Só fazem sentido em `context='PHASE'` (config é "config do Pipe").
  requisitoEntrada Boolean        @default(false)
  requisitoSaida   Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe              Pipe?              @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  phase             Phase?             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  database          Database?          @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  fields            Field[]
  versions          FormVersion[]
  cards             Card[]
  publicSubmissions SubmissaoPublica[]
  publicRoutes      PublicFormRoute[]
  records           Record[]

  // Acesso começa por Org; a resolução por owner busca por (orgId, pipeId|phaseId|databaseId, context).
  @@index([orgId, pipeId])
  @@index([orgId, phaseId])
  @@index([orgId, databaseId])
  @@map("Form")
}

/// FormVersion — SNAPSHOT IMUTÁVEL da definição publicada de um Formulário (Story 2.6, AD-12/PRD D3.2).
///
/// Publicar congela o rascunho VALIDADO num `snapshot` JSON integral (Campos ATIVOS com id estável, tipo, label,
/// ajuda e `typeConfig`), na ordem do array — numerado monotonicamente por Formulário
/// (`@@unique([orgId, formId, version])`). O snapshot captura o que a definição realmente tem: NÃO há atributo
/// de obrigatoriedade em `Field` na 2.4/2.5 e o snapshot não o inventa (Constitution II). Submissões futuras
/// (2.7+) referenciarão `formVersionId`. Editar o rascunho depois NÃO altera versões já publicadas — imutáveis.
///
/// **Imutabilidade é do BANCO, não do código:** o runtime (`giraffe_app`) recebe **só SELECT+INSERT** em
/// `FormVersion` — sem UPDATE, sem DELETE (ver GRANT na migration). Uma rota que tentasse alterar uma versão
/// bateria em `permission denied`. Isolamento por RLS ENABLE+FORCE, policies por `current_org_id()`.
model FormVersion {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @db.Uuid
  formId      String   @db.Uuid
  /// Número monotônico por Formulário (1, 2, 3...). Unicidade imposta pelo banco.
  version     Int
  /// Snapshot integral e ordenado da definição publicada. Schema/limite/allowlist validados no serviço.
  snapshot    Json
  /// Hash determinístico do snapshot (revisão) — detecta divergência e identifica a versão.
  revision    String
  publishedAt DateTime @default(now())
  /// Conta que publicou (quando disponível). Não é PII sensível: é referência de ator para auditoria.
  actorId     String?  @db.Uuid
  createdAt   DateTime @default(now())

  organization      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form              Form               @relation(fields: [formId], references: [id], onDelete: Cascade)
  cards             Card[]
  publicSubmissions SubmissaoPublica[]
  phaseValues       CardPhaseValues[]
  records           Record[]

  @@unique([orgId, formId, version])
  @@index([orgId, formId])
  @@map("FormVersion")
}

/// Card — instância de trabalho criada por uma submissão do Formulário inicial (Story 2.7). Dado operacional
/// org-owned (AD-10). **Card ≠ Registro** (invariante conceitual): o Card é a unidade que percorre o Pipe; o
/// Registro (dado de Database) é do E3. **Fase ≠ Status do Card**: o Card nasce numa Fase e se move entre
/// Fases; o ciclo de vida/estado do Card (ativo/finalizado/arquivado) é da 2.11 — **não materializado aqui**.
///
/// A submissão interna **cria** um Card (nunca preenche um existente — D3.3). O Card nasce na **1ª Fase ativa**
/// do Pipe e referencia a **`FormVersion` publicada** no ato (`formVersionId`, imutável — AD-12): a definição
/// usada fica congelada, independentemente de edições futuras do rascunho. Os `valores` submetidos vivem em
/// JSONB **chaveado por `Field.id`** (e opção por `id`, nunca rótulo — AD-11/AD-12), não em tabela de valores
/// por Campo (normalização especulativa proibida por AD-11) — coerente com o snapshot JSON da 2.6.
///
/// **Idempotência**: `idempotencyKey` do cliente + `@@unique([orgId, formId, idempotencyKey])` — um retry da
/// MESMA submissão lógica colide e devolve o Card existente (nunca duplica). Isolamento pelo banco (RLS
/// ENABLE+FORCE); na 2.7 o runtime tem **só SELECT/INSERT** — sem UPDATE (nenhum consumidor de UPDATE ainda; a
/// 2.9/2.11 concede junto do consumidor e do teste) e **sem DELETE** (arquivar será `state` na 2.11).
model Card {
  id                     String              @id @default(uuid()) @db.Uuid
  orgId                  String              @db.Uuid
  pipeId                 String              @db.Uuid
  phaseId                String              @db.Uuid
  formId                 String              @db.Uuid
  formVersionId          String              @db.Uuid
  /// Chave lógica da submissão (cliente). Garante idempotência via índice único org+form.
  idempotencyKey         String
  /// Valores submetidos, chaveados por `Field.id` do snapshot (opção por `id`). Validados contra a versão.
  valores                Json                @default("{}")
  /// Origem do Card (Story 2.8): submissão interna (`INTERNAL`, 2.7) ou pública (`PUBLIC`, aprovada/direta).
  origin                 CardOrigin          @default(INTERNAL)
  /// Estado de CICLO DE VIDA (Story 2.11), eixo INDEPENDENTE da Fase (`Fase ≠ Status do Card`) e da saúde temporal
  /// (2.13). Três estados canônicos; `reaberto`/`restaurado` são TRANSIÇÕES, não estados. É a ÚNICA coluna de `Card`
  /// que o runtime pode UPDATE (GRANT column-scoped na migration da 2.11) — junto de `previousLifecycleState` e
  /// `updatedAt`; `phaseId` (movimentação, 2.14) segue **sem** GRANT de UPDATE.
  lifecycleState         CardLifecycleState  @default(ATIVO)
  /// Estado ANTERIOR ao arquivamento (ATIVO ou FINALIZADO), para restaurar de forma confiável (AC 2.11). Nulo fora
  /// de ARQUIVADO. Preenchido ao arquivar, limpo ao restaurar.
  previousLifecycleState CardLifecycleState?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  organization     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe             Pipe              @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  phase            Phase             @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  form             Form              @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion      FormVersion       @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  history          CardHistory[]
  publicSubmission SubmissaoPublica?
  grants           CardGrant[]
  responsaveis     CardResponsavel[]
  phaseEntries     CardPhaseEntry[]
  phaseValues      CardPhaseValues[]
  movementEvents   MovementEvent[]

  // Um retry da mesma submissão lógica não cria um 2º Card.
  @@unique([orgId, formId, idempotencyKey])
  // Superfície do Kanban (2.9): Cards de um Pipe, por Fase.
  @@index([orgId, pipeId, phaseId])
  @@map("Card")
}

/// CardHistory — trilha de eventos do Card (Story 2.7 estabelece o contrato write-side, reusado por 2.10-2.16).
/// Dado operacional org-owned (AD-10). É **append-only e IMUTÁVEL**: o runtime recebe **só SELECT+INSERT**
/// (sem UPDATE/DELETE — ver GRANT na migration), como `FormVersion`. Distinta da Auditoria/Log técnico (AD-15):
/// é histórico de negócio, legível pelo usuário.
///
/// Na 2.7 há um único tipo de evento: `CREATED` (criação do Card pela submissão). O evento é escrito na MESMA
/// transação atômica do INSERT do Card (AD-13): não há Card sem evento nem evento sem Card.
model CardHistory {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  cardId    String   @db.Uuid
  /// Vocabulário do evento (2.7: apenas `CREATED`). String — a taxonomia completa é das Stories 2.10+.
  type      String
  /// Resumo legível do evento (sem PII desnecessária).
  summary   String
  /// Ator que originou o evento (quando disponível).
  actorId   String?  @db.Uuid
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([orgId, cardId, createdAt])
  @@map("CardHistory")
}

/// Estado de CICLO DE VIDA do Card (Story 2.11). Três estados canônicos e persistentes; `reaberto`/`restaurado`
/// NÃO são estados — são transições que devolvem o Card a ATIVO/estado-anterior. Eixo independente da Fase e da
/// saúde temporal (2.13).
enum CardLifecycleState {
  ATIVO
  FINALIZADO
  ARQUIVADO
}

/// Estado de uma concessão direta de acesso a um Card (Story 2.10). Revogar preserva a linha (sem DELETE).
enum CardGrantState {
  ACTIVE
  REVOKED
}

/// Estado da atribuição de Responsável de um Card (Story 2.10). Remover preserva a linha (sem DELETE).
enum CardResponsavelState {
  ACTIVE
  REMOVED
}

/// CardGrant — concessão DIRETA de acesso a UM Card específico (Story 2.10, PRD D1.5). Dado operacional org-owned.
/// Não é papel: dá acesso SÓ àquele Card, nunca lista/config/métricas do Pipe nem outros Cards. Observador = só
/// `podeLer`; concessão operacional direta = `podeOperar` (+ `podeMover` opt-in — a OPERAÇÃO de mover é a 2.14;
/// aqui só o DADO da capacidade). Deny-by-default (capacidades default falsas, exceto leitura). Isolamento pelo
/// banco (RLS ENABLE+FORCE); runtime SELECT/INSERT/UPDATE — **sem DELETE** (revogar é `state = REVOKED`).
model CardGrant {
  id           String         @id @default(uuid()) @db.Uuid
  orgId        String         @db.Uuid
  cardId       String         @db.Uuid
  membershipId String         @db.Uuid
  /// Observador (leitura). Default true — uma concessão sempre concede ao menos ler o Card.
  podeLer      Boolean        @default(true)
  /// Concessão operacional direta (agir no Card). Deny-by-default.
  podeOperar   Boolean        @default(false)
  /// Capacidade "Mover Card" (dado de autorização; a operação é 2.14). Deny-by-default; só se concedida.
  podeMover    Boolean        @default(false)
  state        CardGrantState @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  revokedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  // Consultas por Card (quem acessa) e por pessoa (quais Cards).
  @@index([orgId, cardId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "uma concessão ativa por (card, pessoa)" é índice PARCIAL na migration (WHERE state='ACTIVE').
  @@map("CardGrant")
}

/// CardResponsavel — atribuição de RESPONSÁVEL de um Card (Story 2.10, PRD D5.1). Dado operacional org-owned. É
/// ATRIBUIÇÃO operacional, **não papel**: não amplia acesso (o alvo já precisa de acesso operacional). A chave é
/// `membershipId` (elegibilidade é por Membership — PRD §1065), não accountId. Mantém `Card` **append-only** (a
/// 2.10 NÃO abre GRANT de UPDATE em `Card`; o 1º UPDATE de Card segue reservado à movimentação — 2.14). No máximo
/// UMA atribuição ACTIVE por Card (índice parcial na migration). `creator` NÃO vive aqui — é o `actorId` do evento
/// `CREATED` (2.7). Isolamento pelo banco (RLS); runtime SELECT/INSERT/UPDATE — **sem DELETE** (remover é `state`).
model CardResponsavel {
  id           String               @id @default(uuid()) @db.Uuid
  orgId        String               @db.Uuid
  cardId       String               @db.Uuid
  membershipId String               @db.Uuid
  state        CardResponsavelState @default(ACTIVE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  removedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  membership   Membership   @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([orgId, cardId])
  @@index([orgId, membershipId])
  // Nota: a unicidade "um Responsável ativo por Card" é índice PARCIAL na migration (WHERE state='ACTIVE').
  @@map("CardResponsavel")
}

/// Origem de uma entrada efetiva do Card numa Fase (Story 2.12). `SUBMISSION` = criação do Card (2.7 interna / 2.8
/// pública); `MOVE` = movimentação entre Fases (2.14, futura — o helper de entrada já aceita a origem, sem chamador
/// de movimentação nesta Story).
enum CardPhaseEntryOrigin {
  SUBMISSION
  MOVE
}

/// CardPhaseEntry — referência temporal de uma ENTRADA efetiva do Card numa Fase (Story 2.12, FR-10; D2.7). Dado
/// operacional org-owned (AD-10). É a **base absoluta** dos marcos: cada entrada preserva o **instante** e a
/// **origem**; cada reentrada (2.14) cria uma NOVA linha, preservando o histórico. "Entrada atual" = a linha mais
/// recente por `(cardId, enteredAt desc)` — sem "linha ativa" única, logo sem índice parcial de unicidade.
///
/// **Append-only e IMUTÁVEL** (como `CardHistory`/`FormVersion`): o runtime recebe **só SELECT + INSERT** (sem
/// UPDATE, sem DELETE — ver GRANT na migration). Não toca `Card` (a 2.12 não abre GRANT de UPDATE em `Card`;
/// `phaseId`/movimentação seguem sem UPDATE até 2.14).
///
/// **`configSnapshot`** congela as durações/override vigentes da Fase no instante da entrada (decisão D-OA1=A:
/// mudar a config afeta só entradas FUTURAS; "sem recálculo retroativo silencioso" cai por construção — padrão da
/// `FormVersion` da 2.6). JSON: `{ expectedDurationMin, dueDurationMin, expirationDurationMin, expectedFieldId,
/// dueFieldId, expirationFieldId }` (todos nuláveis). A **derivação** dos marcos a partir da base é 2.13.
///
/// **`enteredAt` é `@db.Timestamptz`** (instante absoluto — decisão de Arquitetura; diverge do `TIMESTAMP(3)` do
/// restante do schema por escolha explícita, DIV-1). Isolamento pelo banco (RLS ENABLE+FORCE, WITH CHECK).
model CardPhaseEntry {
  id             String               @id @default(uuid()) @db.Uuid
  orgId          String               @db.Uuid
  cardId         String               @db.Uuid
  phaseId        String               @db.Uuid
  /// Instante ABSOLUTO da entrada (base dos marcos). Timestamptz — instante, não data local.
  enteredAt      DateTime             @default(now()) @db.Timestamptz(3)
  origin         CardPhaseEntryOrigin
  /// Snapshot congelado da config de marcos da Fase no instante da entrada (D-OA1=A). Ver nota do model.
  configSnapshot Json
  createdAt      DateTime             @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  phase        Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  // "Entrada atual" e histórico: consulta por Card ordenada por instante de entrada.
  @@index([orgId, cardId, enteredAt])
  @@map("CardPhaseEntry")
}

/// CardPhaseValues — valores do Formulário de Fase por (Card, Fase) (Story 2.15). Dado operacional org-owned
/// (AD-10). É **append-only e IMUTÁVEL** (runtime só SELECT+INSERT — ver GRANT): registrar/corrigir valores é
/// INSERT (nova linha), NUNCA UPDATE/DELETE. O conjunto CORRENTE por (Card, Fase) é o mais recente por `createdAt`;
/// a correção posterior é uma nova linha + evento `PHASE_VALUES_CORRECTED` antes/depois no `CardHistory`.
///
/// **INV-FORM-01**: é DISTINTO de `Card.valores` (Formulário inicial, 2.7) — os três Formulários são independentes.
/// `valores` em JSONB por `Field.id` (opção por `id` — AD-11/AD-12), validado contra o snapshot da `FormVersion`
/// **publicada** (`formVersionId`, congelada — AD-12). Preenchido no requisito de ENTRADA na MESMA transação da
/// movimentação (2.14); no requisito de SAÍDA e na correção, validado/gravado no seu próprio fluxo.
model CardPhaseValues {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  cardId        String   @db.Uuid
  phaseId       String   @db.Uuid
  /// Versão publicada do Formulário de Fase contra a qual os valores foram validados (congelada — AD-12).
  formVersionId String   @db.Uuid
  /// Valores submetidos, chaveados por `Field.id` do snapshot (opção por `id`). Validados contra a versão.
  valores       Json     @default("{}")
  /// Ator que registrou/corrigiu (quando disponível). Referência de auditoria, não PII sensível.
  actorId       String?  @db.Uuid
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  phase        Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  formVersion  FormVersion  @relation(fields: [formVersionId], references: [id], onDelete: Cascade)

  // "Conjunto corrente" (mais recente por Card+Fase) e histórico das correções.
  @@index([orgId, cardId, phaseId, createdAt])
  @@map("CardPhaseValues")
}

/// MovementEvent — EVENTO CANÔNICO de movimentação de Card (Story 2.16). É a persistência confiável do tipo
/// **Outbox** (AD-13: registro do evento de integração confirmado ATOMICAMENTE com a movimentação; o processamento
/// assíncrono, se houver, vem depois). Trilha de INTEGRAÇÃO — DISTINTA do Histórico do Card (`CardHistory`) e das
/// demais trilhas (AD-15): o consumo é de E4 (Automação) e E5 (Notificação), **não** implementados aqui.
///
/// **Append-only e IMUTÁVEL**: o runtime recebe **só SELECT+INSERT** (sem UPDATE/DELETE — ver GRANT), como
/// `CardHistory`/`FormVersion`/`CardPhaseEntry`. Emitido SOMENTE quando a movimentação persiste, na MESMA transação
/// do UPDATE `phaseId` + `CardPhaseEntry`(MOVE) + `CardHistory`(MOVED) [+ `CardPhaseValues` da 2.15]; bloqueio,
/// no-op idempotente ou "aguardando confirmação" NÃO emitem (CA2). Rollback integral se qualquer gravação falhar.
///
/// **Idempotência (CA3):** `eventId` DETERMINÍSTICO — `uuidv5(orgId + cardId + correlationId)` — com
/// `@@unique([orgId, eventId])`: um reprocessamento técnico reproduz o MESMO `eventId`; o índice único impede
/// duplicata lógica. `correlationId` é gerado server-side por operação (linka o evento ao `MOVED`/`CardPhaseEntry`
/// da mesma movimentação). `type`+`version` versionam o envelope (AD-13). `payload` é o envelope mínimo, sem PII
/// desnecessária. **Este E2 NÃO controla idempotência de Automação/Notificação** — E4/E5 o fazem a partir do `eventId`.
model MovementEvent {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @db.Uuid
  /// Identidade lógica estável do evento (determinística por operação). Único por Organização.
  eventId       String   @db.Uuid
  pipeId        String   @db.Uuid
  cardId        String   @db.Uuid
  sourcePhaseId String   @db.Uuid
  targetPhaseId String   @db.Uuid
  /// Ator que originou a movimentação (quando disponível). Referência de auditoria.
  actorId       String?  @db.Uuid
  /// Origem da movimentação (espelha `CardPhaseEntryOrigin`; hoje `MOVE`). String — vocabulário estável.
  origin        String
  /// Momento efetivo da movimentação (instante absoluto).
  occurredAt    DateTime @default(now()) @db.Timestamptz(3)
  /// Chave de correlação da operação (linka evento ↔ MOVED ↔ CardPhaseEntry da mesma movimentação).
  correlationId String   @db.Uuid
  /// Tipo do envelope canônico (ex.: `CARD_MOVED`). Versão do contrato do envelope.
  type          String
  version       Int      @default(1)
  /// Envelope mínimo versionado (sem PII desnecessária), chaveado pelo contrato canônico.
  payload       Json     @default("{}")
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipe         Pipe         @relation(fields: [pipeId], references: [id], onDelete: Cascade)
  card         Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  sourcePhase  Phase        @relation("MovementEventSource", fields: [sourcePhaseId], references: [id], onDelete: Cascade)
  targetPhase  Phase        @relation("MovementEventTarget", fields: [targetPhaseId], references: [id], onDelete: Cascade)

  // Um reprocessamento não cria um 2º evento lógico.
  @@unique([orgId, eventId])
  // Leitura da trilha por Card (cronológica) e correlação com a operação.
  @@index([orgId, cardId, occurredAt])
  @@index([orgId, correlationId])
  @@map("MovementEvent")
}

/// SubmissaoPublica — submissão de um Formulário inicial PÚBLICO por ator externo (Story 2.8). Dado operacional
/// org-owned (AD-10). É entidade DISTINTA do Card, com ciclo PRÓPRIO (`SubmissaoPublicaState`): triagem NÃO é
/// estado do Card (`Fase ≠ Status do Card`). Referencia o `Form` inicial e a `FormVersion` publicada no ato;
/// `valores` em JSONB por `Field.id`, validados contra o snapshot (reusa `submission.ts` da 2.7). Em modo
/// `TRIAGE` nasce `PENDING`; aprovar cria 1 Card (origem `PUBLIC`) e marca `CONVERTED` com `cardId` na MESMA
/// transação (AD-13); rejeitar marca `REJECTED` (sem Card). Em modo `DIRECT` a submissão pública cria o Card
/// direto e nasce `CONVERTED`.
///
/// **Sem exclusão** (preserva por Governança/LGPD — NFR-8): o runtime tem `SELECT/INSERT/UPDATE`, **sem DELETE**.
/// Isolamento pelo banco (RLS ENABLE+FORCE, policies por `current_org_id()`, WITH CHECK). **Idempotência** da
/// conversão: `cardId` é único (`@@unique`) e o estado terminal `CONVERTED` guarda contra reconversão — nunca 2
/// Cards. `valores` são PII de titular externo: NUNCA em log.
model SubmissaoPublica {
  id             String                @id @default(uuid()) @db.Uuid
  orgId          String                @db.Uuid
  formId         String                @db.Uuid
  formVersionId  String                @db.Uuid
  state          SubmissaoPublicaState @default(PENDING)
  valores        Json                  @default("{}")
  /// Ponteiro do Card criado na conversão (null enquanto PENDING/REJECTED). Único: uma submissão ⇒ ≤1 Card.
  cardId         String?               @db.Uuid
  /// Chave de idempotência do cliente público (dedup de reenvio da mesma submissão lógica).
  idempotencyKey String?
  /// Ator que decidiu a triagem (aprovou/rejeitou), quando aplicável.
  decidedBy      String?               @db.Uuid
  decidedAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion  FormVersion  @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  card         Card?        @relation(fields: [cardId], references: [id], onDelete: SetNull)

  // Uma submissão convertida aponta no máximo um Card (idempotência da conversão).
  @@unique([cardId])
  // Dedup de reenvio público por Formulário.
  @@unique([orgId, formId, idempotencyKey])
  // Fila de triagem por Formulário e estado.
  @@index([orgId, formId, state])
  @@map("SubmissaoPublica")
}

/// PublicFormRoute — mapa GLOBAL e opaco de `publicId` → (`orgId`, `formId`) para resolver o tenant de uma
/// submissão pública ANTES de haver contexto (Story 2.8). GLOBAL e **SEM RLS por definição** (como `Account`,
/// AD-10): resolver o tenant não pode depender do contexto que ainda não existe. Guarda o MÍNIMO e **nenhuma
/// PII**: só o `publicId` aleatório/opaco (a URL pública), o `orgId` e o `formId` de destino.
///
/// O cliente público apresenta APENAS o `publicId`; o servidor resolve `(orgId, formId)`, entra em
/// `withTenantContext(orgId)` e RELÊ o `Form` sob RLS para validar (publicado, opt-in, versão, contexto) antes
/// de qualquer escrita — **nunca** aceita `orgId`/`formId` do cliente. `active=false` revoga (rotação = novo
/// `publicId`); link inválido/revogado/cross-tenant → 404 uniforme. Runtime: `SELECT` (resolver) + `INSERT`/
/// `UPDATE` (criar/revogar pela config autenticada), **sem DELETE** (revogar é estado, preserva a trilha).
model PublicFormRoute {
  id        String    @id @default(uuid()) @db.Uuid
  /// Identificador público OPACO e aleatório (a URL). Único global. Não deriva de orgId/formId.
  publicId  String    @unique
  orgId     String    @db.Uuid
  formId    String    @db.Uuid
  /// Revogação (link deixa de resolver). Rotação = revogar o antigo + criar um `publicId` novo.
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("PublicFormRoute")
}

/// Field — Campo de um Formulário (Story 2.4). Dado operacional org-owned (AD-10). O `id` é a IDENTIDADE
/// ESTÁVEL do Campo (AD-12): não depende do rótulo — renomear (na 2.5) não desloca valores.
///
/// `typeConfig` carrega o que VARIA por tipo (ex.: `options` de Seleção, cada uma com UUID estável; formato
/// de Número). Opções de Seleção vivem AQUI, em JSON com id estável — não em tabela própria (DBT-2.4-OPCOES-
/// JSON): assim criar um Campo de Seleção com suas opções é UM único `create` atômico, coerente com a recusa
/// de `$transaction` do `withTenantContext`. A validação do `typeConfig` por tipo vive no serviço.
///
/// `state` é ATRIBUTO desde a 2.4; arquivar/restaurar COM TRAVAS é da 2.5. Ordenação intra-Formulário por
/// chave fracionária (`position`), como `Phase`: mover = 1 UPDATE (ponto médio dos vizinhos). Isolamento pelo
/// banco (RLS); runtime SELECT/INSERT/UPDATE — **sem DELETE**.
model Field {
  id           String     @id @default(uuid()) @db.Uuid
  orgId        String     @db.Uuid
  formId       String     @db.Uuid
  label        String
  type         FieldType
  help         String?
  /// Config específica do tipo (ex.: `{ "options": [{ "id": uuid, "label": ..., "position": n }] }`).
  typeConfig   Json       @default("{}")
  /// Valor padrão do Campo (SQL NULL via `Prisma.DbNull` quando ausente).
  defaultValue Json?
  /// Chave de ordenação fracionária (ver nota do model). `numeric` de alta escala.
  position     Decimal    @db.Decimal(38, 18)
  /// Obrigatoriedade do Campo (Story 2.15). A Fase 1 não tinha obrigatoriedade (2.4-2.7); a 2.15 a introduz e o
  /// snapshot da publicação (2.6) a captura. É GATED ao Formulário de Fase (`context='PHASE'`) no serviço — o
  /// Formulário inicial (2.7) ignora obrigatoriedade. Default false: nada muda para Campos/Formulários existentes.
  required     Boolean    @default(false)
  state        FieldState @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  /// Momento do arquivamento (null quando ativo). Usado a partir da 2.5.
  archivedAt   DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)

  // Acesso começa por Org; a listagem por Formulário filtra estado e ordena por position.
  @@index([orgId, formId, state, position])
  @@map("Field")
}

/// Record — Registro: instância de DADO DO TITULAR de um Database (Story 3.4). Dado operacional org-owned
/// (AD-10). **Card ≠ Registro** (invariante conceitual): o Registro é o dado do Database; o Card é a unidade
/// que percorre o Pipe. O Registro pertence a EXATAMENTE UM Database (RN-063) e **não é transferível** — não há
/// rota nem GRANT que altere `databaseId`.
///
/// Criado por uma submissão do **Formulário de Database publicado** (3.3), reusando a maquinaria da submissão de
/// Card (2.7): referencia a `FormVersion` publicada no ato (`formVersionId`, imutável — AD-12) e guarda os
/// `valores` validados contra o snapshot em JSONB **chaveado por `Field.id`** (opção por `id`, nunca rótulo —
/// AD-11), não em tabela de valores por Campo. **Idempotência**: `idempotencyKey` + `@@unique([orgId,
/// databaseId, idempotencyKey])` — um retry da MESMA operação lógica devolve o Registro existente (nunca
/// duplica); P2002/P2028 → idempotente/409, nunca 500.
///
/// Ciclo de vida de **2 estados** (`ATIVO`/`ARQUIVADO` — sem `FINALIZADO`, que é do Card): arquivar é reversível
/// e não bloqueado por vínculos; restaurar volta a ATIVO (sem `previousLifecycleState`). Isolamento pelo banco
/// (RLS ENABLE+FORCE); GRANT column-scoped: o runtime pode UPDATE **só** `lifecycleState`/`valores`/`updatedAt`
/// (ciclo de vida 2.11 + edição de valores) e **sem DELETE** — arquivar é `state`, sem exclusão física (LGPD).
model Record {
  id             String               @id @default(uuid()) @db.Uuid
  orgId          String               @db.Uuid
  databaseId     String               @db.Uuid
  formId         String               @db.Uuid
  formVersionId  String               @db.Uuid
  /// Chave lógica da operação de criação (cliente). Garante idempotência via índice único org+database.
  idempotencyKey String
  /// Valores submetidos/editados, chaveados por `Field.id` do snapshot (opção por `id`). Validados contra a versão.
  valores        Json                 @default("{}")
  /// Origem do Registro. Story 3.4 materializa só `NOVO_REGISTRO` (criação interna); Automação (E4) e público
  /// entram com seus consumidores (AD-11).
  origin         RecordOrigin         @default(NOVO_REGISTRO)
  /// Estado de CICLO DE VIDA (Story 3.4), eixo próprio. Dois estados canônicos; `restaurado`/`arquivado` são
  /// TRANSIÇÕES. Coluna que o runtime pode UPDATE (GRANT column-scoped), junto de `valores`/`updatedAt`.
  lifecycleState RecordLifecycleState @default(ATIVO)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  database     Database        @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  form         Form            @relation(fields: [formId], references: [id], onDelete: Cascade)
  formVersion  FormVersion     @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  history      RecordHistory[]

  // Um retry da mesma operação lógica não cria um 2º Registro no mesmo Database.
  @@unique([orgId, databaseId, idempotencyKey])
  // Consulta por Database (a visualização 3.5 consumirá).
  @@index([orgId, databaseId])
  @@map("Record")
}

/// RecordHistory — trilha própria do Registro (write-side, Story 3.4). Dado operacional org-owned (AD-10). É
/// **append-only e IMUTÁVEL**: o runtime recebe **só SELECT+INSERT** (sem UPDATE/DELETE — ver GRANT), como
/// `CardHistory`/`FormVersion`. Distinta da Auditoria/Log técnico (AD-15): é histórico de negócio, legível.
///
/// Vocabulário inicial: `CREATED`/`VALUES_UPDATED`/`ARCHIVED`/`RESTORED`. Eventos de arquivo (3.8) e de vínculo
/// (3.9, com `correlationId`) entram com suas Stories. O evento é escrito na MESMA transação da mutação (AD-13):
/// não há Registro/mutação sem evento. Correção = NOVO evento (não altera o original — imutabilidade do banco).
/// A CONSULTA da timeline (projeção/autorização por acesso atual/mascaramento) é a 3.6 (read-side).
model RecordHistory {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  recordId  String   @db.Uuid
  /// Vocabulário do evento (3.4: CREATED/VALUES_UPDATED/ARCHIVED/RESTORED). String — a taxonomia cresce em 3.8/3.9.
  type      String
  /// Resumo legível do evento (sem PII desnecessária).
  summary   String
  /// Ator/iniciador que originou o evento (quando disponível).
  actorId   String?  @db.Uuid
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  record       Record       @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([orgId, recordId, createdAt])
  @@map("RecordHistory")
}

/// Estado de CICLO DE VIDA do Registro (Story 3.4). Dois estados canônicos e persistentes; `restaurado`/
/// `arquivado` NÃO são estados — são transições. Sem `FINALIZADO` (é do Card): restaurar volta sempre a ATIVO.
enum RecordLifecycleState {
  ATIVO
  ARQUIVADO
}

/// Origem do Registro (Story 3.4). Só `NOVO_REGISTRO` tem consumidor agora (criação interna autenticada);
/// `AUTOMACAO` (E4) e público entram com suas Stories (AD-11 — sem antecipar valores sem consumidor).
enum RecordOrigin {
  NOVO_REGISTRO
}
